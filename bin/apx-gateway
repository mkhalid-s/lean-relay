    "proxy-authenticate",
    "proxy-authorization",
    "te",
    "trailer",
    "transfer-encoding",
    "upgrade",
}

START_TIME = time.time()
_HISTORY: "collections.deque[dict]" = collections.deque(maxlen=HISTORY_SIZE)
_HISTORY_LOCK = threading.Lock()
_STATS = {
    "requests": 0,
    "latency_sum_ms": 0.0,
    "status_2xx": 0,
    "status_4xx": 0,
    "status_5xx": 0,
    "tokens_in": 0,
    "tokens_out": 0,
    "cost_est_usd": 0.0,
}
_STATS_LOCK = threading.Lock()
_HEALTH_CACHE: dict = {"ts": 0.0, "value": {}}
_HEALTH_LOCK = threading.Lock()
_LOG_STREAMS_BY_IP: "collections.defaultdict[str, int]" = collections.defaultdict(int)
_LOG_STREAMS_LOCK = threading.Lock()
_EVENT_STREAMS_BY_IP: "collections.defaultdict[str, int]" = collections.defaultdict(int)
_EVENT_STREAMS_LOCK = threading.Lock()
_EVENT_PAYLOAD_CACHE: dict[str, dict[str, Any]] = {}
_EVENT_PAYLOAD_CACHE_LOCK = threading.Lock()
_HISTORY_FH = None
_HISTORY_FH_DATE: str | None = None
_HISTORY_FH_LOCK = threading.Lock()


def log(message: str) -> None:
    print(f"[{time.strftime('%Y-%m-%dT%H:%M:%S%z')}] [apx-gateway] {message}", flush=True)


def _read_version() -> str:
    try:
        with open(VERSION_FILE, "r", encoding="utf-8") as fh:
            return fh.readline().strip() or "unknown"
    except OSError:
        return "unknown"


def _load_config_values() -> dict[str, str]:
    out: dict[str, str] = {}
    try:
        with open(CONFIG_FILE, "r", encoding="utf-8") as fh:
            for raw in fh:
                line = raw.strip()
                if not line or line.startswith("#") or "=" not in line:
                    continue
                key, value = line.split("=", 1)
                value = value.strip().strip('"').strip("'")
                out[key.strip()] = value
    except OSError:
        pass
    return out


_PRESET_BY_CHAIN = {
    "": "direct",
    "headroom": "headroom",
    "pxpipe": "pxpipe",
    "squeezr": "squeezr",
    "headroom,pxpipe": "headroom-pxpipe",
    "pxpipe,headroom": "pxpipe-headroom",
    "headroom,squeezr": "headroom-squeezr",
}


def _chain_from_config(cfg: dict[str, str]) -> list[str]:
    raw = os.environ.get("APX_CHAIN", cfg.get("APX_CHAIN", "")).strip().strip('"').strip("'")
    if raw:
        return [p.strip() for p in raw.split(",") if p.strip()]
    # Legacy inference for pre-chain configs.
    bind = cfg.get("BIND_HOST", "127.0.0.1")
    h = cfg.get("HEADROOM_ENABLED", "0")
    p = cfg.get("PXPIPE_ENABLED", "0")
    s = cfg.get("SQUEEZR_ENABLED", "0")
    gt = cfg.get("GATEWAY_TARGET_API_URL", "")
    pt = cfg.get("PXPIPE_TARGET_API_URL", "")
    pxp = f"http://{bind}:{cfg.get('PXPIPE_PORT', '47821')}"
    hdr = f"http://{bind}:{cfg.get('HEADROOM_PORT', '8788')}"
    if h == "1" and p == "1" and gt == pxp and pt == hdr:
        return ["pxpipe", "headroom"]
    if h == "1" and p == "1":
        return ["headroom", "pxpipe"]
    if h == "1" and s == "1":
        return ["headroom", "squeezr"]
    if h == "1":
        return ["headroom"]
    if p == "1":
        return ["pxpipe"]
    if s == "1":
        return ["squeezr"]
    return []


def _current_mode(cfg: dict[str, str]) -> str:
    if cfg.get("GATEWAY_ENABLED", "1") != "1":
        return "off"
    chain = _chain_from_config(cfg)
    return _PRESET_BY_CHAIN.get(",".join(chain), "custom")


def _chain_hops(cfg: dict[str, str], mode: str) -> list[str]:
    if mode == "off":
        return ["disabled"]
    hops = ["Claude", f"Gateway:{cfg.get('GATEWAY_PORT', '8787')}"]
    port_by_service = {
        "headroom": cfg.get("HEADROOM_PORT", "8788"),
        "pxpipe":   cfg.get("PXPIPE_PORT", "47821"),
        "squeezr":  cfg.get("SQUEEZR_PORT", "18780"),
    }
    label_by_service = {name: SERVICES[name]["label"] for name in SERVICES}
    for svc in _chain_from_config(cfg):
        label = label_by_service.get(svc, svc)
        port = port_by_service.get(svc, "?")
        hops.append(f"{label}:{port}")
    hops.append("Anthropic")
    return hops


def _service_ok(url: str, path: str = "/livez", timeout: float = 1.5) -> bool:
    try:
        target = urlsplit(url + path)
        cls = http.client.HTTPSConnection if target.scheme == "https" else http.client.HTTPConnection
        conn = cls(target.netloc, timeout=timeout)
        try:
            conn.request("GET", target.path or "/")
            resp = conn.getresponse()
            resp.read()
            return 200 <= resp.status < 500
        finally:
            conn.close()
    except Exception:
        return False


def _health_map_uncached(cfg: dict[str, str]) -> dict[str, str]:
    active = set(_chain_from_config(cfg))
    out: dict[str, str] = {"gateway": "ok"}
    for name, meta in SERVICES.items():
        if name not in active:
            out[name] = "disabled"
            continue
        out[name] = "ok" if _service_ok(str(meta["url"]), path=str(meta["health"])) else "fail"
    return out


def _health_snapshot(cfg: dict[str, str]) -> dict[str, str]:
    with _HEALTH_LOCK:
        cached = _HEALTH_CACHE.get("value") or {}
        return dict(cached) if cached else {"gateway": "ok"}


def _health_refresher_loop() -> None:
    while True:
        try:
            cfg = _load_config_values()
            snapshot = _health_map_uncached(cfg)
        except Exception:  # noqa: BLE001
            snapshot = {"gateway": "ok"}
        with _HEALTH_LOCK:
            _HEALTH_CACHE["value"] = snapshot
            _HEALTH_CACHE["ts"] = time.time()
        time.sleep(max(1.0, HEALTH_INTERVAL_SECONDS))


def _new_request_id() -> str:
    return f"apx-{secrets.token_hex(8)}"


def _model_from_path(path: str, body: bytes) -> str | None:
    if body:
        try:
            payload = json.loads(body.decode("utf-8", errors="replace"))
        except Exception:  # noqa: BLE001
            payload = None
        if isinstance(payload, dict):
            model = payload.get("model")
            if isinstance(model, str):
                return model
    return None


def _cost_estimate(model: str | None, tokens_in: int, tokens_out: int) -> float:
    if not model or (tokens_in <= 0 and tokens_out <= 0):
        return 0.0
    m = model.lower()
    for base, (rate_in, rate_out) in MODEL_COSTS.items():
        if m.startswith(base):
            return round((tokens_in / 1_000_000.0) * rate_in + (tokens_out / 1_000_000.0) * rate_out, 6)
    return 0.0


def _rotate_history_fh() -> "any":
    global _HISTORY_FH, _HISTORY_FH_DATE
    if not HISTORY_PERSIST:
        return None
    today = date.today().isoformat()
    if _HISTORY_FH is not None and _HISTORY_FH_DATE == today:
        return _HISTORY_FH
    try:
        if _HISTORY_FH is not None:
            _HISTORY_FH.close()
    except Exception:  # noqa: BLE001
        pass
    try:
        history_path = Path(HISTORY_DIR)
        history_path.mkdir(parents=True, exist_ok=True, mode=0o700)
        os.chmod(history_path, 0o700)
        file_path = os.path.join(HISTORY_DIR, f"{today}.jsonl")
        fd = os.open(file_path, os.O_WRONLY | os.O_CREAT | os.O_APPEND, 0o600)
        os.chmod(file_path, 0o600)
        _HISTORY_FH = os.fdopen(fd, "a", encoding="utf-8")
        _HISTORY_FH_DATE = today
    except OSError:
        _HISTORY_FH = None
        _HISTORY_FH_DATE = None
    return _HISTORY_FH


def _persist_history(entry: dict) -> None:
    with _HISTORY_FH_LOCK:
        fh = _rotate_history_fh()
        if fh is None:
            return
        try:
            fh.write(json.dumps(entry, separators=(",", ":")) + "\n")
            fh.flush()
        except Exception:  # noqa: BLE001
            pass


def _record_request(
    method: str,
    path: str,
    status: int,
    latency_ms: float,
    upstream: str,
    request_id: str = "",
    session_id: str = "",
    model: str | None = None,
    tokens_in: int = 0,
    tokens_out: int = 0,
    cache_read_tokens: int = 0,
    cache_write_tokens: int = 0,
    bytes_in: int = 0,
    bytes_out: int = 0,
    first_byte_ms: float = 0.0,
    chain_mode: str = "",
    chain_hops: str = "",
    hop_timings: str = "",
    is_stream: bool = False,
    tool_call_count: int = 0,
    err_class: str = "",
    request_body: str | None = None,
    response_body: str | None = None,
    request_headers: str | None = None,
) -> None:
    cost = _cost_estimate(model, tokens_in, tokens_out)
    ts = time.time()
    entry = {
        "ts": ts,
        "request_id": request_id,
        "session_id": session_id,
        "method": method,
        "path": path,
        "status": status,
        "latency_ms": round(latency_ms, 2),
        "first_byte_ms": round(first_byte_ms, 2),
        "upstream": upstream,
        "model": model or "",
        "tokens_in": tokens_in,
        "tokens_out": tokens_out,
        "cache_read_tokens": cache_read_tokens,
        "cache_write_tokens": cache_write_tokens,
        "cost_est_usd": cost,
        "bytes_in": bytes_in,
        "bytes_out": bytes_out,
        "chain_mode": chain_mode,
        "chain_hops": chain_hops,
        "hop_timings": hop_timings,
        "is_stream": bool(is_stream),
        "tool_call_count": tool_call_count,
        "err_class": err_class,
        "capture_level": CAPTURE_LEVEL,
    }
    with _HISTORY_LOCK:
        _HISTORY.append(entry)
    with _STATS_LOCK:
        _STATS["requests"] += 1
        _STATS["latency_sum_ms"] += latency_ms
        bucket = "status_2xx" if status < 400 else "status_4xx" if status < 500 else "status_5xx"
        _STATS[bucket] += 1
        _STATS["tokens_in"] += tokens_in
        _STATS["tokens_out"] += tokens_out
        _STATS["cost_est_usd"] += cost
    # JSONL audit log (always metadata-only regardless of capture level).
    _persist_history(entry)
    # Durable SQLite store. Body/headers captured only if CAPTURE_LEVEL=full.
    sqlite_row = dict(entry)
    sqlite_row["is_stream"] = int(bool(is_stream))
    sqlite_row["request_body"] = request_body if CAPTURE_LEVEL == "full" else None
    sqlite_row["response_body"] = response_body if CAPTURE_LEVEL == "full" else None
    sqlite_row["request_headers"] = request_headers if CAPTURE_LEVEL == "full" else None
    METRICS.insert(sqlite_row)


def _log_targets() -> dict[str, str]:
    """Discover streamable log files at request time.

    Every `*.log` in $LOG_DIR is exposed under its basename (minus the .log
    extension). Special targets (headroom.proxy) are added if the underlying
    file exists.
    """
    targets: dict[str, str] = {}
    try:
        for entry in os.listdir(LOG_DIR):
            if entry.endswith(".log"):
                targets[entry[:-4]] = os.path.join(LOG_DIR, entry)
    except OSError:
        pass
    if os.path.exists(HEADROOM_PROXY_LOG):
        targets["headroom.proxy"] = HEADROOM_PROXY_LOG
    return targets


def _fetch_json(url: str, timeout: float = 3.0) -> dict:
    target = urlsplit(url)
    cls = http.client.HTTPSConnection if target.scheme == "https" else http.client.HTTPConnection
    conn = cls(target.netloc, timeout=timeout)
    try:
        path = target.path or "/"
        if target.query:
            path = f"{path}?{target.query}"
        conn.request("GET", path)
        resp = conn.getresponse()
        body = resp.read()
        if resp.status >= 400:
            raise RuntimeError(f"upstream {url} returned {resp.status}")
        return json.loads(body.decode("utf-8"))
    finally:
        conn.close()


def _fetch_text(url: str, timeout: float = 3.0) -> tuple[int, str, str]:
    """GET url and return (status, content_type, text). Never raises."""
    try:
        target = urlsplit(url)
        cls = http.client.HTTPSConnection if target.scheme == "https" else http.client.HTTPConnection
        conn = cls(target.netloc, timeout=timeout)
        try:
            path = target.path or "/"
            if target.query:
                path = f"{path}?{target.query}"
            conn.request("GET", path)
            resp = conn.getresponse()
            ct = resp.getheader("content-type", "") or ""
            body = resp.read()
            return resp.status, ct, body.decode("utf-8", errors="replace")
        finally:
            conn.close()
    except Exception as exc:  # noqa: BLE001
        return 0, "", f"error: {exc}"


def _parse_prometheus_metrics(text: str) -> dict[str, Any]:
    """Parse a Prometheus exposition-format string into a compact JSON structure.

    Preserves label sets. Histograms are folded into `{name: {"_buckets": {le: value}, "_sum": s, "_count": c}}`.
    """
    metrics: dict[str, dict[str, Any]] = {}
    for raw in text.splitlines():
        line = raw.strip()
        if not line or line.startswith("#"):
            continue
        m = re.match(r"^([a-zA-Z_:][a-zA-Z0-9_:]*)(?:\{([^}]*)\})?\s+([-+]?\d*\.?\d+(?:[eE][-+]?\d+)?)(?:\s+\d+)?$", line)
        if not m:
            continue
        name, labels_raw, value_raw = m.group(1), m.group(2) or "", m.group(3)
        try:
            value = float(value_raw)
        except ValueError:
            continue
        labels: dict[str, str] = {}
        for pair in re.findall(r'([a-zA-Z_][a-zA-Z0-9_]*)="([^"]*)"', labels_raw):
            labels[pair[0]] = pair[1]
        # Detect histogram folding
        if name.endswith("_bucket") and "le" in labels:
            base = name[: -len("_bucket")]
            metrics.setdefault(base, {}).setdefault("_buckets", {})[labels["le"]] = value
        elif name.endswith("_sum"):
            base = name[: -len("_sum")]
            metrics.setdefault(base, {})["_sum"] = value
        elif name.endswith("_count"):
            base = name[: -len("_count")]
            metrics.setdefault(base, {})["_count"] = value
        else:
            entry = metrics.setdefault(name, {})
            if labels:
                entry.setdefault("_series", []).append({"labels": labels, "value": value})
            else:
                entry["_value"] = value
    return metrics


def _percentile(sorted_vals: list[float], pct: float) -> float:
    if not sorted_vals:
        return 0.0
    if pct <= 0:
        return sorted_vals[0]
    if pct >= 100:
        return sorted_vals[-1]
    k = (len(sorted_vals) - 1) * (pct / 100.0)
    f = int(k)
    c = min(f + 1, len(sorted_vals) - 1)
    if f == c:
        return sorted_vals[f]
    return sorted_vals[f] + (sorted_vals[c] - sorted_vals[f]) * (k - f)


def _window_seconds(window: str) -> float:
    m = {"5m": 300, "15m": 900, "1h": 3600, "6h": 21600, "24h": 86400, "7d": 7 * 86400, "30d": 30 * 86400}
    return float(m.get(window, 3600))


def _bucket_seconds(bucket: str) -> int:
    m = {"1m": 60, "5m": 300, "15m": 900, "1h": 3600, "6h": 21600, "1d": 86400}
    return int(m.get(bucket, 60))


def _bounded_int(value: str | None, default: int, lo: int, hi: int) -> int:
    try:
        n = int(value or default)
    except (TypeError, ValueError):
        n = default
    return max(lo, min(n, hi))


# --- API helpers for /api/metrics/* and /api/tool/* -------------------------
_TOOL_CACHE: dict[str, dict[str, Any]] = {}
_TOOL_CACHE_LOCK = threading.Lock()


def _tool_cached(key: str, ttl: float, fetch) -> dict[str, Any]:
    now = time.time()
    with _TOOL_CACHE_LOCK:
        entry = _TOOL_CACHE.get(key)
        if entry and now - entry.get("_ts", 0) < ttl:
            return entry["_value"]
    try:
        value = fetch()
    except Exception as exc:  # noqa: BLE001
        value = {"error": str(exc)}
    with _TOOL_CACHE_LOCK:
        _TOOL_CACHE[key] = {"_ts": now, "_value": value}
    return value


def _event_payload_cached(key: str, ttl: float, fetch) -> dict[str, Any]:
    """Single-flight cache for SSE payloads shared by all dashboard clients."""
    with _EVENT_PAYLOAD_CACHE_LOCK:
        now = time.time()
        entry = _EVENT_PAYLOAD_CACHE.get(key)
        if entry and now - float(entry.get("_ts", 0.0)) < ttl:
            return entry["_value"]
        value = fetch()
        _EVENT_PAYLOAD_CACHE[key] = {"_ts": time.time(), "_value": value}
        return value


def _api_metrics_summary(query: dict[str, list[str]]) -> dict[str, Any]:
    window = (query.get("window", ["1h"])[0] or "1h").lower()
    ws = _window_seconds(window)
    since = time.time() - ws
    if METRICS.enabled:
        rows = METRICS.query(
            "SELECT status, latency_ms, first_byte_ms, tokens_in, tokens_out, "
            "cache_read_tokens, cache_write_tokens, cost_est_usd, bytes_in, "
            "bytes_out, is_stream, tool_call_count, model FROM requests WHERE ts >= ?",
            (since,),
        )
    else:
        with _HISTORY_LOCK:
            rows = [dict(r) for r in _HISTORY if r.get("ts", 0) >= since]
    total = len(rows)
    ok = sum(1 for r in rows if 200 <= (r.get("status") or 0) < 400)
    warn = sum(1 for r in rows if 400 <= (r.get("status") or 0) < 500)
    err = sum(1 for r in rows if (r.get("status") or 0) >= 500)
    latencies = sorted(float(r.get("latency_ms") or 0) for r in rows if r.get("latency_ms"))
    first_bytes = sorted(float(r.get("first_byte_ms") or 0) for r in rows if r.get("first_byte_ms"))
    tokens_in = sum(int(r.get("tokens_in") or 0) for r in rows)
    tokens_out = sum(int(r.get("tokens_out") or 0) for r in rows)
    cache_read = sum(int(r.get("cache_read_tokens") or 0) for r in rows)
    cache_write = sum(int(r.get("cache_write_tokens") or 0) for r in rows)
    cost = sum(float(r.get("cost_est_usd") or 0) for r in rows)
    bytes_in = sum(int(r.get("bytes_in") or 0) for r in rows)
    bytes_out = sum(int(r.get("bytes_out") or 0) for r in rows)
    tool_calls = sum(int(r.get("tool_call_count") or 0) for r in rows)
    streams = sum(1 for r in rows if int(r.get("is_stream") or 0))
    # Per-model rollup
    by_model: dict[str, dict[str, Any]] = {}
    for r in rows:
        m = (r.get("model") or "").strip() or "unknown"
        e = by_model.setdefault(m, {"requests": 0, "tokens_in": 0, "tokens_out": 0, "cost_usd": 0.0, "latency_p50_ms": 0.0, "_lats": []})
        e["requests"] += 1
        e["tokens_in"] += int(r.get("tokens_in") or 0)
        e["tokens_out"] += int(r.get("tokens_out") or 0)
        e["cost_usd"] += float(r.get("cost_est_usd") or 0)
        e["_lats"].append(float(r.get("latency_ms") or 0))
    for e in by_model.values():
        lats = sorted(e.pop("_lats"))
        e["latency_p50_ms"] = round(_percentile(lats, 50), 2)
        e["latency_p95_ms"] = round(_percentile(lats, 95), 2)
        e["cost_usd"] = round(e["cost_usd"], 6)
    return {
        "window": window,
        "since_ts": since,
        "totals": {
            "requests": total,
            "ok": ok,
            "warn_4xx": warn,
            "err_5xx": err,
            "streams": streams,
            "tool_calls": tool_calls,
            "tokens_in": tokens_in,
            "tokens_out": tokens_out,
            "cache_read_tokens": cache_read,
            "cache_write_tokens": cache_write,
            "cost_est_usd": round(cost, 6),
            "bytes_in": bytes_in,
            "bytes_out": bytes_out,
        },
        "latency_ms": {
            "p50": round(_percentile(latencies, 50), 2),
            "p95": round(_percentile(latencies, 95), 2),
            "p99": round(_percentile(latencies, 99), 2),
            "avg": round(sum(latencies) / len(latencies), 2) if latencies else 0.0,
        },
        "first_byte_ms": {
            "p50": round(_percentile(first_bytes, 50), 2),
            "p95": round(_percentile(first_bytes, 95), 2),
        },
        "by_model": by_model,
    }


def _api_metrics_timeseries(query: dict[str, list[str]]) -> dict[str, Any]:
    window = (query.get("window", ["1h"])[0] or "1h").lower()
    bucket = (query.get("bucket", ["1m"])[0] or "1m").lower()
    ws = _window_seconds(window)
    bs = _bucket_seconds(bucket)
    since = time.time() - ws
    if METRICS.enabled:
        rows = METRICS.query(
            "SELECT ts, status, latency_ms, tokens_in, tokens_out, cost_est_usd "
            "FROM requests WHERE ts >= ? ORDER BY ts ASC",
            (since,),
        )
    else:
        with _HISTORY_LOCK:
            rows = [dict(r) for r in _HISTORY if r.get("ts", 0) >= since]
    buckets: dict[int, dict[str, float]] = {}
    for r in rows:
        b = int((r.get("ts") or 0) // bs) * bs
        e = buckets.setdefault(b, {"requests": 0, "err": 0, "tokens_in": 0, "tokens_out": 0, "cost_usd": 0.0, "_lats": []})
        e["requests"] += 1
        if (r.get("status") or 0) >= 400:
            e["err"] += 1
        e["tokens_in"] += int(r.get("tokens_in") or 0)
        e["tokens_out"] += int(r.get("tokens_out") or 0)
        e["cost_usd"] += float(r.get("cost_est_usd") or 0)
        e["_lats"].append(float(r.get("latency_ms") or 0))
    series = []
    now_bucket = int(time.time() // bs) * bs
    first_bucket = int(since // bs) * bs
    bucket_count = ((now_bucket - first_bucket) // bs) + 1
    bucket_keys = (
        range(first_bucket, now_bucket + bs, bs)
        if bucket_count <= 5000
        else sorted(buckets.keys())
    )
    for b in bucket_keys:
        e = buckets.get(b, {"requests": 0, "err": 0, "tokens_in": 0, "tokens_out": 0, "cost_usd": 0.0, "_lats": []})
        lats = sorted(e.pop("_lats"))
        series.append({
            "ts": b,
            "requests": e["requests"],
            "err": e["err"],
            "tokens_in": e["tokens_in"],
            "tokens_out": e["tokens_out"],
            "cost_usd": round(e["cost_usd"], 6),
            "latency_p50_ms": round(_percentile(lats, 50), 2),
            "latency_p95_ms": round(_percentile(lats, 95), 2),
        })
    return {"window": window, "bucket": bucket, "since_ts": since, "series": series}


def _api_metrics_sessions(query: dict[str, list[str]]) -> dict[str, Any]:
    limit = _bounded_int(query.get("limit", ["50"])[0], 50, 1, 500)
    window = (query.get("window", ["24h"])[0] or "24h").lower()
    since = time.time() - _window_seconds(window)
    if METRICS.enabled:
        rows = METRICS.query(
            "SELECT session_id, MIN(ts) AS first_ts, MAX(ts) AS last_ts, COUNT(*) AS requests, "
            "SUM(tokens_in) AS tokens_in, SUM(tokens_out) AS tokens_out, "
            "SUM(cost_est_usd) AS cost_usd, SUM(tool_call_count) AS tool_calls, "
            "AVG(latency_ms) AS avg_latency_ms, "
            "(SELECT r2.chain_mode FROM requests r2 WHERE r2.session_id = requests.session_id AND r2.ts >= ? "
            " ORDER BY r2.ts DESC, r2.id DESC LIMIT 1) AS chain_mode, "
            "(SELECT r3.model FROM requests r3 WHERE r3.session_id = requests.session_id AND r3.ts >= ? "
            " ORDER BY r3.ts DESC, r3.id DESC LIMIT 1) AS last_model "
            "FROM requests WHERE ts >= ? AND session_id != '' "
            "GROUP BY session_id ORDER BY last_ts DESC LIMIT ?",
            (since, since, since, limit),
        )
    else:
        # In-memory fallback: group history entries.
        with _HISTORY_LOCK:
            hist = [dict(r) for r in _HISTORY if r.get("ts", 0) >= since and r.get("session_id")]
        grouped: dict[str, dict[str, Any]] = {}
        for r in hist:
            sid = r.get("session_id") or ""
            e = grouped.setdefault(sid, {
                "session_id": sid, "first_ts": r["ts"], "last_ts": r["ts"],
                "requests": 0, "tokens_in": 0, "tokens_out": 0, "cost_usd": 0.0,
                "tool_calls": 0, "_lat_sum": 0.0, "chain_mode": r.get("chain_mode", ""),
                "last_model": r.get("model", ""),
            })
            e["requests"] += 1
            e["tokens_in"] += int(r.get("tokens_in") or 0)
            e["tokens_out"] += int(r.get("tokens_out") or 0)
            e["cost_usd"] += float(r.get("cost_est_usd") or 0)
            e["tool_calls"] += int(r.get("tool_call_count") or 0)
            e["_lat_sum"] += float(r.get("latency_ms") or 0)
            e["first_ts"] = min(e["first_ts"], r["ts"])
            e["last_ts"] = max(e["last_ts"], r["ts"])
            e["last_model"] = r.get("model") or e["last_model"]
        rows = []
        for e in grouped.values():
            e["avg_latency_ms"] = e["_lat_sum"] / e["requests"] if e["requests"] else 0.0
            del e["_lat_sum"]
            rows.append(e)
        rows.sort(key=lambda x: x["last_ts"], reverse=True)
        rows = rows[:limit]
    return {"window": window, "sessions": rows, "count": len(rows)}


def _api_metrics_session_detail(session_id: str, query: dict[str, list[str]]) -> dict[str, Any]:
    if not session_id:
        return {"error": "session_id required", "requests": []}
    if METRICS.enabled:
        rows = METRICS.query(
            "SELECT id, ts, request_id, method, path, model, status, latency_ms, first_byte_ms, "
            "tokens_in, tokens_out, cache_read_tokens, cache_write_tokens, cost_est_usd, "
            "bytes_in, bytes_out, chain_mode, chain_hops, hop_timings, is_stream, "
            "tool_call_count, err_class, capture_level "
            "FROM requests WHERE session_id = ? ORDER BY ts ASC LIMIT 5000",
            (session_id,),
        )
    else:
        with _HISTORY_LOCK:
            rows = [dict(r) for r in _HISTORY if r.get("session_id") == session_id]
    # Include full bodies only when explicitly requested AND capture=full.
    if query.get("include_body", ["0"])[0] in ("1", "true", "yes") and CAPTURE_LEVEL == "full" and METRICS.enabled:
        detail = METRICS.query(
            "SELECT id, request_body, response_body, request_headers "
            "FROM requests WHERE session_id = ? ORDER BY ts ASC LIMIT 5000",
            (session_id,),
        )
        detail_by_id = {d.get("id"): d for d in detail}
        for r in rows:
            d = detail_by_id.get(r.get("id")) or {}
            r["request_body"] = d.get("request_body")
            r["response_body"] = d.get("response_body")
            r["request_headers"] = d.get("request_headers")
    return {"session_id": session_id, "requests": rows, "count": len(rows)}


# --- Tool proxy endpoints (feature-detect + per-tool aggregate) --------------
def _cfg_now() -> dict[str, str]:
    return _load_config_values()


def _service_is_enabled(cfg: dict[str, str], name: str) -> bool:
    active = set(_chain_from_config(cfg))
    if name in active:
        return True
    flag = {"headroom": "HEADROOM_ENABLED", "pxpipe": "PXPIPE_ENABLED", "squeezr": "SQUEEZR_ENABLED"}.get(name)
    return bool(flag and cfg.get(flag) == "1")


def _api_tool_headroom() -> dict[str, Any]:
    def _fetch():
        stats_status, _, stats_body = _fetch_text(HEADROOM_URL + "/stats", timeout=2.5)
        try:
            stats = json.loads(stats_body) if stats_status == 200 else {"_error": f"stats status {stats_status}"}
        except Exception:  # noqa: BLE001
            stats = {"_error": "invalid json from /stats"}
        prom_status, _, prom_body = _fetch_text(HEADROOM_URL + "/metrics", timeout=2.5)
        prom = _parse_prometheus_metrics(prom_body) if prom_status == 200 else {}
        # Extract normalized fields for the unified card.
        lifetime = ((stats.get("persistent_savings") or {}).get("lifetime") or {}) if isinstance(stats, dict) else {}
        tokens = (stats.get("tokens") or {}) if isinstance(stats, dict) else {}
        cache = (stats.get("cache") or {}) if isinstance(stats, dict) else {}
        requests = (stats.get("requests") or {}) if isinstance(stats, dict) else {}
        normalized = {
            "tokens_saved_lifetime": int(lifetime.get("tokens_saved") or 0),
            "tokens_saved_session": int(tokens.get("saved") or 0),
            "savings_pct_session": float(tokens.get("savings_percent") or 0),
            "usd_saved_lifetime": float(lifetime.get("compression_savings_usd") or 0),
            "cache_entries": int(cache.get("entries") or 0),
            "cache_hits": int(cache.get("total_hits") or 0),
            "requests_total": int(requests.get("total") or 0),
            "requests_failed": int(requests.get("failed") or 0),
        }
        return {
            "reachable": stats_status == 200,
            "status": stats_status,
            "normalized": normalized,
            "stats": stats,
            "prometheus": prom,
        }
    return _tool_cached("headroom", 2.0, _fetch)


def _api_tool_pxpipe() -> dict[str, Any]:
    def _fetch():
        ps_status, _, ps_body = _fetch_text(PXPIPE_URL + "/proxy-stats", timeout=2.5)
        try:
            proxy_stats = json.loads(ps_body) if ps_status == 200 else {"_error": f"proxy-stats status {ps_status}"}
        except Exception:  # noqa: BLE001
            proxy_stats = {"_error": "invalid json from /proxy-stats"}
        as_status, _, as_body = _fetch_text(PXPIPE_URL + "/api/stats.json", timeout=3.0)
        try:
            api_stats = json.loads(as_body) if as_status == 200 else {}
        except Exception:  # noqa: BLE001
            api_stats = {}
        cs_status, _, cs_body = _fetch_text(PXPIPE_URL + "/api/current-session.json", timeout=2.0)
        try:
            current_session = json.loads(cs_body) if cs_status == 200 else {}
        except Exception:  # noqa: BLE001
            current_session = {}
        summary = api_stats.get("summary") or {}
        normalized = {
            "requests_total": int(proxy_stats.get("requests") or 0),
            "compressed_requests": int(proxy_stats.get("compressed_requests") or 0),
            "saved_input_tokens": int(proxy_stats.get("saved_input_tokens") or 0),
            "saved_pct_input_only": float(proxy_stats.get("saved_pct_input_only") or 0),
            "saved_pct_of_all_spend": float(proxy_stats.get("saved_pct_of_all_spend") or 0),
            "saved_usd": float(proxy_stats.get("saved_usd") or 0),
            "compression_enabled": bool(proxy_stats.get("compression_enabled", True)),
            "compressed_avg_usd_per_request": float(proxy_stats.get("compressed_avg_usd_per_request") or 0),
            "passthrough_avg_usd_per_request": float(proxy_stats.get("passthrough_avg_usd_per_request") or 0),
            "split_sufficient_sample": bool(proxy_stats.get("split_sufficient_sample", False)),
            "cache_hit_rate": (
                float(summary.get("cacheHitEvents") or 0) / float(summary.get("eventsWithUsage") or 1)
                if summary.get("eventsWithUsage")
                else 0.0
            ),
            "duration_p95_ms": int(summary.get("durationP95") or 0),
            "first_byte_p95_ms": int(summary.get("firstByteP95") or 0),
            "orig_chars_total": int(summary.get("origCharsTotal") or 0),
            "image_bytes_total": int(summary.get("imageBytesTotal") or 0),
            "uptime_sec": float(proxy_stats.get("uptime_sec") or 0),
        }
        return {
            "reachable": ps_status == 200,
            "status": ps_status,
            "normalized": normalized,
            "proxy_stats": proxy_stats,
            "api_stats": api_stats,
            "current_session": current_session,
        }
    return _tool_cached("pxpipe", 2.0, _fetch)


def _api_tool_squeezr() -> dict[str, Any]:
    def _fetch():
        h_status, _, h_body = _fetch_text(SQUEEZR_URL + "/squeezr/health", timeout=2.0)
        try:
            health = json.loads(h_body) if h_status == 200 else {}
        except Exception:  # noqa: BLE001
            health = {}
        s_status, _, s_body = _fetch_text(SQUEEZR_URL + "/squeezr/stats", timeout=2.5)
        try:
            stats = json.loads(s_body) if s_status == 200 else {"_error": f"stats status {s_status}"}
        except Exception:  # noqa: BLE001
            stats = {"_error": "invalid json from /squeezr/stats"}
        l_status, _, l_body = _fetch_text(SQUEEZR_URL + "/squeezr/limits", timeout=2.0)
        try:
            limits = json.loads(l_body) if l_status == 200 else {}
        except Exception:  # noqa: BLE001
            limits = {}
        is_squeezr = isinstance(health, dict) and health.get("identity") == "squeezr"
        latency = (stats.get("latency") or {}).get("total") or {} if isinstance(stats, dict) else {}
        breakdown = stats.get("breakdown") or {} if isinstance(stats, dict) else {}
        expand = stats.get("expand") or {} if isinstance(stats, dict) else {}
        normalized = {
            "requests_total": int(stats.get("requests") or 0),
            "compressions": int(stats.get("compressions") or 0),
            "session_cache_hits": int(stats.get("session_cache_hits") or 0),
            "total_saved_tokens": int(stats.get("total_saved_tokens") or 0),
            "savings_pct": float(stats.get("savings_pct") or 0),
            "latency_p50_ms": float(latency.get("p50") or 0),
            "latency_p95_ms": float(latency.get("p95") or 0),
            "latency_p99_ms": float(latency.get("p99") or 0),
            "bypassed": bool(health.get("bypassed", False)) if isinstance(health, dict) else False,
            "mode": (health.get("mode") if isinstance(health, dict) else "") or (stats.get("mode") if isinstance(stats, dict) else ""),
            "circuit_breaker_state": ((health.get("circuit_breaker") or {}).get("state")
                                       if isinstance(health, dict) else "unknown"),
            "expand_rate_pct": float(expand.get("rate_pct") or 0),
            "breakdown": breakdown,
        }
        return {
            "reachable": is_squeezr,
            "identity_ok": is_squeezr,
            "status": s_status,
            "normalized": normalized,
            "health": health,
            "stats": stats,
            "limits": limits,
        }
    return _tool_cached("squeezr", 2.0, _fetch)


def _api_tool_detect() -> dict[str, Any]:
    cfg = _cfg_now()
    out: dict[str, Any] = {"tools": {}, "capture": {"level": CAPTURE_LEVEL}}
    for name in ("headroom", "pxpipe", "squeezr"):
        enabled = _service_is_enabled(cfg, name)
        entry: dict[str, Any] = {"enabled": enabled, "reachable": False, "doing_work": False, "note": ""}
        if not enabled:
            out["tools"][name] = entry
            continue
        try:
            data = {"headroom": _api_tool_headroom, "pxpipe": _api_tool_pxpipe, "squeezr": _api_tool_squeezr}[name]()
            entry["reachable"] = bool(data.get("reachable"))
            n = data.get("normalized") or {}
            if name == "headroom":
                entry["doing_work"] = int(n.get("tokens_saved_session") or 0) > 0 or int(n.get("tokens_saved_lifetime") or 0) > 0
            elif name == "pxpipe":
                entry["doing_work"] = int(n.get("compressed_requests") or 0) > 0
            elif name == "squeezr":
                entry["doing_work"] = int(n.get("compressions") or 0) > 0
            if not entry["reachable"]:
                entry["note"] = "process not reachable on configured port"
            elif not entry["doing_work"]:
                entry["note"] = "reachable but no compression activity yet"
        except Exception as exc:  # noqa: BLE001
            entry["note"] = f"probe error: {exc}"
        out["tools"][name] = entry
    return out


def _api_tool_compare() -> dict[str, Any]:
    """Return normalized side-by-side rows for whichever tools are enabled."""
    detect = _api_tool_detect()
    rows: list[dict[str, Any]] = []
    tools = detect.get("tools") or {}
    if tools.get("headroom", {}).get("reachable"):
        h = (_api_tool_headroom() or {}).get("normalized") or {}
        rows.append({
            "tool": "headroom",
            "tokens_saved_lifetime": h.get("tokens_saved_lifetime", 0),
            "tokens_saved_session": h.get("tokens_saved_session", 0),
            "savings_pct": h.get("savings_pct_session", 0),
            "usd_saved": h.get("usd_saved_lifetime", 0),
            "cache_hit_rate": (h.get("cache_hits", 0) / max(h.get("requests_total", 1), 1)) if h.get("requests_total") else 0,
            "requests_total": h.get("requests_total", 0),
            "bypassed": False,
        })
    if tools.get("pxpipe", {}).get("reachable"):
        p = (_api_tool_pxpipe() or {}).get("normalized") or {}
        rows.append({
            "tool": "pxpipe",
            "tokens_saved_lifetime": p.get("saved_input_tokens", 0),
            "tokens_saved_session": p.get("saved_input_tokens", 0),
            "savings_pct": p.get("saved_pct_of_all_spend") or p.get("saved_pct_input_only", 0),
            "usd_saved": p.get("saved_usd", 0),
            "cache_hit_rate": p.get("cache_hit_rate", 0),
            "requests_total": p.get("requests_total", 0),
            "bypassed": not bool(p.get("compression_enabled", True)),
        })
    if tools.get("squeezr", {}).get("reachable"):
        s = (_api_tool_squeezr() or {}).get("normalized") or {}
        rows.append({
            "tool": "squeezr",
            "tokens_saved_lifetime": s.get("total_saved_tokens", 0),
            "tokens_saved_session": s.get("total_saved_tokens", 0),
            "savings_pct": s.get("savings_pct", 0),
            "usd_saved": None,
            "cache_hit_rate": (s.get("session_cache_hits", 0) / max(s.get("requests_total", 1), 1)) if s.get("requests_total") else 0,
            "requests_total": s.get("requests_total", 0),
            "bypassed": bool(s.get("bypassed", False)),
        })
    return {"rows": rows, "count": len(rows)}


def _read_dashboard_html() -> bytes:
    if DASHBOARD_HTML_PATH:
        p = Path(DASHBOARD_HTML_PATH)
        if p.is_file():
            return p.read_bytes()
    for candidate in [
        Path(__file__).resolve().parent.parent / "share" / "dashboard.html",
        Path.home() / ".local" / "share" / "apx" / "dashboard.html",
    ]:
        if candidate.is_file():
            return candidate.read_bytes()
    return b"<!doctype html><meta charset=utf-8><title>apx</title><h1>apx dashboard not installed</h1>"


class RequestBodyTooLarge(Exception):
    pass


class ApxHTTPServer(ThreadingHTTPServer):
    """ThreadingHTTPServer with quiet handling for normal browser disconnects."""

    def handle_error(self, request, client_address) -> None:  # noqa: ANN001
        exc = sys.exc_info()[1]
        if isinstance(exc, (BrokenPipeError, ConnectionResetError, ConnectionAbortedError)):
            log(f"client disconnected before request completed: {client_address[0]}:{client_address[1]}")
            return
        super().handle_error(request, client_address)


class GatewayHandler(BaseHTTPRequestHandler):
    protocol_version = "HTTP/1.1"
    server_version = "apx-gateway/0.1"

    def log_message(self, fmt: str, *args: object) -> None:
        safe_args = list(args)
        if safe_args and isinstance(safe_args[0], str):
            parts = safe_args[0].split(" ", 2)
            if len(parts) == 3 and parts[1].startswith("/"):
                parts[1] = _scrub_url_path(parts[1])
                safe_args[0] = " ".join(parts)
        msg = fmt % tuple(safe_args)
        msg = re.sub(r"([?&](?:token|api_key|apikey|api-key|authorization|password|secret)=)[^&\s\"]+", r"\1REDACTED", msg, flags=re.I)
        log(msg)

    def do_GET(self) -> None:  # noqa: N802
        if self._handle_dashboard_or_api():
            return
        if self.path in {"/livez", "/readyz", "/health"}:
            self._json(200, {"ok": True, "target": TARGET_URL})
            return
        self._proxy()

    def do_HEAD(self) -> None:  # noqa: N802
        if self._handle_dashboard_or_api():
            return
        if self.path in {"/", "/livez", "/readyz", "/health"}:
            self.send_response(200)
            self.send_header("content-type", "application/json")
            self.send_header("content-length", "0")
            self.send_header("connection", "close")
            self.end_headers()
            return
        self._proxy()

    def do_POST(self) -> None:  # noqa: N802
        if self._handle_dashboard_or_api():
            return
        self._proxy()

    def do_PUT(self) -> None:  # noqa: N802
        if self._handle_dashboard_or_api():
            return
        self._proxy()

    def do_PATCH(self) -> None:  # noqa: N802
        if self._handle_dashboard_or_api():
            return
        self._proxy()

    def do_DELETE(self) -> None:  # noqa: N802
        if self._handle_dashboard_or_api():
            return
        self._proxy()

    def do_OPTIONS(self) -> None:  # noqa: N802
        if self._handle_dashboard_or_api():
            return
        self._proxy()

    def _client_ip(self) -> str:
        try:
            return self.client_address[0]
        except Exception:  # noqa: BLE001
            return "unknown"

    def _dashboard_host_allowed(self) -> bool:
        host_header = self.headers.get("host", "")
        try:
            hostname = (urlsplit(f"//{host_header}").hostname or "").lower()
        except ValueError:
            return False
        allowed = {"127.0.0.1", "::1", "localhost", "host.docker.internal"}
        if BIND_HOST not in {"0.0.0.0", "::"}:
            allowed.add(BIND_HOST.lower())
        return hostname in allowed or bool(DASHBOARD_TOKEN and self._authorized_for_dashboard())

    def _dashboard_origin_allowed(self) -> bool:
        if self.headers.get("sec-fetch-site", "").lower() == "cross-site":
            return False
        origin = self.headers.get("origin", "")
        if not origin:
            return True
        try:
            origin_host = (urlsplit(origin).hostname or "").lower()
            request_host = (urlsplit(f"//{self.headers.get('host', '')}").hostname or "").lower()
        except ValueError:
            return False
        return origin_host == request_host

    def _authorized_for_dashboard(self, allow_query: bool = True) -> bool:
        if not DASHBOARD_TOKEN:
            return True
        provided = ""
        auth = self.headers.get("authorization", "")
        if auth.lower().startswith("bearer "):
            provided = auth[7:].strip()
        if not provided:
            cookie = self.headers.get("cookie", "")
            for part in cookie.split(";"):
                key, sep, value = part.strip().partition("=")
                if sep and key == DASHBOARD_COOKIE_NAME:
                    provided = unquote(value).strip()
                    break
        if allow_query and not provided:
            parsed = urlsplit(self.path)
            provided = (parse_qs(parsed.query).get("token", [""])[0] or "").strip()
        return secrets.compare_digest(provided, DASHBOARD_TOKEN)

    def _dashboard_cookie_headers(self) -> dict[str, str]:
        if not DASHBOARD_TOKEN:
            return {}
        provided = ""
        auth = self.headers.get("authorization", "")
        if auth.lower().startswith("bearer "):
            provided = auth[7:].strip()
        if not provided:
            parsed = urlsplit(self.path)
            provided = (parse_qs(parsed.query).get("token", [""])[0] or "").strip()
        if provided and secrets.compare_digest(provided, DASHBOARD_TOKEN):
            return {
                "set-cookie": (
                    f"{DASHBOARD_COOKIE_NAME}={quote(provided, safe='')}; "
                    "Path=/; HttpOnly; SameSite=Lax"
                )
            }
        return {}

    def _drop_dashboard_token_query(self, query: str) -> str:
        if not query:
            return ""
        parts = []
        for raw in query.split("&"):
            key = raw.partition("=")[0]
            if unquote(key).lower() == "token":
                continue
            parts.append(raw)
        return "&".join(parts)

    def _handle_dashboard_or_api(self) -> bool:
        if not DASHBOARD_ENABLED:
            return False
        parsed = urlsplit(self.path)
        path = parsed.path
        query = parse_qs(parsed.query)
        passthrough_query = self._drop_dashboard_token_query(parsed.query)
        is_dashboard_path = (
            path in {"/", "/dashboard", "/metrics"}
            or path.startswith("/api/")
            or path.startswith("/proxy/pxpipe")
            or path.startswith("/proxy/squeezr")
        )
        if is_dashboard_path and not self._dashboard_host_allowed():
            self._respond_json(403, {"error": "dashboard_host_forbidden"})
            return True
        if is_dashboard_path and not self._dashboard_origin_allowed():
            self._respond_json(403, {"error": "cross_site_dashboard_request_forbidden"})
            return True

        if path.startswith("/proxy/pxpipe/") or path == "/proxy/pxpipe":
            if not self._authorized_for_dashboard(allow_query=False):
                self._require_token()
                return True
            self._passthrough(PXPIPE_URL, path[len("/proxy/pxpipe"):] or "/", passthrough_query, prefix="/proxy/pxpipe")
            return True
        if path.startswith("/proxy/squeezr/") or path == "/proxy/squeezr":
            if not self._authorized_for_dashboard(allow_query=False):
                self._require_token()
                return True
            self._passthrough(SQUEEZR_URL, path[len("/proxy/squeezr"):] or "/squeezr/dashboard", passthrough_query, prefix="/proxy/squeezr")
            return True

        if path in ("/", "/dashboard"):
            if not self._authorized_for_dashboard():
                self._require_token()
                return True
            cookie_headers = self._dashboard_cookie_headers()
            if cookie_headers and "token" in query:
                location = path
                if passthrough_query:
                    location = f"{location}?{passthrough_query}"
                self._redirect(303, location, cookie_headers)
                return True
            body = _read_dashboard_html()
            self._respond(200, body, content_type="text/html; charset=utf-8", extra_headers=cookie_headers)
            return True
        if path.startswith("/api/"):
            if not self._authorized_for_dashboard():
                self._respond_json(401, {"error": "unauthorized", "hint": "set APX_DASHBOARD_TOKEN and pass ?token= or Authorization: Bearer"})
                return True
        if path == "/api/status":
            self._respond_json(200, self._build_status_payload())
            return True
        if path == "/api/history":
            n = _bounded_int((query.get("n", ["100"])[0]), 100, 1, HISTORY_SIZE)
            with _HISTORY_LOCK:
                items = list(_HISTORY)[-n:]
            self._respond_json(200, {"items": items, "size": HISTORY_SIZE})
            return True
        if path == "/api/headroom/stats":
            try:
                data = _fetch_json(HEADROOM_URL + "/stats")
                self._respond_json(200, data)
            except Exception as exc:  # noqa: BLE001
                self._respond_json(502, {"error": str(exc)})
            return True
        # --- 0.4.0 metrics + tool APIs --------------------------------------
        if path == "/api/metrics/summary":
            self._respond_json(200, _api_metrics_summary(query))
            return True
        if path == "/api/metrics/timeseries":
            self._respond_json(200, _api_metrics_timeseries(query))
            return True
        if path == "/api/metrics/sessions":
            self._respond_json(200, _api_metrics_sessions(query))
            return True
        if path.startswith("/api/metrics/session/"):
            sid = unquote(path[len("/api/metrics/session/") :])
            self._respond_json(200, _api_metrics_session_detail(sid, query))
            return True
        if path == "/api/tool/detect":
            self._respond_json(200, _api_tool_detect())
            return True
        if path == "/api/tool/headroom":
            self._respond_json(200, _api_tool_headroom())
            return True
        if path == "/api/tool/pxpipe":
            self._respond_json(200, _api_tool_pxpipe())
            return True
        if path == "/api/tool/squeezr":
            self._respond_json(200, _api_tool_squeezr())
            return True
        if path == "/api/tool/compare":
            self._respond_json(200, _api_tool_compare())
            return True
        if path == "/api/capture":
            self._respond_json(200, {
                "level": CAPTURE_LEVEL,
                "ack_ok": (CAPTURE_LEVEL != "full") or (CAPTURE_FULL_ACK == "i-understand"),
                "body_cap_bytes": CAPTURE_BODY_CAP,
                "redact_extra": list(REDACT_KEYS_EXTRA),
                "sqlite_enabled": METRICS.enabled,
                "sqlite_error": METRICS.error,
                "sqlite_path": METRICS.path if METRICS.enabled else None,
                "retention_days": METRICS_RETENTION_DAYS,
            })
            return True
        if path == "/api/events/stream":
            window = (query.get("window", ["1h"])[0] or "1h").lower()
            self._stream_events(window)
            return True
        if path == "/api/logs/stream":
            service = (query.get("service", ["supervisor"])[0]) or "supervisor"
            self._stream_log(service)
            return True
        if path == "/api/logs/targets":
            self._respond_json(200, {"targets": sorted(_log_targets().keys())})
            return True
        if path.startswith("/api/"):
            self._respond_json(404, {"error": "not_found", "path": path})
            return True
        if path == "/metrics":
            if not self._authorized_for_dashboard():
                self._respond_json(401, {"error": "unauthorized"})
                return True
            if not METRICS_ENABLED:
                self._respond_json(404, {"error": "metrics disabled; set APX_METRICS_ENABLED=1"})
                return True
            self._respond(200, self._build_metrics_payload(), content_type="text/plain; version=0.0.4; charset=utf-8")
            return True
        return False

    def _require_token(self) -> None:
        body = (
            b"<!doctype html><meta charset=utf-8><title>apx</title>"
            b"<h1>apx dashboard</h1><p>Set <code>APX_DASHBOARD_TOKEN</code> and open with "
            b"<code>?token=...</code> or an <code>Authorization: Bearer</code> header.</p>"
        )
        self._respond(401, body, content_type="text/html; charset=utf-8")

    def _redirect(self, status: int, location: str, headers: dict[str, str] | None = None) -> None:
        extra = dict(headers or {})
        extra["location"] = location
        self._respond(status, b"", content_type="text/plain; charset=utf-8", extra_headers=extra)

    def _rewrite_proxied_html(self, body: bytes, prefix: str, content_type: str) -> bytes:
        if not prefix or "text/html" not in (content_type or "").lower():
            return body
        try:
            text = body.decode("utf-8", errors="replace")
        except Exception:  # noqa: BLE001
            return body
        replacements = {
            'href="/': f'href="{prefix}/',
            "href='/": f"href='{prefix}/",
            'src="/': f'src="{prefix}/',
            "src='/": f"src='{prefix}/",
            'action="/': f'action="{prefix}/',
            "action='/": f"action='{prefix}/",
            'fetch("/': f'fetch("{prefix}/',
            "fetch('/": f"fetch('{prefix}/",
            'EventSource("/': f'EventSource("{prefix}/',
            "EventSource('/": f"EventSource('{prefix}/",
        }
        for old, new in replacements.items():
            text = text.replace(old, new)
        return text.encode("utf-8")

    def _passthrough(self, base_url: str, sub_path: str, query: str, prefix: str = "") -> None:
        target = urlsplit(base_url)
        if target.scheme not in {"http", "https"} or not target.netloc:
            self._respond_json(502, {"error": f"invalid passthrough target: {base_url}"})
            return
        path = sub_path if sub_path.startswith("/") else "/" + sub_path
        if query:
            path = f"{path}?{query}"
        conn_cls = http.client.HTTPSConnection if target.scheme == "https" else http.client.HTTPConnection
        conn = conn_cls(target.netloc, timeout=REQUEST_TIMEOUT)
        try:
            headers = {}
            for key in ("accept", "user-agent"):
                if key in self.headers:
                    headers[key] = self.headers[key]
            headers["Accept-Encoding"] = "identity"
            headers["Host"] = target.netloc
            try:
                body = self._read_request_body_bytes()
            except RequestBodyTooLarge as exc:
                self._respond_json(413, {"error": "request_body_too_large", "message": str(exc)})
                return
            conn.request(self.command, path, body=body, headers=headers)
            resp = conn.getresponse()
            content_type = resp.getheader("content-type", "") or ""
            rewrite_body = bool(prefix and self.command != "HEAD" and "text/html" in content_type.lower())
            body_out = b""
            if rewrite_body:
                body_out = self._rewrite_proxied_html(resp.read(), prefix, content_type)
            self.send_response(resp.status, resp.reason)
            for key, value in resp.getheaders():
                lower = key.lower()
                if lower in HOP_BY_HOP_HEADERS or lower in {"x-frame-options", "content-security-policy"}:
                    continue
                if rewrite_body and lower in {"content-length", "content-encoding"}:
                    continue
                if prefix and lower == "location" and value.startswith("/"):
                    value = prefix + value
                self.send_header(key, value)
            if rewrite_body:
                self.send_header("content-length", str(len(body_out)))
            self.send_header("x-frame-options", "DENY")
            self.send_header("content-security-policy", "frame-ancestors 'none'")
            self.send_header("connection", "close")
            self.end_headers()
            if rewrite_body:
                self.wfile.write(body_out)
            elif self.command != "HEAD":
                while True:
                    chunk = resp.read(8192)
                    if not chunk:
                        break
                    try:
                        self.wfile.write(chunk)
                    except Exception:  # noqa: BLE001
                        break
        except Exception as exc:  # noqa: BLE001
            self._respond_json(502, {"error": "proxy_error", "message": str(exc)})
        finally:
            conn.close()

    def _build_status_payload(self) -> dict:
        cfg = _load_config_values()
        mode = _current_mode(cfg)
        hops = _chain_hops(cfg, mode)
        with _STATS_LOCK:
            req = _STATS["requests"]
            avg = (_STATS["latency_sum_ms"] / req) if req else 0.0
            stats_snapshot = dict(_STATS)
        return {
            "version": _read_version(),
            "mode": mode,
            "chain_hops": hops,
            "chain_short": " -> ".join(hops),
            "health": _health_snapshot(cfg),
            "request_count": req,
            "avg_latency_ms": avg,
            "uptime_seconds": int(time.time() - START_TIME),
            "target_url": TARGET_URL,
            "headroom_url": HEADROOM_URL,
            "pxpipe_url": PXPIPE_URL,
            "squeezr_url": SQUEEZR_URL,
            "stats": stats_snapshot,
            "bind_host": BIND_HOST,
            "bind_warning": (
                "bound to non-loopback host; dashboard exposes logs and history"
                if BIND_HOST not in ("127.0.0.1", "::1", "localhost")
                else ""
            ),
        }

    def _build_metrics_payload(self) -> bytes:
        with _STATS_LOCK:
            snapshot = dict(_STATS)
        lines = [
            "# HELP apx_requests_total total number of requests proxied through the gateway",
            "# TYPE apx_requests_total counter",
            f"apx_requests_total {snapshot['requests']}",
            "# HELP apx_latency_ms_sum sum of per-request latency in milliseconds",
            "# TYPE apx_latency_ms_sum counter",
            f"apx_latency_ms_sum {snapshot['latency_sum_ms']}",
            "# HELP apx_requests_by_status_total requests bucketed by HTTP status class",
            "# TYPE apx_requests_by_status_total counter",
            f'apx_requests_by_status_total{{class="2xx"}} {snapshot["status_2xx"]}',
            f'apx_requests_by_status_total{{class="4xx"}} {snapshot["status_4xx"]}',
            f'apx_requests_by_status_total{{class="5xx"}} {snapshot["status_5xx"]}',
            "# HELP apx_tokens_in_total total input tokens observed",
            "# TYPE apx_tokens_in_total counter",
            f"apx_tokens_in_total {snapshot['tokens_in']}",
            "# HELP apx_tokens_out_total total output tokens observed",
            "# TYPE apx_tokens_out_total counter",
            f"apx_tokens_out_total {snapshot['tokens_out']}",
            "# HELP apx_cost_usd_total estimated cost in USD",
            "# TYPE apx_cost_usd_total counter",
            f"apx_cost_usd_total {snapshot['cost_est_usd']}",
            "# HELP apx_uptime_seconds gateway process uptime in seconds",
            "# TYPE apx_uptime_seconds gauge",
            f"apx_uptime_seconds {int(time.time() - START_TIME)}",
        ]
        return ("\n".join(lines) + "\n").encode("utf-8")

    def _stream_log(self, service: str) -> None:
        allowed = _log_targets()
        path = allowed.get(service)
        if not path:
            self._respond_json(400, {"error": f"unknown service: {service}"})
            return

        ip = self._client_ip()
        with _LOG_STREAMS_LOCK:
            active = _LOG_STREAMS_BY_IP[ip]
            if active >= MAX_LOG_STREAMS_PER_IP:
                self._respond_json(429, {"error": "too many log streams", "limit": MAX_LOG_STREAMS_PER_IP})
                return
            _LOG_STREAMS_BY_IP[ip] = active + 1
        try:
            self._stream_log_body(path, service)
        finally:
            with _LOG_STREAMS_LOCK:
                _LOG_STREAMS_BY_IP[ip] = max(0, _LOG_STREAMS_BY_IP[ip] - 1)

    def _stream_log_body(self, path: str, service: str) -> None:
        try:
            self.send_response(200)
            self.send_header("content-type", "text/event-stream")
            self.send_header("cache-control", "no-cache")
            self.send_header("connection", "keep-alive")
            self.send_header("x-accel-buffering", "no")
            self.end_headers()
        except Exception:
            return

        if not os.path.exists(path):
            try:
                Path(path).parent.mkdir(parents=True, exist_ok=True)
                Path(path).touch()
            except OSError:
                pass

        fh = None
        try:
            fh = open(path, "r", encoding="utf-8", errors="replace")
            inode = os.fstat(fh.fileno()).st_ino
            fh.seek(0, os.SEEK_END)
            size = fh.tell()
            start = max(0, size - 4096)
            fh.seek(start)
            if start > 0:
                fh.readline()
            for line in fh.read().splitlines():
                self._sse_write(line)
            last_heartbeat = time.time()
            while True:
                where = fh.tell()
                line = fh.readline()
                if line:
                    if line.endswith("\n"):
                        line = line[:-1]
                    if not self._sse_write(line):
                        return
                    last_heartbeat = time.time()
                    continue
                try:
                    stat_now = os.stat(path)
                    if stat_now.st_ino != inode or stat_now.st_size < where:
                        fh.close()
                        fh = open(path, "r", encoding="utf-8", errors="replace")
                        inode = os.fstat(fh.fileno()).st_ino
                        continue
                except OSError:
                    pass
                if time.time() - last_heartbeat > 15:
                    try:
                        self.wfile.write(b": keepalive\n\n")
                        self.wfile.flush()
                        last_heartbeat = time.time()
                    except Exception:
                        return
                time.sleep(0.5)
                fh.seek(where)
        except Exception as exc:  # noqa: BLE001
            log(f"log stream error for {service}: {exc}")
        finally:
            if fh is not None:
                try:
                    fh.close()
                except Exception:  # noqa: BLE001
                    pass

    def _sse_write(self, line: str) -> bool:
        try:
            payload = f"data: {line}\n\n".encode("utf-8")
            self.wfile.write(payload)
            self.wfile.flush()
            return True
        except Exception:
            return False

    def _sse_write_named(self, event: str, data: str) -> bool:
        try:
            lines = [f"event: {event}"]
            for line in str(data).splitlines() or [""]:
                lines.append(f"data: {line}")
            payload = ("\n".join(lines) + "\n\n").encode("utf-8")
            self.wfile.write(payload)
            self.wfile.flush()
            return True
        except Exception:
            return False

    def _stream_events(self, window: str = "1h") -> None:
        """Stream cached summary/comparison updates without per-client workers."""
        ip = self._client_ip()
        with _EVENT_STREAMS_LOCK:
            active = _EVENT_STREAMS_BY_IP[ip]
            if active >= MAX_EVENT_STREAMS_PER_IP:
                self._respond_json(429, {"error": "too many event streams", "limit": MAX_EVENT_STREAMS_PER_IP})
                return
            _EVENT_STREAMS_BY_IP[ip] = active + 1
        try:
            self.send_response(200)
            self.send_header("content-type", "text/event-stream")
            self.send_header("cache-control", "no-cache")
            self.send_header("connection", "keep-alive")
            self.send_header("x-accel-buffering", "no")
            self.end_headers()
        except Exception:
            with _EVENT_STREAMS_LOCK:
                _EVENT_STREAMS_BY_IP[ip] = max(0, _EVENT_STREAMS_BY_IP[ip] - 1)
            return

        with _HISTORY_LOCK:
            last_history_ts = max((float(r.get("ts") or 0.0) for r in _HISTORY), default=0.0)
        next_summary = next_compare = next_ping = 0.0
        try:
            while True:
                now = time.monotonic()
                if now >= next_summary:
                    summary = _event_payload_cached(
                        f"summary:{window}",
                        1.5,
                        lambda: _api_metrics_summary({"window": [window]}),
                    )
                    if not self._sse_write_named("summary", json.dumps(summary, default=str)):
                        return
                    with _HISTORY_LOCK:
                        new = [r for r in _HISTORY if float(r.get("ts") or 0.0) > last_history_ts]
                    if new:
                        last_history_ts = max(float(r.get("ts") or 0.0) for r in new)
                        if not self._sse_write_named("history", json.dumps({"items": new[-25:]}, default=str)):
                            return
                    next_summary = now + 2.0
                if now >= next_compare:
                    compare = _event_payload_cached("compare", 4.5, _api_tool_compare)
                    if not self._sse_write_named("compare", json.dumps(compare, default=str)):
                        return
                    next_compare = now + 5.0
                if now >= next_ping:
                    try:
                        self.wfile.write(b": ping\n\n")
                        self.wfile.flush()
                    except Exception:
                        return
                    next_ping = now + 15.0
                wait_for = min(next_summary, next_compare, next_ping) - time.monotonic()
                time.sleep(max(0.05, min(0.5, wait_for)))
        except Exception as exc:  # noqa: BLE001
            log(f"event stream error for {ip}: {exc}")
        finally:
            with _EVENT_STREAMS_LOCK:
                _EVENT_STREAMS_BY_IP[ip] = max(0, _EVENT_STREAMS_BY_IP[ip] - 1)

    def _respond_json(self, status: int, payload: dict) -> None:
        body = json.dumps(payload, default=str).encode("utf-8")
        self._respond(status, body, content_type="application/json")

    def _respond(self, status: int, body: bytes, content_type: str, extra_headers: dict[str, str] | None = None) -> None:
        try:
            self.send_response(status)
            self.send_header("content-type", content_type)
            self.send_header("content-length", str(len(body)))
            self.send_header("cache-control", "no-store")
            for key, value in (extra_headers or {}).items():
                self.send_header(key, value)
            self.send_header("connection", "close")
            self.end_headers()
            if self.command != "HEAD":
                self.wfile.write(body)
        except Exception:
            pass

    def _json(self, status: int, payload: dict[str, object]) -> None:
        self._respond_json(status, payload)

    def _read_request_body_bytes(self, cap: int | None = None) -> bytes:
        if cap is None:
            cap = MAX_REQUEST_BYTES
        length = self.headers.get("content-length")
        if length:
            try:
                n = int(length)
            except ValueError:
                return b""
            if n <= 0:
                return b""
            if n > cap:
                raise RequestBodyTooLarge(f"content-length {n} exceeds APX_MAX_REQUEST_BYTES={cap}")
            return self.rfile.read(min(n, cap))
        if self.headers.get("transfer-encoding", "").lower() == "chunked":
            chunks: list[bytes] = []
            remaining = cap
            while True:
                size_line = self.rfile.readline().strip()
                if not size_line:
                    break
                try:
                    size = int(size_line.split(b";")[0], 16)
                except ValueError:
                    break
                if size == 0:
                    self.rfile.readline()
                    break
                if size > remaining:
                    raise RequestBodyTooLarge(f"chunked body exceeds APX_MAX_REQUEST_BYTES={cap}")
                read = self.rfile.read(min(size, remaining))
                chunks.append(read)
                self.rfile.readline()
                remaining -= len(read)
            return b"".join(chunks)
        return b""

    def _proxy_headers(self, target, request_id: str, session_id: str = "", body_len: int | None = None) -> dict[str, str]:
        headers: dict[str, str] = {}
        for key, value in self.headers.items():
            lower = key.lower()
            if lower in HOP_BY_HOP_HEADERS or lower in {"host", "content-length", "accept-encoding"}:
                continue
            if lower == "cookie" and DASHBOARD_TOKEN:
                kept = []
                for part in value.split(";"):
                    name, sep, _cookie_value = part.strip().partition("=")
                    if sep and name == DASHBOARD_COOKIE_NAME:
                        continue
                    if part.strip():
                        kept.append(part.strip())
                if kept:
                    headers[key] = "; ".join(kept)
                continue
            if lower == "authorization" and DASHBOARD_TOKEN:
                prefix = "bearer "
                if value.lower().startswith(prefix):
                    provided = value[len(prefix):].strip()
                    if secrets.compare_digest(provided, DASHBOARD_TOKEN):
                        continue
            headers[key] = value
        headers["Host"] = target.netloc
        headers["Accept-Encoding"] = "identity"
        headers["X-Apx-Gateway-Target"] = TARGET_URL
        headers["X-Apx-Request-Id"] = request_id
        if session_id:
            headers["X-Apx-Session-Id"] = session_id
        if body_len is not None:
            headers["Content-Length"] = str(body_len)
        return headers

    def _usage_from_dict(self, usage: Any) -> tuple[int, int, int, int]:
        """Return (tokens_in, tokens_out, cache_read, cache_write) from a usage block."""
        if not isinstance(usage, dict):
            return 0, 0, 0, 0
        tin = int(usage.get("input_tokens", usage.get("prompt_tokens", 0)) or 0)
        tout = int(usage.get("output_tokens", usage.get("completion_tokens", 0)) or 0)
        cread = int(
            usage.get("cache_read_input_tokens")
            or usage.get("cached_tokens")
            or (usage.get("prompt_tokens_details") or {}).get("cached_tokens")
            or 0
        )
        cwrite = int(usage.get("cache_creation_input_tokens") or 0)
        return tin, tout, cread, cwrite

    def _tool_call_count_from_dict(self, data: Any) -> int:
        """Count tool_use content blocks (Anthropic) or tool_calls (OpenAI)."""
        if not isinstance(data, dict):
            return 0
        count = 0
        content = data.get("content")
        if isinstance(content, list):
            for part in content:
                if isinstance(part, dict) and part.get("type") == "tool_use":
                    count += 1
        choices = data.get("choices")
        if isinstance(choices, list):
            for ch in choices:
                if not isinstance(ch, dict):
                    continue
                msg = ch.get("message") or {}
                calls = msg.get("tool_calls") if isinstance(msg, dict) else None
                if isinstance(calls, list):
                    count += len(calls)
        return count

    def _extract_tokens_from_json(self, payload_bytes: bytes) -> tuple[int, int, int, int, int]:
        """Returns (tokens_in, tokens_out, cache_read, cache_write, tool_calls)."""
        if not payload_bytes:
            return 0, 0, 0, 0, 0
        try:
            data = json.loads(payload_bytes.decode("utf-8", errors="replace"))
        except Exception:  # noqa: BLE001
            return 0, 0, 0, 0, 0
        if not isinstance(data, dict):
            return 0, 0, 0, 0, 0
        tin, tout, cread, cwrite = self._usage_from_dict(data.get("usage"))
        return tin, tout, cread, cwrite, self._tool_call_count_from_dict(data)

    def _extract_tokens_from_sse(self, body_bytes: bytes) -> tuple[int, int, int, int, int]:
        """Extract usage from SSE frames.

        Anthropic emits usage on `event: message_start` (input_tokens) and
        `event: message_delta` (output_tokens). OpenAI streams a single
        `data: {"usage": ...}` chunk when `stream_options.include_usage` is
        set. We scan line-oriented rather than parsing full frames so we can
        keep the response capture cheap. Also counts `content_block_start`
        frames with `type=tool_use`.
        """
        if not body_bytes:
            return 0, 0, 0, 0, 0
        tokens_in = tokens_out = cache_read = cache_write = tool_calls = 0
        try:
            text = body_bytes.decode("utf-8", errors="replace")
        except Exception:  # noqa: BLE001
            return 0, 0, 0, 0, 0
        for line in text.splitlines():
            if not line.startswith("data:"):
                continue
            data = line[5:].strip()
            if not data or data == "[DONE]":
                continue
            try:
                obj = json.loads(data)
            except Exception:  # noqa: BLE001
                continue
            if not isinstance(obj, dict):
                continue
            usage = obj.get("usage")
            if usage is None:
                msg = obj.get("message")
                if isinstance(msg, dict):
                    usage = msg.get("usage")
            tin, tout, cread, cwrite = self._usage_from_dict(usage)
            if tin:
                tokens_in = tin
            if tout:
                tokens_out = tout
            if cread:
                cache_read = cread
            if cwrite:
                cache_write = cwrite
            if obj.get("type") == "content_block_start":
                block = obj.get("content_block") or {}
                if isinstance(block, dict) and block.get("type") == "tool_use":
                    tool_calls += 1
            choices = obj.get("choices")
            if isinstance(choices, list):
                for ch in choices:
                    if not isinstance(ch, dict):
                        continue
                    delta = ch.get("delta") or ch.get("message") or {}
                    tcalls = delta.get("tool_calls") if isinstance(delta, dict) else None
                    if isinstance(tcalls, list):
                        for c in tcalls:
                            if isinstance(c, dict) and c.get("id"):
                                tool_calls += 1
        return tokens_in, tokens_out, cache_read, cache_write, tool_calls

    def _proxy(self) -> None:
        target = urlsplit(TARGET_URL)
        if target.scheme not in {"http", "https"} or not target.netloc:
            self._json(502, {"error": f"invalid gateway target: {TARGET_URL}"})
            return

        request_id = self.headers.get("x-apx-request-id") or _new_request_id()
        path = self.path if self.path.startswith("/") else f"/{self.path}"
        safe_path = _scrub_url_path(path)
        upstream_path = f"{target.path.rstrip('/')}{path}"
        if not upstream_path.startswith("/"):
            upstream_path = f"/{upstream_path}"

        try:
            body = self._read_request_body_bytes()
        except RequestBodyTooLarge as exc:
            self._respond_json(413, {"error": "request_body_too_large", "message": str(exc)})
            return
        bytes_in = len(body)
        model = _model_from_path(path, body)
        session_id = _derive_session_id(self.headers, model, body)
        cfg_cache = _load_config_values()
        chain_mode = _current_mode(cfg_cache)
        chain_hops = ",".join(_chain_hops(cfg_cache, chain_mode))

        # Capture request body/headers only if CAPTURE_LEVEL=full.
        cap_req_body = _capture_body(body, self.headers.get("content-type", ""))
        cap_req_headers: str | None = None
        if CAPTURE_LEVEL == "full":
            try:
                headers_dict = {k: v for k, v in self.headers.items()}
                cap_req_headers = json.dumps(_redact_headers(headers_dict), separators=(",", ":"))
            except Exception:  # noqa: BLE001
                cap_req_headers = None

        conn_cls = http.client.HTTPSConnection if target.scheme == "https" else http.client.HTTPConnection
        started = time.time()
        first_byte_at: float | None = None
        status = 0
        bytes_out = 0
        response_prefix_chunks: list[bytes] = []
        response_prefix_size = 0
        response_tail = bytearray()
        response_total_captured = 0
        capture_response = self.command == "POST" and body
        conn = conn_cls(target.netloc, timeout=REQUEST_TIMEOUT)
        err_class = ""
        is_stream = False
        response_started = False
        client_disconnected = False
        try:
            conn.request(self.command, upstream_path, body=body, headers=self._proxy_headers(target, request_id, session_id, body_len=len(body)))
            resp = conn.getresponse()
            status = resp.status
            content_type = resp.getheader("content-type", "").lower()
            is_stream = "text/event-stream" in content_type
            # Merge/append Server-Timing so we don't clobber upstream entries.
            upstream_st = resp.getheader("server-timing") or ""
            self.send_response(resp.status, resp.reason)
            for key, value in resp.getheaders():
                lower = key.lower()
                if lower in HOP_BY_HOP_HEADERS or lower == "server-timing":
                    continue
                self.send_header(key, value)
            self.send_header("x-apx-request-id", request_id)
            self.send_header("x-apx-session-id", session_id)
            self.send_header("connection", "close")
            # We can only send headers before streaming the body, so this
            # header reports gateway time-to-first-upstream-headers. The full
            # gateway duration is persisted in SQLite after the response ends.
            gateway_ttfb_ms = int((time.time() - started) * 1000)
            st_entries = [f'gateway_ttfb;dur={gateway_ttfb_ms}']
            if upstream_st:
                st_entries.append(upstream_st)
            self.send_header("server-timing", ", ".join(st_entries))
            self.end_headers()
            response_started = True

            if self.command != "HEAD":
                prefix_cap = 128 * 1024 if is_stream else 512 * 1024
                tail_cap = 512 * 1024 if is_stream else 0
                while True:
                    chunk = resp.read1(65536) if is_stream else resp.read(8192)
                    if not chunk:
                        break
                    if first_byte_at is None:
                        first_byte_at = time.time()
                    try:
                        self.wfile.write(chunk)
                        self.wfile.flush()
                    except (BrokenPipeError, ConnectionResetError):
                        client_disconnected = True
                        break
                    bytes_out += len(chunk)
                    if capture_response:
                        response_total_captured += len(chunk)
                        if response_prefix_size < prefix_cap:
                            take = chunk[: prefix_cap - response_prefix_size]
                            response_prefix_chunks.append(take)
                            response_prefix_size += len(take)
                        if tail_cap:
                            response_tail.extend(chunk)
                            if len(response_tail) > tail_cap:
                                del response_tail[: len(response_tail) - tail_cap]

            elapsed_ms = (time.time() - started) * 1000
            first_byte_ms = ((first_byte_at - started) * 1000) if first_byte_at else 0.0

            tokens_in = tokens_out = cache_read = cache_write = tool_calls = 0
            cap_resp_body: str | None = None
            if capture_response and 200 <= status < 300:
                prefix = b"".join(response_prefix_chunks)
                if is_stream:
                    tail = bytes(response_tail)
                    overlap = max(0, len(prefix) + len(tail) - response_total_captured)
                    usage_bytes = prefix + (b"\n" if prefix and tail else b"") + tail[overlap:]
                    tokens_in, tokens_out, cache_read, cache_write, tool_calls = self._extract_tokens_from_sse(usage_bytes)
                elif "application/json" in content_type:
                    tokens_in, tokens_out, cache_read, cache_write, tool_calls = self._extract_tokens_from_json(prefix)
                if CAPTURE_LEVEL == "full":
                    cap_resp_body = _capture_body(prefix, content_type)

            if client_disconnected:
                err_class = "client_disconnected"
            elif status >= 500:
                err_class = "upstream_5xx"
            elif status >= 400:
                err_class = "upstream_4xx"

            recorded_status = 499 if client_disconnected else resp.status
            log(
                f"{self.command} {safe_path} -> {recorded_status} via {TARGET_URL} "
                f"({int(elapsed_ms)}ms) req_id={request_id} session={session_id}"
            )
            _record_request(
                self.command,
                safe_path,
                recorded_status,
                elapsed_ms,
                TARGET_URL,
                request_id=request_id,
                session_id=session_id,
                model=model,
                tokens_in=tokens_in,
                tokens_out=tokens_out,
                cache_read_tokens=cache_read,
                cache_write_tokens=cache_write,
                bytes_in=bytes_in,
                bytes_out=bytes_out,
                first_byte_ms=first_byte_ms,
                chain_mode=chain_mode,
                chain_hops=chain_hops,
                hop_timings=json.dumps({
                    "gateway_total_ms": round(elapsed_ms, 2),
                    "gateway_first_byte_ms": round(first_byte_ms, 2),
                    "upstream_server_timing": upstream_st,
                }, separators=(",", ":")),
                is_stream=is_stream,
                tool_call_count=tool_calls,
                err_class=err_class,
                request_body=cap_req_body,
                response_body=cap_resp_body,
                request_headers=cap_req_headers,
            )
        except BrokenPipeError:
            log(f"client disconnected during {self.command} {safe_path} req_id={request_id}")
            _record_request(
                self.command,
                safe_path,
                status or 499,
                (time.time() - started) * 1000,
                TARGET_URL,
                request_id=request_id,
                session_id=session_id,
                model=model,
                bytes_in=bytes_in,
                bytes_out=bytes_out,
                chain_mode=chain_mode,
                chain_hops=chain_hops,
                is_stream=is_stream,
                err_class="client_disconnected",
                request_body=cap_req_body,
                request_headers=cap_req_headers,
            )
        except Exception as exc:  # noqa: BLE001
            log(f"proxy error for {self.command} {safe_path} req_id={request_id}: {exc}")
            _record_request(
                self.command,
                safe_path,
                502,
                (time.time() - started) * 1000,
                TARGET_URL,
                request_id=request_id,
                session_id=session_id,
                model=model,
                bytes_in=bytes_in,
                bytes_out=bytes_out,
                chain_mode=chain_mode,
                chain_hops=chain_hops,
                is_stream=is_stream,
                err_class=f"gateway_exception:{type(exc).__name__}",
                request_body=cap_req_body,
                request_headers=cap_req_headers,
            )
            if not response_started and not self.wfile.closed:
                try:
                    self._json(502, {"error": "gateway_proxy_error", "message": str(exc)})
                except Exception:
                    pass
        finally:
            conn.close()


def main() -> int:
    cap_err = _validate_capture_level()
    if cap_err:
        log(f"FATAL: {cap_err}")
        return 3

    if METRICS_DB_ENABLED:
        if METRICS.open():
            log(f"metrics: SQLite store ready at {METRICS.path}")
            try:
                _backfill_from_jsonl()
            except Exception as exc:  # noqa: BLE001
                log(f"metrics: backfill failed: {exc}")
        else:
            log(f"metrics: SQLite disabled (open failed: {METRICS.error})")

    httpd = ApxHTTPServer((BIND_HOST, PORT), GatewayHandler)
    httpd.daemon_threads = True
    shutdown_started = threading.Event()

    def _shutdown(_signum, _frame) -> None:
        if shutdown_started.is_set():
            return
        shutdown_started.set()
        log("shutting down")
        threading.Thread(target=httpd.shutdown, name="apx-http-shutdown", daemon=True).start()

    signal.signal(signal.SIGTERM, _shutdown)
    signal.signal(signal.SIGINT, _shutdown)

    health_thread = threading.Thread(target=_health_refresher_loop, daemon=True)
    health_thread.start()
    if METRICS.enabled:
        threading.Thread(target=_metrics_janitor_loop, daemon=True).start()

    if BIND_HOST not in ("127.0.0.1", "::1", "localhost"):
        log(
            f"WARNING: apx-gateway is bound to {BIND_HOST}; dashboard exposes "
            "logs and history. Set APX_DASHBOARD_TOKEN or bind to 127.0.0.1."
        )
    if DASHBOARD_ENABLED and not DASHBOARD_TOKEN and BIND_HOST not in ("127.0.0.1", "::1", "localhost"):
        log("WARNING: dashboard is enabled without APX_DASHBOARD_TOKEN; refusing to start")
        return 2

    log(
        f"listening on http://{BIND_HOST}:{PORT} -> {TARGET_URL}"
        f" (dashboard={'on' if DASHBOARD_ENABLED else 'off'},"
        f" auth={'token' if DASHBOARD_TOKEN else 'none'},"
        f" capture={CAPTURE_LEVEL},"
        f" metrics_db={'on' if METRICS.enabled else 'off'},"
        f" history_persist={'on' if HISTORY_PERSIST else 'off'})"
    )
    try:
        httpd.serve_forever()
    finally:
        httpd.server_close()
        METRICS.close()
        with _HISTORY_FH_LOCK:
            if _HISTORY_FH is not None:
                try:
                    _HISTORY_FH.close()
                except Exception:  # noqa: BLE001
                    pass
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
