# Header names redacted from ever being persisted, even at APX_CAPTURE=full.
_ALWAYS_REDACT_HEADERS = frozenset({
    "authorization",
    "cookie",
    "set-cookie",
    "proxy-authorization",
    "x-api-key",
    "api-key",
    "x-anthropic-api-key",
    "openai-organization",
    "x-goog-api-key",
    "x-goog-user-project",
    "x-amz-security-token",
    "x-amz-signature",
    "x-amz-access-token",
    "x-amz-credential",
    "x-amz-date",
    "x-amz-content-sha256",
    "x-forwarded-authorization",
})
# Body JSON keys that are always redacted.
_ALWAYS_REDACT_JSON_KEYS = frozenset({
    "api_key", "apikey", "api-key",
    "authorization", "auth", "bearer",
    "password", "passphrase", "secret",
    "token", "access_token", "refresh_token", "session_token", "id_token",
    "client_secret", "private_key",
    "x-api-key",
})
_SENSITIVE_TEXT_PATTERNS = tuple(
    re.compile(pat) for pat in (
        r"sk-[A-Za-z0-9_\-]{20,}",              # OpenAI/Anthropic style keys
        r"anthropic-[A-Za-z0-9_\-]{20,}",       # Anthropic explicit
        r"AIza[0-9A-Za-z_\-]{30,}",             # Google API keys
        r"ghp_[A-Za-z0-9]{30,}",                # GitHub PAT
        r"AKIA[0-9A-Z]{16}",                    # AWS access key
    )
)
_SENSITIVE_QUERY_KEYS = frozenset({
    "api_key",
    "apikey",
    "api-key",
    "authorization",
    "auth",
    "token",
    "access_token",
    "refresh_token",
    "session_token",
    "id_token",
    "password",
    "secret",
    "key",
})

# Service registry. Adding a new proxyable service means one entry here
# (health path + label + default port) plus any needed env override.
SERVICES: dict[str, dict[str, object]] = {
    "headroom": {"url": HEADROOM_URL, "label": "Headroom", "health": "/livez"},
    "pxpipe":   {"url": PXPIPE_URL,   "label": "pxpipe",   "health": "/"},
    "squeezr":  {"url": SQUEEZR_URL,  "label": "Squeezr",  "health": "/squeezr/health"},
}

# Approximate USD costs per million tokens for common model bases.
# Kept intentionally coarse; users should treat this as an estimate only.
# Override at runtime with ~/.config/apx/prices.env:
#   claude-opus-4-8=15.00,75.00
#   claude-sonnet-5=3.00,15.00
DEFAULT_MODEL_COSTS = {
    "claude-opus-4-8": (15.00, 75.00),
    "claude-opus-4-7": (15.00, 75.00),
    "claude-opus-4": (15.00, 75.00),
    "claude-sonnet-5": (3.00, 15.00),
    "claude-sonnet-4-6": (3.00, 15.00),
    "claude-sonnet-4": (3.00, 15.00),
    "claude-fable-5": (1.00, 5.00),
    "claude-haiku": (0.80, 4.00),
    "gpt-5.6": (5.00, 15.00),
    "gpt-5.5": (5.00, 15.00),
    "gpt-5": (5.00, 15.00),
    "gpt-4o": (2.50, 10.00),
    "gpt-4o-mini": (0.15, 0.60),
}


def _load_model_costs() -> dict[str, tuple[float, float]]:
    costs = dict(DEFAULT_MODEL_COSTS)
    try:
        with open(PRICES_FILE, "r", encoding="utf-8") as fh:
            for raw in fh:
                line = raw.strip()
                if not line or line.startswith("#") or "=" not in line:
                    continue
                key, value = line.split("=", 1)
                parts = [p.strip() for p in value.split(",", 1)]
                if len(parts) != 2:
                    continue
                try:
                    costs[key.strip().lower()] = (float(parts[0]), float(parts[1]))
                except ValueError:
                    continue
    except OSError:
        pass
    return costs


MODEL_COSTS = _load_model_costs()

# --- Session id derivation ---------------------------------------------------
# We derive a stable session id from a small set of headers that CLI-based
# clients (Claude Code, Codex, etc.) reuse across a chat, so we can group
# requests without adding server-side state or trusting a client-supplied id.
_SESSION_HEADER_CANDIDATES = (
    "x-apx-session-id",
    "x-session-id",
    "x-request-session",
    "x-anthropic-session-id",
    "anthropic-session-id",
    "x-conversation-id",
    "conversation-id",
    "x-chat-id",
    "x-thread-id",
    "openai-thread-id",
)

# --- Capture-level validation ------------------------------------------------
_CAPTURE_LEVELS = ("metadata", "full")


def _validate_capture_level() -> str | None:
    """Return an error message if capture config is invalid, else None."""
    if CAPTURE_LEVEL not in _CAPTURE_LEVELS:
        return (
            f"invalid APX_CAPTURE={CAPTURE_LEVEL!r}; expected one of {_CAPTURE_LEVELS}"
        )
    if CAPTURE_BODY_CAP < 0:
        return "APX_CAPTURE_BODY_CAP must be >= 0"
    if MAX_REQUEST_BYTES < 1:
        return "APX_MAX_REQUEST_BYTES must be >= 1"
    if CAPTURE_LEVEL == "full" and CAPTURE_FULL_ACK != "i-understand":
        return (
            "APX_CAPTURE=full requires APX_CAPTURE_FULL_ACK=i-understand. "
            "Full capture writes redacted request/response bodies to a LOCAL SQLite "
            "database; the JSONL audit log remains metadata-only. Data never leaves "
            "this machine, but you must acknowledge the sensitivity before enabling it."
        )
    return None


# --- Redaction helpers -------------------------------------------------------
def _redact_headers(headers: dict[str, str]) -> dict[str, str]:
    """Return headers with sensitive values masked, safe to persist."""
    if not headers:
        return {}
    out: dict[str, str] = {}
    always = _ALWAYS_REDACT_HEADERS
    extra = set(REDACT_KEYS_EXTRA)
    for key, value in headers.items():
        lk = key.lower()
        if lk in always or lk in extra or lk.startswith("x-amz-"):
            out[key] = "***"
        else:
            out[key] = value
    return out


def _redact_json_value(node: Any, depth: int = 0) -> Any:
    if depth > 8:
        return "[REDACTED_DEPTH_LIMIT]"
    if isinstance(node, dict):
        red: dict[str, Any] = {}
        redact_names = _ALWAYS_REDACT_JSON_KEYS | set(REDACT_KEYS_EXTRA)
        for k, v in node.items():
            if isinstance(k, str) and k.lower() in redact_names:
                red[k] = "***"
            else:
                red[k] = _redact_json_value(v, depth + 1)
        return red
    if isinstance(node, list):
        return [_redact_json_value(x, depth + 1) for x in node[:2000]]
    if isinstance(node, str):
        return _redact_secrets_in_text(node)
    return node


def _redact_secrets_in_text(text: str) -> str:
    if not text:
        return text
    out = text
    for pat in _SENSITIVE_TEXT_PATTERNS:
        out = pat.sub("[REDACTED]", out)
    return out


def _scrub_url_path(path: str) -> str:
    """Redact sensitive query params before logging or persisting metadata."""
    if not path or "?" not in path:
        return path
    parsed = urlsplit(path)
    parts: list[str] = []
    for raw in parsed.query.split("&"):
        if not raw:
            continue
        key, sep, value = raw.partition("=")
        lk = unquote(key).lower()
        if lk in _SENSITIVE_QUERY_KEYS or lk.startswith("x-") and "key" in lk:
            parts.append(f"{key}{sep}REDACTED" if sep else f"{key}=REDACTED")
        else:
            parts.append(raw)
    out = parsed.path
    if parts:
        out += "?" + "&".join(parts)
    if parsed.fragment:
        out += "#" + parsed.fragment
    return out


def _capture_body(body: bytes, content_type: str) -> str | None:
    """Return a JSON-serializable string representation of the body, respecting
    APX_CAPTURE. Never returns raw bytes; always redacted.

    Metadata mode returns None (no body captured).
    Full mode returns a redacted, truncated string.
    """
    if CAPTURE_LEVEL != "full" or not body:
        return None
    try:
        text = body.decode("utf-8", errors="replace")
    except Exception:  # noqa: BLE001
        return None
    ct = (content_type or "").lower()
    if "application/json" in ct:
        try:
            parsed = json.loads(text)
            parsed = _redact_json_value(parsed)
            return json.dumps(parsed, separators=(",", ":"))[: CAPTURE_BODY_CAP]
        except Exception:  # noqa: BLE001
            return _redact_secrets_in_text(text)[: CAPTURE_BODY_CAP]
    return _redact_secrets_in_text(text)[: CAPTURE_BODY_CAP]


def _derive_session_id(headers: Any, model: str | None, body: bytes) -> str:
    """Derive a stable session id. Prefer explicit headers; fall back to a
    content-derived hash of the first-user-message contents (matching how
    pxpipe and Squeezr internally group sessions).
    """
    if headers is not None:
        for name in _SESSION_HEADER_CANDIDATES:
            try:
                val = headers.get(name) or headers.get(name.title())
            except Exception:  # noqa: BLE001
                val = None
            if val:
                return str(val)[:64]
    # Content-derived fallback: hash first user text block.
    try:
        obj = json.loads((body or b"").decode("utf-8", errors="replace") or "{}")
    except Exception:  # noqa: BLE001
        obj = {}
    seed = ""
    if isinstance(obj, dict):
        msgs = obj.get("messages") or obj.get("input") or []
        if isinstance(msgs, list):
            for m in msgs:
                if not isinstance(m, dict):
                    continue
                if m.get("role") not in ("user", None):
                    continue
                content = m.get("content")
                if isinstance(content, str):
                    seed = content
                    break
                if isinstance(content, list):
                    for part in content:
                        if isinstance(part, dict):
                            t = part.get("text")
                            if isinstance(t, str) and t:
                                seed = t
                                break
                if seed:
                    break
    if not seed:
        return f"m-{model or 'unknown'}-{int(time.time()) // 1800}"
    digest = hashlib.sha1(seed.encode("utf-8")).hexdigest()
    return f"s-{digest[:12]}"


# --- SQLite metrics store ---------------------------------------------------
_METRICS_SCHEMA_VERSION = 2
_METRICS_DDL = [
    """
    CREATE TABLE IF NOT EXISTS schema_version (
      version INTEGER NOT NULL
    )
    """,
    """
    CREATE TABLE IF NOT EXISTS backfill_state (
      key TEXT PRIMARY KEY,
      value TEXT NOT NULL
    )
    """,
    """
    CREATE TABLE IF NOT EXISTS requests (
      id INTEGER PRIMARY KEY AUTOINCREMENT,
      ts REAL NOT NULL,
      request_id TEXT,
      session_id TEXT,
      method TEXT,
      path TEXT,
      model TEXT,
      status INTEGER,
      latency_ms REAL,
      first_byte_ms REAL,
      tokens_in INTEGER,
      tokens_out INTEGER,
      cache_read_tokens INTEGER,
      cache_write_tokens INTEGER,
      cost_est_usd REAL,
      bytes_in INTEGER,
      bytes_out INTEGER,
      chain_mode TEXT,
      chain_hops TEXT,
      hop_timings TEXT,
      upstream TEXT,
      is_stream INTEGER,
      tool_call_count INTEGER,
      err_class TEXT,
      capture_level TEXT,
      request_body TEXT,
      response_body TEXT,
      request_headers TEXT,
      source_key TEXT
    )
    """,
    "CREATE INDEX IF NOT EXISTS idx_requests_ts ON requests(ts)",
    "CREATE INDEX IF NOT EXISTS idx_requests_session ON requests(session_id, ts)",
    "CREATE INDEX IF NOT EXISTS idx_requests_model ON requests(model, ts)",
    "CREATE INDEX IF NOT EXISTS idx_requests_status ON requests(status, ts)",
]


class MetricsStore:
    """Thread-safe SQLite writer for per-request metrics.

    Uses a single connection guarded by a lock (the record volume is tiny
    compared to the request throughput, so contention is minimal). WAL mode
    is enabled so read queries from the dashboard never block writes.
    """

    def __init__(self, path: str) -> None:
        self.path = path
        self._lock = threading.Lock()
        self._conn: sqlite3.Connection | None = None
        self.enabled = False
        self.error: str | None = None

    def open(self) -> bool:
        try:
            parent = Path(os.path.dirname(self.path) or ".")
            parent.mkdir(parents=True, exist_ok=True, mode=0o700)
            os.chmod(parent, 0o700)
            conn = sqlite3.connect(
                self.path,
                timeout=5.0,
                check_same_thread=False,
                isolation_level=None,  # autocommit; we use explicit txns
            )
            conn.execute("PRAGMA journal_mode=WAL")
            conn.execute("PRAGMA synchronous=NORMAL")
            conn.execute("PRAGMA busy_timeout=5000")
            for stmt in _METRICS_DDL:
                conn.execute(stmt)
            cur = conn.execute("SELECT COALESCE(MAX(version), 0) FROM schema_version")
            row = cur.fetchone()
            current = int(row[0]) if row else 0
            columns = {str(r[1]) for r in conn.execute("PRAGMA table_info(requests)").fetchall()}
            if "source_key" not in columns:
                conn.execute("ALTER TABLE requests ADD COLUMN source_key TEXT")
            conn.execute("CREATE UNIQUE INDEX IF NOT EXISTS idx_requests_source_key ON requests(source_key)")
            if current < _METRICS_SCHEMA_VERSION:
                if current < 2:
                    existing = int(conn.execute("SELECT COUNT(*) FROM requests").fetchone()[0])
                    if existing > 0:
                        conn.execute(
                            "INSERT OR IGNORE INTO backfill_state(key, value) VALUES ('jsonl_complete', 'legacy_nonempty')"
                        )
                conn.execute("DELETE FROM schema_version")
                conn.execute("INSERT INTO schema_version(version) VALUES (?)", (_METRICS_SCHEMA_VERSION,))
            self._conn = conn
            self.enabled = True
            self._secure_files()
            return True
        except Exception as exc:  # noqa: BLE001
            self.error = str(exc)
            self.enabled = False
            self._conn = None
            return False

    def close(self) -> None:
        with self._lock:
            if self._conn is not None:
                try:
                    self._conn.close()
                except Exception:  # noqa: BLE001
                    pass
            self._conn = None
            self.enabled = False

    def _secure_files(self) -> None:
        for candidate in (self.path, f"{self.path}-wal", f"{self.path}-shm"):
            try:
                os.chmod(candidate, 0o600)
            except FileNotFoundError:
                pass
            except OSError as exc:
                log(f"metrics: could not restrict permissions on {candidate}: {exc}")

    def is_fresh(self) -> bool:
        if not self.enabled or self._conn is None:
            return False
        with self._lock:
            cur = self._conn.execute("SELECT COUNT(*) FROM requests")
            return int(cur.fetchone()[0]) == 0

    def insert(self, row: dict[str, Any]) -> None:
        if not self.enabled or self._conn is None:
            return
        cols = (
            "ts", "request_id", "session_id", "method", "path", "model", "status",
            "latency_ms", "first_byte_ms", "tokens_in", "tokens_out",
            "cache_read_tokens", "cache_write_tokens", "cost_est_usd",
            "bytes_in", "bytes_out", "chain_mode", "chain_hops", "hop_timings",
            "upstream", "is_stream", "tool_call_count", "err_class",
            "capture_level", "request_body", "response_body", "request_headers",
            "source_key",
        )
        values = tuple(row.get(c) for c in cols)
        placeholders = ",".join(["?"] * len(cols))
        try:
            with self._lock:
                self._conn.execute(
                    f"INSERT INTO requests({','.join(cols)}) VALUES ({placeholders})",
                    values,
                )
                self._secure_files()
        except Exception as exc:  # noqa: BLE001
            log(f"metrics insert failed: {exc}")

    def bulk_insert(self, rows: Iterable[dict[str, Any]]) -> int:
        if not self.enabled or self._conn is None:
            return 0
        cols = (
            "ts", "request_id", "session_id", "method", "path", "model", "status",
            "latency_ms", "first_byte_ms", "tokens_in", "tokens_out",
            "cache_read_tokens", "cache_write_tokens", "cost_est_usd",
            "bytes_in", "bytes_out", "chain_mode", "chain_hops", "hop_timings",
            "upstream", "is_stream", "tool_call_count", "err_class",
            "capture_level", "request_body", "response_body", "request_headers",
            "source_key",
        )
        placeholders = ",".join(["?"] * len(cols))
        stmt = f"INSERT OR IGNORE INTO requests({','.join(cols)}) VALUES ({placeholders})"
        count = 0
        try:
            with self._lock:
                self._conn.execute("BEGIN")
                for r in rows:
                    cur = self._conn.execute(stmt, tuple(r.get(c) for c in cols))
                    if (cur.rowcount or 0) > 0:
                        count += 1
                self._conn.execute("COMMIT")
                self._secure_files()
        except Exception as exc:  # noqa: BLE001
            try:
                self._conn.execute("ROLLBACK")
            except Exception:  # noqa: BLE001
                pass
            log(f"metrics bulk insert failed after {count}: {exc}")
        return count

    def query(self, sql: str, params: tuple = ()) -> list[dict[str, Any]]:
        if not self.enabled or self._conn is None:
            return []
        uri = f"{Path(self.path).resolve().as_uri()}?mode=ro"
        conn = sqlite3.connect(uri, uri=True, timeout=5.0)
        try:
            conn.execute("PRAGMA busy_timeout=5000")
            cur = conn.execute(sql, params)
            columns = [d[0] for d in cur.description] if cur.description else []
            return [dict(zip(columns, row)) for row in cur.fetchall()]
        finally:
            conn.close()

    def backfill_completed(self) -> bool:
        if not self.enabled or self._conn is None:
            return True
        with self._lock:
            row = self._conn.execute(
                "SELECT value FROM backfill_state WHERE key = 'jsonl_complete'"
            ).fetchone()
            return row is not None

    def mark_backfill_complete(self) -> None:
        if not self.enabled or self._conn is None:
            return
        with self._lock:
            self._conn.execute(
                "INSERT OR REPLACE INTO backfill_state(key, value) VALUES ('jsonl_complete', ?)",
                (str(int(time.time())),),
            )

    def prune_older_than(self, cutoff_ts: float) -> int:
        if not self.enabled or self._conn is None:
            return 0
        with self._lock:
            cur = self._conn.execute("DELETE FROM requests WHERE ts < ?", (cutoff_ts,))
            return cur.rowcount or 0

    def checkpoint(self) -> None:
        if not self.enabled or self._conn is None:
            return
        with self._lock:
            self._conn.execute("PRAGMA wal_checkpoint(TRUNCATE)")
            self._secure_files()


METRICS = MetricsStore(METRICS_DB_PATH)


def _backfill_from_jsonl() -> None:
    """Resume-safe, idempotent import of retained history JSONL into SQLite."""
    if not METRICS_BACKFILL or not METRICS.enabled:
        return
    if METRICS.backfill_completed():
        return
    if not os.path.isdir(HISTORY_DIR):
        METRICS.mark_backfill_complete()
        return
    files = sorted(f for f in os.listdir(HISTORY_DIR) if f.endswith(".jsonl"))
    if not files:
        METRICS.mark_backfill_complete()
        return
    log(f"metrics: backfilling from {len(files)} JSONL file(s) in {HISTORY_DIR}")
    total = 0
    all_read = True
    cutoff = (
        time.time() - METRICS_RETENTION_DAYS * 86400
        if METRICS_RETENTION_DAYS > 0
        else 0.0
    )
    for fname in files:
        rows: list[dict[str, Any]] = []
        try:
            with open(os.path.join(HISTORY_DIR, fname), "r", encoding="utf-8", errors="replace") as fh:
                for line_number, raw in enumerate(fh, 1):
                    raw = raw.strip()
                    if not raw:
                        continue
                    try:
                        entry = json.loads(raw)
                        if not isinstance(entry, dict):
                            continue
                        ts = float(entry.get("ts") or 0.0)
                        if ts < cutoff:
                            continue
                        rows.append({
                            "ts": ts,
                            "request_id": entry.get("request_id") or "",
                            "session_id": entry.get("session_id") or "",
                            "method": entry.get("method") or "",
                            "path": entry.get("path") or "",
                            "model": entry.get("model") or "",
                            "status": int(entry.get("status") or 0),
                            "latency_ms": float(entry.get("latency_ms") or 0.0),
                            "first_byte_ms": float(entry.get("first_byte_ms") or 0.0),
                            "tokens_in": int(entry.get("tokens_in") or 0),
                            "tokens_out": int(entry.get("tokens_out") or 0),
                            "cache_read_tokens": int(entry.get("cache_read_tokens") or 0),
                            "cache_write_tokens": int(entry.get("cache_write_tokens") or 0),
                            "cost_est_usd": float(entry.get("cost_est_usd") or 0.0),
                            "bytes_in": int(entry.get("bytes_in") or 0),
                            "bytes_out": int(entry.get("bytes_out") or 0),
                            "chain_mode": entry.get("chain_mode") or "",
                            "chain_hops": entry.get("chain_hops") or "",
                            "hop_timings": entry.get("hop_timings") or "",
                            "upstream": entry.get("upstream") or "",
                            "is_stream": int(bool(entry.get("is_stream"))),
                            "tool_call_count": int(entry.get("tool_call_count") or 0),
                            "err_class": entry.get("err_class") or "",
                            "capture_level": entry.get("capture_level") or "metadata",
                            "request_body": None,
                            "response_body": None,
                            "request_headers": None,
                            "source_key": f"jsonl:{fname}:{line_number}",
                        })
                    except (TypeError, ValueError, json.JSONDecodeError):
                        continue
                    if len(rows) >= 500:
                        total += METRICS.bulk_insert(rows)
                        rows.clear()
        except OSError:
            all_read = False
            continue
        total += METRICS.bulk_insert(rows)
    if all_read:
        METRICS.mark_backfill_complete()
        log(f"metrics: backfill complete, {total} row(s) imported")
    else:
        log(f"metrics: backfill paused after {total} row(s); unreadable files will be retried")


def _metrics_janitor_loop() -> None:
    """Periodically prune old rows per retention policy."""
    while True:
        try:
            if METRICS_RETENTION_DAYS > 0:
                cutoff = time.time() - METRICS_RETENTION_DAYS * 86400
                if METRICS.enabled:
                    deleted = METRICS.prune_older_than(cutoff)
                    if deleted:
                        log(f"metrics: pruned {deleted} row(s) older than {METRICS_RETENTION_DAYS}d")
                    METRICS.checkpoint()
                removed_history = _prune_history_files(cutoff)
                if removed_history:
                    log(f"history: pruned {removed_history} JSONL file(s) older than {METRICS_RETENTION_DAYS}d")
        except Exception as exc:  # noqa: BLE001
            log(f"metrics janitor error: {exc}")
        time.sleep(3600)


def _prune_history_files(cutoff_ts: float) -> int:
    cutoff_day = date.fromtimestamp(cutoff_ts)
    removed = 0
    try:
        names = os.listdir(HISTORY_DIR)
    except OSError:
        return 0
    for name in names:
        if not name.endswith(".jsonl"):
            continue
        try:
            file_day = date.fromisoformat(name[:-6])
        except ValueError:
            continue
        if file_day >= cutoff_day:
            continue
        try:
            os.remove(os.path.join(HISTORY_DIR, name))
            removed += 1
        except OSError as exc:
            log(f"history: could not prune {name}: {exc}")
    return removed


