#!/usr/bin/env python3
"""apx-gateway: streaming reverse proxy + unified dashboard."""

from __future__ import annotations

import collections
import http.client
import json
import os
import secrets
import signal
import threading
import time
from datetime import date, datetime, timezone
from http.server import BaseHTTPRequestHandler, ThreadingHTTPServer
from pathlib import Path
from urllib.parse import parse_qs, urlsplit

BIND_HOST = os.environ.get("GATEWAY_HOST") or os.environ.get("HOST") or "127.0.0.1"
PORT = int(os.environ.get("GATEWAY_PORT", "8787"))
TARGET_URL = os.environ.get("GATEWAY_TARGET_URL", "https://api.anthropic.com").rstrip("/")
REQUEST_TIMEOUT = float(os.environ.get("GATEWAY_REQUEST_TIMEOUT_SECONDS", "600"))

DASHBOARD_ENABLED = os.environ.get("APX_DASHBOARD_ENABLED", "1") == "1"
DASHBOARD_HTML_PATH = os.environ.get("APX_DASHBOARD_HTML", "")
DASHBOARD_TOKEN = os.environ.get("APX_DASHBOARD_TOKEN", "").strip()
METRICS_ENABLED = os.environ.get("APX_METRICS_ENABLED", "0") == "1"
HISTORY_SIZE = int(os.environ.get("APX_HISTORY_SIZE", "500"))
STATE_DIR = os.environ.get("APX_STATE_DIR", os.path.expanduser("~/.local/state/apx"))
LOG_DIR = os.environ.get("APX_LOG_DIR", os.path.join(STATE_DIR, "logs"))
CONFIG_FILE = os.environ.get("APX_CONFIG", os.path.expanduser("~/.config/apx/config.env"))
PRICES_FILE = os.environ.get("APX_PRICES_FILE", os.path.join(os.path.dirname(CONFIG_FILE), "prices.env"))
HEADROOM_URL = os.environ.get("APX_HEADROOM_URL", "http://127.0.0.1:8788").rstrip("/")
PXPIPE_URL = os.environ.get("APX_PXPIPE_URL", "http://127.0.0.1:47821").rstrip("/")
SQUEEZR_URL = os.environ.get("APX_SQUEEZR_URL", "http://127.0.0.1:18780").rstrip("/")
HEADROOM_PROXY_LOG = os.environ.get(
    "HEADROOM_LOG_FILE", os.path.expanduser("~/.headroom/logs/proxy.log")
)
HISTORY_PERSIST = os.environ.get("APX_HISTORY_PERSIST", "1") == "1"
HISTORY_DIR = os.environ.get("APX_HISTORY_DIR", os.path.join(STATE_DIR, "history"))
HEALTH_INTERVAL_SECONDS = float(os.environ.get("APX_HEALTH_INTERVAL_SECONDS", "5"))
MAX_LOG_STREAMS_PER_IP = int(os.environ.get("APX_MAX_LOG_STREAMS_PER_IP", "8"))
MAX_REQUEST_BYTES = int(os.environ.get("APX_MAX_REQUEST_BYTES", str(64 * 1024 * 1024)))

VERSION_FILE = os.path.join(STATE_DIR, "VERSION")

# Service registry. Adding a new proxyable service means one entry here
# (health path + label + default port) plus any needed env override.
SERVICES: dict[str, dict[str, object]] = {
    "headroom": {"url": HEADROOM_URL, "label": "Headroom", "health": "/livez"},
    "pxpipe":   {"url": PXPIPE_URL,   "label": "pxpipe",   "health": "/"},
    "squeezr":  {"url": SQUEEZR_URL,  "label": "Squeezr",  "health": "/squeezr/health"},
}

# Approximate USD costs per million tokens for common model bases.
# Kept intentionally coarse; users should treat this as an estimate only.
# Override at runtime with ~/.config/apx/prices.env:
#   claude-opus-4-8=15.00,75.00
#   claude-sonnet-5=3.00,15.00
DEFAULT_MODEL_COSTS = {
    "claude-opus-4-8": (15.00, 75.00),
    "claude-opus-4-7": (15.00, 75.00),
    "claude-opus-4": (15.00, 75.00),
    "claude-sonnet-5": (3.00, 15.00),
    "claude-sonnet-4-6": (3.00, 15.00),
    "claude-sonnet-4": (3.00, 15.00),
    "claude-fable-5": (1.00, 5.00),
    "claude-haiku": (0.80, 4.00),
    "gpt-5.6": (5.00, 15.00),
    "gpt-5.5": (5.00, 15.00),
    "gpt-5": (5.00, 15.00),
    "gpt-4o": (2.50, 10.00),
    "gpt-4o-mini": (0.15, 0.60),
}


def _load_model_costs() -> dict[str, tuple[float, float]]:
    costs = dict(DEFAULT_MODEL_COSTS)
    try:
        with open(PRICES_FILE, "r", encoding="utf-8") as fh:
            for raw in fh:
                line = raw.strip()
                if not line or line.startswith("#") or "=" not in line:
                    continue
                key, value = line.split("=", 1)
                parts = [p.strip() for p in value.split(",", 1)]
                if len(parts) != 2:
                    continue
                try:
                    costs[key.strip().lower()] = (float(parts[0]), float(parts[1]))
                except ValueError:
                    continue
    except OSError:
        pass
    return costs


MODEL_COSTS = _load_model_costs()

HOP_BY_HOP_HEADERS = {
    "connection",
    "keep-alive",
    "proxy-authenticate",
    "proxy-authorization",
    "te",
    "trailer",
    "transfer-encoding",
    "upgrade",
}

START_TIME = time.time()
_HISTORY: "collections.deque[dict]" = collections.deque(maxlen=HISTORY_SIZE)
_HISTORY_LOCK = threading.Lock()
_STATS = {
    "requests": 0,
    "latency_sum_ms": 0.0,
    "status_2xx": 0,
    "status_4xx": 0,
    "status_5xx": 0,
    "tokens_in": 0,
    "tokens_out": 0,
    "cost_est_usd": 0.0,
}
_STATS_LOCK = threading.Lock()
_HEALTH_CACHE: dict = {"ts": 0.0, "value": {}}
_HEALTH_LOCK = threading.Lock()
_LOG_STREAMS_BY_IP: "collections.defaultdict[str, int]" = collections.defaultdict(int)
_LOG_STREAMS_LOCK = threading.Lock()
_HISTORY_FH = None
_HISTORY_FH_DATE: str | None = None
_HISTORY_FH_LOCK = threading.Lock()


def log(message: str) -> None:
    print(f"[{time.strftime('%Y-%m-%dT%H:%M:%S%z')}] [apx-gateway] {message}", flush=True)


def _read_version() -> str:
    try:
        with open(VERSION_FILE, "r", encoding="utf-8") as fh:
            return fh.readline().strip() or "unknown"
    except OSError:
        return "unknown"


def _load_config_values() -> dict[str, str]:
    out: dict[str, str] = {}
    try:
        with open(CONFIG_FILE, "r", encoding="utf-8") as fh:
            for raw in fh:
                line = raw.strip()
                if not line or line.startswith("#") or "=" not in line:
                    continue
                key, value = line.split("=", 1)
                value = value.strip().strip('"').strip("'")
                out[key.strip()] = value
    except OSError:
        pass
    return out


_PRESET_BY_CHAIN = {
    "": "direct",
    "headroom": "headroom",
    "pxpipe": "pxpipe",
    "squeezr": "squeezr",
    "headroom,pxpipe": "headroom-pxpipe",
    "pxpipe,headroom": "pxpipe-headroom",
    "headroom,squeezr": "headroom-squeezr",
}


def _chain_from_config(cfg: dict[str, str]) -> list[str]:
    raw = os.environ.get("APX_CHAIN", cfg.get("APX_CHAIN", "")).strip().strip('"').strip("'")
    if raw:
        return [p.strip() for p in raw.split(",") if p.strip()]
    # Legacy inference for pre-chain configs.
    bind = cfg.get("BIND_HOST", "127.0.0.1")
    h = cfg.get("HEADROOM_ENABLED", "0")
    p = cfg.get("PXPIPE_ENABLED", "0")
    s = cfg.get("SQUEEZR_ENABLED", "0")
    gt = cfg.get("GATEWAY_TARGET_API_URL", "")
    pt = cfg.get("PXPIPE_TARGET_API_URL", "")
    pxp = f"http://{bind}:{cfg.get('PXPIPE_PORT', '47821')}"
    hdr = f"http://{bind}:{cfg.get('HEADROOM_PORT', '8788')}"
    if h == "1" and p == "1" and gt == pxp and pt == hdr:
        return ["pxpipe", "headroom"]
    if h == "1" and p == "1":
        return ["headroom", "pxpipe"]
    if h == "1" and s == "1":
        return ["headroom", "squeezr"]
    if h == "1":
        return ["headroom"]
    if p == "1":
        return ["pxpipe"]
    if s == "1":
        return ["squeezr"]
    return []


def _current_mode(cfg: dict[str, str]) -> str:
    if cfg.get("GATEWAY_ENABLED", "1") != "1":
        return "off"
    chain = _chain_from_config(cfg)
    return _PRESET_BY_CHAIN.get(",".join(chain), "custom")


def _chain_hops(cfg: dict[str, str], mode: str) -> list[str]:
    if mode == "off":
        return ["disabled"]
    hops = ["Claude", f"Gateway:{cfg.get('GATEWAY_PORT', '8787')}"]
    port_by_service = {
        "headroom": cfg.get("HEADROOM_PORT", "8788"),
        "pxpipe":   cfg.get("PXPIPE_PORT", "47821"),
        "squeezr":  cfg.get("SQUEEZR_PORT", "18780"),
    }
    label_by_service = {name: SERVICES[name]["label"] for name in SERVICES}
    for svc in _chain_from_config(cfg):
        label = label_by_service.get(svc, svc)
        port = port_by_service.get(svc, "?")
        hops.append(f"{label}:{port}")
    hops.append("Anthropic")
    return hops


def _service_ok(url: str, path: str = "/livez", timeout: float = 1.5) -> bool:
    try:
        target = urlsplit(url + path)
        cls = http.client.HTTPSConnection if target.scheme == "https" else http.client.HTTPConnection
        conn = cls(target.netloc, timeout=timeout)
        try:
            conn.request("GET", target.path or "/")
            resp = conn.getresponse()
            resp.read()
            return 200 <= resp.status < 500
        finally:
            conn.close()
    except Exception:
        return False


def _health_map_uncached(cfg: dict[str, str]) -> dict[str, str]:
    active = set(_chain_from_config(cfg))
    out: dict[str, str] = {"gateway": "ok"}
    for name, meta in SERVICES.items():
        if name not in active:
            out[name] = "disabled"
            continue
        out[name] = "ok" if _service_ok(str(meta["url"]), path=str(meta["health"])) else "fail"
    return out


def _health_snapshot(cfg: dict[str, str]) -> dict[str, str]:
    with _HEALTH_LOCK:
        cached = _HEALTH_CACHE.get("value") or {}
        return dict(cached) if cached else {"gateway": "ok"}


def _health_refresher_loop() -> None:
    while True:
        try:
            cfg = _load_config_values()
            snapshot = _health_map_uncached(cfg)
        except Exception:  # noqa: BLE001
            snapshot = {"gateway": "ok"}
        with _HEALTH_LOCK:
            _HEALTH_CACHE["value"] = snapshot
            _HEALTH_CACHE["ts"] = time.time()
        time.sleep(max(1.0, HEALTH_INTERVAL_SECONDS))


def _new_request_id() -> str:
    return f"apx-{secrets.token_hex(8)}"


def _model_from_path(path: str, body: bytes) -> str | None:
    if body:
        try:
            payload = json.loads(body.decode("utf-8", errors="replace"))
        except Exception:  # noqa: BLE001
            payload = None
        if isinstance(payload, dict):
            model = payload.get("model")
            if isinstance(model, str):
                return model
    return None


def _cost_estimate(model: str | None, tokens_in: int, tokens_out: int) -> float:
    if not model or (tokens_in <= 0 and tokens_out <= 0):
        return 0.0
    m = model.lower()
    for base, (rate_in, rate_out) in MODEL_COSTS.items():
        if m.startswith(base):
            return round((tokens_in / 1_000_000.0) * rate_in + (tokens_out / 1_000_000.0) * rate_out, 6)
    return 0.0


def _rotate_history_fh() -> "any":
    global _HISTORY_FH, _HISTORY_FH_DATE
    if not HISTORY_PERSIST:
        return None
    today = date.today().isoformat()
    if _HISTORY_FH is not None and _HISTORY_FH_DATE == today:
        return _HISTORY_FH
    try:
        if _HISTORY_FH is not None:
            _HISTORY_FH.close()
    except Exception:  # noqa: BLE001
        pass
    try:
        Path(HISTORY_DIR).mkdir(parents=True, exist_ok=True)
        _HISTORY_FH = open(os.path.join(HISTORY_DIR, f"{today}.jsonl"), "a", encoding="utf-8")
        _HISTORY_FH_DATE = today
    except OSError:
        _HISTORY_FH = None
        _HISTORY_FH_DATE = None
    return _HISTORY_FH


def _persist_history(entry: dict) -> None:
    with _HISTORY_FH_LOCK:
        fh = _rotate_history_fh()
        if fh is None:
            return
        try:
            fh.write(json.dumps(entry, separators=(",", ":")) + "\n")
            fh.flush()
        except Exception:  # noqa: BLE001
            pass


def _record_request(
    method: str,
    path: str,
    status: int,
    latency_ms: float,
    upstream: str,
    request_id: str = "",
    model: str | None = None,
    tokens_in: int = 0,
    tokens_out: int = 0,
    bytes_out: int = 0,
) -> None:
    cost = _cost_estimate(model, tokens_in, tokens_out)
    entry = {
        "ts": time.time(),
        "request_id": request_id,
        "method": method,
        "path": path,
        "status": status,
        "latency_ms": round(latency_ms, 2),
        "upstream": upstream,
        "model": model or "",
        "tokens_in": tokens_in,
        "tokens_out": tokens_out,
        "cost_est_usd": cost,
        "bytes_out": bytes_out,
    }
    with _HISTORY_LOCK:
        _HISTORY.append(entry)
    with _STATS_LOCK:
        _STATS["requests"] += 1
        _STATS["latency_sum_ms"] += latency_ms
        bucket = "status_2xx" if status < 400 else "status_4xx" if status < 500 else "status_5xx"
        _STATS[bucket] += 1
        _STATS["tokens_in"] += tokens_in
        _STATS["tokens_out"] += tokens_out
        _STATS["cost_est_usd"] += cost
    _persist_history(entry)


def _log_targets() -> dict[str, str]:
    """Discover streamable log files at request time.

    Every `*.log` in $LOG_DIR is exposed under its basename (minus the .log
    extension). Special targets (headroom.proxy) are added if the underlying
    file exists.
    """
    targets: dict[str, str] = {}
    try:
        for entry in os.listdir(LOG_DIR):
            if entry.endswith(".log"):
                targets[entry[:-4]] = os.path.join(LOG_DIR, entry)
    except OSError:
        pass
    if os.path.exists(HEADROOM_PROXY_LOG):
        targets["headroom.proxy"] = HEADROOM_PROXY_LOG
    return targets


def _fetch_json(url: str, timeout: float = 3.0) -> dict:
    target = urlsplit(url)
    cls = http.client.HTTPSConnection if target.scheme == "https" else http.client.HTTPConnection
    conn = cls(target.netloc, timeout=timeout)
    try:
        path = target.path or "/"
        if target.query:
            path = f"{path}?{target.query}"
        conn.request("GET", path)
        resp = conn.getresponse()
        body = resp.read()
        if resp.status >= 400:
            raise RuntimeError(f"upstream {url} returned {resp.status}")
        return json.loads(body.decode("utf-8"))
    finally:
        conn.close()


def _read_dashboard_html() -> bytes:
    if DASHBOARD_HTML_PATH:
        p = Path(DASHBOARD_HTML_PATH)
        if p.is_file():
            return p.read_bytes()
    for candidate in [
        Path(__file__).resolve().parent.parent / "share" / "dashboard.html",
        Path.home() / ".local" / "share" / "apx" / "dashboard.html",
    ]:
        if candidate.is_file():
            return candidate.read_bytes()
    return b"<!doctype html><meta charset=utf-8><title>apx</title><h1>apx dashboard not installed</h1>"


class GatewayHandler(BaseHTTPRequestHandler):
    protocol_version = "HTTP/1.1"
    server_version = "apx-gateway/0.1"

    def log_message(self, fmt: str, *args: object) -> None:
        log(fmt % args)

    def do_GET(self) -> None:  # noqa: N802
        if self._handle_dashboard_or_api():
            return
        if self.path in {"/livez", "/readyz", "/health"}:
            self._json(200, {"ok": True, "target": TARGET_URL})
            return
        self._proxy()

    def do_HEAD(self) -> None:  # noqa: N802
        if self.path in {"/", "/livez", "/readyz", "/health"}:
            self.send_response(200)
            self.send_header("content-type", "application/json")
            self.send_header("content-length", "0")
            self.send_header("connection", "close")
            self.end_headers()
            return
        self._proxy()

    def do_POST(self) -> None:  # noqa: N802
        self._proxy()

    def do_PUT(self) -> None:  # noqa: N802
        self._proxy()

    def do_PATCH(self) -> None:  # noqa: N802
        self._proxy()

    def do_DELETE(self) -> None:  # noqa: N802
        self._proxy()

    def do_OPTIONS(self) -> None:  # noqa: N802
        if self._handle_dashboard_or_api():
            return
        self._proxy()

    def _client_ip(self) -> str:
        try:
            return self.client_address[0]
        except Exception:  # noqa: BLE001
            return "unknown"

    def _authorized_for_dashboard(self) -> bool:
        if not DASHBOARD_TOKEN:
            return True
        provided = ""
        auth = self.headers.get("authorization", "")
        if auth.lower().startswith("bearer "):
            provided = auth[7:].strip()
        if not provided:
            parsed = urlsplit(self.path)
            provided = (parse_qs(parsed.query).get("token", [""])[0] or "").strip()
        return secrets.compare_digest(provided, DASHBOARD_TOKEN)

    def _handle_dashboard_or_api(self) -> bool:
        if not DASHBOARD_ENABLED:
            return False
        parsed = urlsplit(self.path)
        path = parsed.path
        query = parse_qs(parsed.query)

        if path.startswith("/proxy/pxpipe/") or path == "/proxy/pxpipe":
            self._passthrough(PXPIPE_URL, path[len("/proxy/pxpipe"):] or "/", parsed.query)
            return True
        if path.startswith("/proxy/squeezr/") or path == "/proxy/squeezr":
            self._passthrough(SQUEEZR_URL, path[len("/proxy/squeezr"):] or "/squeezr/dashboard", parsed.query)
            return True

        if path in ("/", "/dashboard"):
            if not self._authorized_for_dashboard():
                self._require_token()
                return True
            body = _read_dashboard_html()
            self._respond(200, body, content_type="text/html; charset=utf-8")
            return True
        if path.startswith("/api/"):
            if not self._authorized_for_dashboard():
                self._respond_json(401, {"error": "unauthorized", "hint": "set APX_DASHBOARD_TOKEN and pass ?token= or Authorization: Bearer"})
                return True
        if path == "/api/status":
            self._respond_json(200, self._build_status_payload())
            return True
        if path == "/api/history":
            n = min(int((query.get("n", ["100"])[0]) or 100), HISTORY_SIZE)
            with _HISTORY_LOCK:
                items = list(_HISTORY)[-n:]
            self._respond_json(200, {"items": items, "size": HISTORY_SIZE})
            return True
        if path == "/api/headroom/stats":
            try:
                data = _fetch_json(HEADROOM_URL + "/stats")
                self._respond_json(200, data)
            except Exception as exc:  # noqa: BLE001
                self._respond_json(502, {"error": str(exc)})
            return True
        if path == "/api/logs/stream":
            service = (query.get("service", ["supervisor"])[0]) or "supervisor"
            self._stream_log(service)
            return True
        if path == "/metrics":
            if not METRICS_ENABLED:
                self._respond_json(404, {"error": "metrics disabled; set APX_METRICS_ENABLED=1"})
                return True
            self._respond(200, self._build_metrics_payload(), content_type="text/plain; version=0.0.4; charset=utf-8")
            return True
        return False

    def _require_token(self) -> None:
        body = (
            b"<!doctype html><meta charset=utf-8><title>apx</title>"
            b"<h1>apx dashboard</h1><p>Set <code>APX_DASHBOARD_TOKEN</code> and open with "
            b"<code>?token=...</code> or an <code>Authorization: Bearer</code> header.</p>"
        )
        self._respond(401, body, content_type="text/html; charset=utf-8")

    def _passthrough(self, base_url: str, sub_path: str, query: str) -> None:
        target = urlsplit(base_url)
        if target.scheme not in {"http", "https"} or not target.netloc:
            self._respond_json(502, {"error": f"invalid passthrough target: {base_url}"})
            return
        path = sub_path if sub_path.startswith("/") else "/" + sub_path
        if query:
            path = f"{path}?{query}"
        conn_cls = http.client.HTTPSConnection if target.scheme == "https" else http.client.HTTPConnection
        conn = conn_cls(target.netloc, timeout=REQUEST_TIMEOUT)
        try:
            headers = {}
            for key in ("accept", "accept-encoding", "user-agent"):
                if key in self.headers:
                    headers[key] = self.headers[key]
            headers["Host"] = target.netloc
            body = self._read_request_body_bytes()
            conn.request(self.command, path, body=body, headers=headers)
            resp = conn.getresponse()
            self.send_response(resp.status, resp.reason)
            for key, value in resp.getheaders():
                lower = key.lower()
                if lower in HOP_BY_HOP_HEADERS or lower == "x-frame-options" or lower == "content-security-policy":
                    continue
                self.send_header(key, value)
            self.send_header("connection", "close")
            self.end_headers()
            if self.command != "HEAD":
                while True:
                    chunk = resp.read(8192)
                    if not chunk:
                        break
                    try:
                        self.wfile.write(chunk)
                    except Exception:  # noqa: BLE001
                        break
        except Exception as exc:  # noqa: BLE001
            self._respond_json(502, {"error": "proxy_error", "message": str(exc)})
        finally:
            conn.close()

    def _build_status_payload(self) -> dict:
        cfg = _load_config_values()
        mode = _current_mode(cfg)
        hops = _chain_hops(cfg, mode)
        with _STATS_LOCK:
            req = _STATS["requests"]
            avg = (_STATS["latency_sum_ms"] / req) if req else 0.0
            stats_snapshot = dict(_STATS)
        return {
            "version": _read_version(),
            "mode": mode,
            "chain_hops": hops,
            "chain_short": " -> ".join(hops),
            "health": _health_snapshot(cfg),
            "request_count": req,
            "avg_latency_ms": avg,
            "uptime_seconds": int(time.time() - START_TIME),
            "target_url": TARGET_URL,
            "headroom_url": HEADROOM_URL,
            "pxpipe_url": PXPIPE_URL,
            "squeezr_url": SQUEEZR_URL,
            "stats": stats_snapshot,
            "bind_host": BIND_HOST,
            "bind_warning": (
                "bound to non-loopback host; dashboard exposes logs and history"
                if BIND_HOST not in ("127.0.0.1", "::1", "localhost")
                else ""
            ),
        }

    def _build_metrics_payload(self) -> bytes:
        with _STATS_LOCK:
            snapshot = dict(_STATS)
        lines = [
            "# HELP apx_requests_total total number of requests proxied through the gateway",
            "# TYPE apx_requests_total counter",
            f"apx_requests_total {snapshot['requests']}",
            "# HELP apx_latency_ms_sum sum of per-request latency in milliseconds",
            "# TYPE apx_latency_ms_sum counter",
            f"apx_latency_ms_sum {snapshot['latency_sum_ms']}",
            "# HELP apx_requests_by_status_total requests bucketed by HTTP status class",
            "# TYPE apx_requests_by_status_total counter",
            f'apx_requests_by_status_total{{class="2xx"}} {snapshot["status_2xx"]}',
            f'apx_requests_by_status_total{{class="4xx"}} {snapshot["status_4xx"]}',
            f'apx_requests_by_status_total{{class="5xx"}} {snapshot["status_5xx"]}',
            "# HELP apx_tokens_in_total total input tokens observed",
            "# TYPE apx_tokens_in_total counter",
            f"apx_tokens_in_total {snapshot['tokens_in']}",
            "# HELP apx_tokens_out_total total output tokens observed",
            "# TYPE apx_tokens_out_total counter",
            f"apx_tokens_out_total {snapshot['tokens_out']}",
            "# HELP apx_cost_usd_total estimated cost in USD",
            "# TYPE apx_cost_usd_total counter",
            f"apx_cost_usd_total {snapshot['cost_est_usd']}",
            "# HELP apx_uptime_seconds gateway process uptime in seconds",
            "# TYPE apx_uptime_seconds gauge",
            f"apx_uptime_seconds {int(time.time() - START_TIME)}",
        ]
        return ("\n".join(lines) + "\n").encode("utf-8")

    def _stream_log(self, service: str) -> None:
        allowed = _log_targets()
        path = allowed.get(service)
        if not path:
            self._respond_json(400, {"error": f"unknown service: {service}"})
            return

        ip = self._client_ip()
        with _LOG_STREAMS_LOCK:
            active = _LOG_STREAMS_BY_IP[ip]
            if active >= MAX_LOG_STREAMS_PER_IP:
                self._respond_json(429, {"error": "too many log streams", "limit": MAX_LOG_STREAMS_PER_IP})
                return
            _LOG_STREAMS_BY_IP[ip] = active + 1
        try:
            self._stream_log_body(path, service)
        finally:
            with _LOG_STREAMS_LOCK:
                _LOG_STREAMS_BY_IP[ip] = max(0, _LOG_STREAMS_BY_IP[ip] - 1)

    def _stream_log_body(self, path: str, service: str) -> None:
        try:
            self.send_response(200)
            self.send_header("content-type", "text/event-stream")
            self.send_header("cache-control", "no-cache")
            self.send_header("connection", "keep-alive")
            self.send_header("x-accel-buffering", "no")
            self.end_headers()
        except Exception:
            return

        if not os.path.exists(path):
            try:
                Path(path).parent.mkdir(parents=True, exist_ok=True)
                Path(path).touch()
            except OSError:
                pass

        try:
            with open(path, "r", encoding="utf-8", errors="replace") as fh:
                fh.seek(0, os.SEEK_END)
                size = fh.tell()
                start = max(0, size - 4096)
                fh.seek(start)
                if start > 0:
                    fh.readline()
                tail = fh.read()
                for line in tail.splitlines():
                    self._sse_write(line)
                last_heartbeat = time.time()
                while True:
                    where = fh.tell()
                    line = fh.readline()
                    if not line:
                        if time.time() - last_heartbeat > 15:
                            try:
                                self.wfile.write(b": keepalive\n\n")
                                self.wfile.flush()
                                last_heartbeat = time.time()
                            except Exception:
                                return
                        time.sleep(0.5)
                        fh.seek(where)
                        continue
                    if line.endswith("\n"):
                        line = line[:-1]
                    if not self._sse_write(line):
                        return
                    last_heartbeat = time.time()
        except Exception as exc:  # noqa: BLE001
            log(f"log stream error for {service}: {exc}")

    def _sse_write(self, line: str) -> bool:
        try:
            payload = f"data: {line}\n\n".encode("utf-8")
            self.wfile.write(payload)
            self.wfile.flush()
            return True
        except Exception:
            return False

    def _respond_json(self, status: int, payload: dict) -> None:
        body = json.dumps(payload, default=str).encode("utf-8")
        self._respond(status, body, content_type="application/json")

    def _respond(self, status: int, body: bytes, content_type: str) -> None:
        try:
            self.send_response(status)
            self.send_header("content-type", content_type)
            self.send_header("content-length", str(len(body)))
            self.send_header("cache-control", "no-store")
            self.send_header("connection", "close")
            self.end_headers()
            if self.command != "HEAD":
                self.wfile.write(body)
        except Exception:
            pass

    def _json(self, status: int, payload: dict[str, object]) -> None:
        self._respond_json(status, payload)

    def _read_request_body_bytes(self, cap: int | None = None) -> bytes:
        if cap is None:
            cap = MAX_REQUEST_BYTES
        length = self.headers.get("content-length")
        if length:
            try:
                n = int(length)
            except ValueError:
                return b""
            if n <= 0:
                return b""
            return self.rfile.read(min(n, cap))
        if self.headers.get("transfer-encoding", "").lower() == "chunked":
            chunks: list[bytes] = []
            remaining = cap
            while True:
                size_line = self.rfile.readline().strip()
                if not size_line:
                    break
                try:
                    size = int(size_line.split(b";")[0], 16)
                except ValueError:
                    break
                if size == 0:
                    self.rfile.readline()
                    break
                read = self.rfile.read(min(size, remaining))
                chunks.append(read)
                self.rfile.readline()
                remaining -= len(read)
                if remaining <= 0:
                    break
            return b"".join(chunks)
        return b""

    def _proxy_headers(self, target, request_id: str) -> dict[str, str]:
        headers: dict[str, str] = {}
        for key, value in self.headers.items():
            lower = key.lower()
            if lower in HOP_BY_HOP_HEADERS or lower == "host":
                continue
            headers[key] = value
        headers["Host"] = target.netloc
        headers["X-Apx-Gateway-Target"] = TARGET_URL
        headers["X-Apx-Request-Id"] = request_id
        return headers

    def _extract_tokens_from_json(self, payload_bytes: bytes) -> tuple[int, int]:
        if not payload_bytes:
            return 0, 0
        try:
            data = json.loads(payload_bytes.decode("utf-8", errors="replace"))
        except Exception:  # noqa: BLE001
            return 0, 0
        if not isinstance(data, dict):
            return 0, 0
        usage = data.get("usage")
        if isinstance(usage, dict):
            tokens_in = int(usage.get("input_tokens", usage.get("prompt_tokens", 0)) or 0)
            tokens_out = int(usage.get("output_tokens", usage.get("completion_tokens", 0)) or 0)
            return tokens_in, tokens_out
        return 0, 0

    def _extract_tokens_from_sse(self, body_bytes: bytes) -> tuple[int, int]:
        """Extract usage from SSE frames.

        Anthropic emits usage on `event: message_start` (input_tokens) and
        `event: message_delta` (output_tokens). OpenAI streams a single
        `data: {"usage": ...}` chunk when `stream_options.include_usage` is
        set. We scan line-oriented rather than parsing full frames so we can
        keep the response capture cheap.
        """
        if not body_bytes:
            return 0, 0
        tokens_in = 0
        tokens_out = 0
        try:
            text = body_bytes.decode("utf-8", errors="replace")
        except Exception:  # noqa: BLE001
            return 0, 0
        for line in text.splitlines():
            if not line.startswith("data:"):
                continue
            data = line[5:].strip()
            if not data or data == "[DONE]":
                continue
            try:
                obj = json.loads(data)
            except Exception:  # noqa: BLE001
                continue
            if not isinstance(obj, dict):
                continue
            usage = obj.get("usage")
            if usage is None:
                msg = obj.get("message")
                if isinstance(msg, dict):
                    usage = msg.get("usage")
            if isinstance(usage, dict):
                new_in = int(usage.get("input_tokens", usage.get("prompt_tokens", 0)) or 0)
                new_out = int(usage.get("output_tokens", usage.get("completion_tokens", 0)) or 0)
                if new_in:
                    tokens_in = new_in
                if new_out:
                    tokens_out = new_out
        return tokens_in, tokens_out

    def _proxy(self) -> None:
        target = urlsplit(TARGET_URL)
        if target.scheme not in {"http", "https"} or not target.netloc:
            self._json(502, {"error": f"invalid gateway target: {TARGET_URL}"})
            return

        request_id = self.headers.get("x-apx-request-id") or _new_request_id()
        path = self.path if self.path.startswith("/") else f"/{self.path}"
        upstream_path = f"{target.path.rstrip('/')}{path}"
        if not upstream_path.startswith("/"):
            upstream_path = f"/{upstream_path}"

        body = self._read_request_body_bytes()
        model = _model_from_path(path, body)

        conn_cls = http.client.HTTPSConnection if target.scheme == "https" else http.client.HTTPConnection
        started = time.time()
        status = 0
        bytes_out = 0
        response_chunks: list[bytes] = []
        capture_response = self.command == "POST" and body
        conn = conn_cls(target.netloc, timeout=REQUEST_TIMEOUT)
        try:
            conn.request(self.command, upstream_path, body=body, headers=self._proxy_headers(target, request_id))
            resp = conn.getresponse()
            status = resp.status
            content_type = resp.getheader("content-type", "").lower()
            self.send_response(resp.status, resp.reason)
            for key, value in resp.getheaders():
                lower = key.lower()
                if lower in HOP_BY_HOP_HEADERS:
                    continue
                self.send_header(key, value)
            self.send_header("x-apx-request-id", request_id)
            self.send_header("connection", "close")
            self.end_headers()

            if self.command != "HEAD":
                is_stream = "text/event-stream" in content_type
                capture_cap = 2 * 1024 * 1024 if is_stream else 512 * 1024
                capture_size = 0
                while True:
                    chunk = resp.read1(65536) if is_stream else resp.read(8192)
                    if not chunk:
                        break
                    try:
                        self.wfile.write(chunk)
                        self.wfile.flush()
                    except (BrokenPipeError, ConnectionResetError):
                        break
                    bytes_out += len(chunk)
                    if capture_response and capture_size < capture_cap:
                        response_chunks.append(chunk)
                        capture_size += len(chunk)

            elapsed_ms = (time.time() - started) * 1000

            tokens_in = 0
            tokens_out = 0
            if capture_response and 200 <= status < 300:
                joined = b"".join(response_chunks)
                if "text/event-stream" in content_type:
                    tokens_in, tokens_out = self._extract_tokens_from_sse(joined)
                elif "application/json" in content_type:
                    tokens_in, tokens_out = self._extract_tokens_from_json(joined)

            log(
                f"{self.command} {self.path} -> {resp.status} via {TARGET_URL} "
                f"({int(elapsed_ms)}ms) req_id={request_id}"
            )
            _record_request(
                self.command,
                self.path,
                resp.status,
                elapsed_ms,
                TARGET_URL,
                request_id=request_id,
                model=model,
                tokens_in=tokens_in,
                tokens_out=tokens_out,
                bytes_out=bytes_out,
            )
        except BrokenPipeError:
            log(f"client disconnected during {self.command} {self.path} req_id={request_id}")
            _record_request(
                self.command,
                self.path,
                status or 499,
                (time.time() - started) * 1000,
                TARGET_URL,
                request_id=request_id,
                model=model,
                bytes_out=bytes_out,
            )
        except Exception as exc:  # noqa: BLE001
            log(f"proxy error for {self.command} {self.path} req_id={request_id}: {exc}")
            _record_request(
                self.command,
                self.path,
                502,
                (time.time() - started) * 1000,
                TARGET_URL,
                request_id=request_id,
                model=model,
                bytes_out=bytes_out,
            )
            if not self.wfile.closed:
                try:
                    self._json(502, {"error": "gateway_proxy_error", "message": str(exc)})
                except Exception:
                    pass
        finally:
            conn.close()


def main() -> int:
    httpd = ThreadingHTTPServer((BIND_HOST, PORT), GatewayHandler)
    httpd.daemon_threads = True

    def _shutdown(_signum, _frame) -> None:
        log("shutting down")
        httpd.shutdown()

    signal.signal(signal.SIGTERM, _shutdown)
    signal.signal(signal.SIGINT, _shutdown)

    health_thread = threading.Thread(target=_health_refresher_loop, daemon=True)
    health_thread.start()

    if BIND_HOST not in ("127.0.0.1", "::1", "localhost"):
        log(
            f"WARNING: apx-gateway is bound to {BIND_HOST}; dashboard exposes "
            "logs and history. Set APX_DASHBOARD_TOKEN or bind to 127.0.0.1."
        )
    if DASHBOARD_ENABLED and not DASHBOARD_TOKEN and BIND_HOST not in ("127.0.0.1", "::1", "localhost"):
        log("WARNING: dashboard is enabled without APX_DASHBOARD_TOKEN; refusing to start")
        return 2

    log(
        f"listening on http://{BIND_HOST}:{PORT} -> {TARGET_URL}"
        f" (dashboard={'on' if DASHBOARD_ENABLED else 'off'},"
        f" auth={'token' if DASHBOARD_TOKEN else 'none'},"
        f" history_persist={'on' if HISTORY_PERSIST else 'off'})"
    )
    httpd.serve_forever()
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
