#!/usr/bin/env python3
"""Small streaming reverse proxy for AI proxy stack mode routing."""

from __future__ import annotations

import http.client
import json
import os
import signal
import sys
import time
from http.server import BaseHTTPRequestHandler, ThreadingHTTPServer
from urllib.parse import urlsplit

BIND_HOST = os.environ.get("GATEWAY_HOST") or os.environ.get("HOST") or "127.0.0.1"
PORT = int(os.environ.get("GATEWAY_PORT", "8787"))
TARGET_URL = os.environ.get("GATEWAY_TARGET_URL", "https://api.anthropic.com").rstrip("/")
REQUEST_TIMEOUT = float(os.environ.get("GATEWAY_REQUEST_TIMEOUT_SECONDS", "600"))

HOP_BY_HOP_HEADERS = {
    "connection",
    "keep-alive",
    "proxy-authenticate",
    "proxy-authorization",
    "te",
    "trailer",
    "transfer-encoding",
    "upgrade",
}


def log(message: str) -> None:
    print(f"[{time.strftime('%Y-%m-%dT%H:%M:%S%z')}] [gateway] {message}", flush=True)


class GatewayHandler(BaseHTTPRequestHandler):
    protocol_version = "HTTP/1.1"
    server_version = "ai-proxy-gateway/0.1"

    def log_message(self, fmt: str, *args: object) -> None:
        log(fmt % args)

    def do_GET(self) -> None:  # noqa: N802
        if self.path in {"/", "/livez", "/readyz", "/health"}:
            self._json(200, {"ok": True, "target": TARGET_URL})
            return
        self._proxy()

    def do_HEAD(self) -> None:  # noqa: N802
        if self.path in {"/", "/livez", "/readyz", "/health"}:
            body = json.dumps({"ok": True, "target": TARGET_URL}).encode()
            self.send_response(200)
            self.send_header("content-type", "application/json")
            self.send_header("content-length", str(len(body)))
            self.send_header("connection", "close")
            self.end_headers()
            return
        self._proxy()

    def do_POST(self) -> None:  # noqa: N802
        self._proxy()

    def do_PUT(self) -> None:  # noqa: N802
        self._proxy()

    def do_PATCH(self) -> None:  # noqa: N802
        self._proxy()

    def do_DELETE(self) -> None:  # noqa: N802
        self._proxy()

    def do_OPTIONS(self) -> None:  # noqa: N802
        self._proxy()

    def _json(self, status: int, payload: dict[str, object]) -> None:
        body = json.dumps(payload).encode()
        self.send_response(status)
        self.send_header("content-type", "application/json")
        self.send_header("content-length", str(len(body)))
        self.send_header("connection", "close")
        self.end_headers()
        if self.command != "HEAD":
            self.wfile.write(body)

    def _request_body(self) -> bytes:
        length = self.headers.get("content-length")
        if not length:
            return b""
        return self.rfile.read(int(length))

    def _proxy_headers(self, target) -> dict[str, str]:
        headers: dict[str, str] = {}
        for key, value in self.headers.items():
            lower = key.lower()
            if lower in HOP_BY_HOP_HEADERS or lower == "host":
                continue
            headers[key] = value
        headers["Host"] = target.netloc
        headers["X-AI-Proxy-Gateway-Target"] = TARGET_URL
        return headers

    def _proxy(self) -> None:
        target = urlsplit(TARGET_URL)
        if target.scheme not in {"http", "https"} or not target.netloc:
            self._json(502, {"error": f"invalid gateway target: {TARGET_URL}"})
            return

        path = self.path if self.path.startswith("/") else f"/{self.path}"
        upstream_path = f"{target.path.rstrip('/')}{path}"
        if not upstream_path.startswith("/"):
            upstream_path = f"/{upstream_path}"

        body = self._request_body()
        conn_cls = http.client.HTTPSConnection if target.scheme == "https" else http.client.HTTPConnection
        started = time.time()
        conn = conn_cls(target.netloc, timeout=REQUEST_TIMEOUT)
        try:
            conn.request(self.command, upstream_path, body=body, headers=self._proxy_headers(target))
            resp = conn.getresponse()
            self.send_response(resp.status, resp.reason)
            for key, value in resp.getheaders():
                lower = key.lower()
                if lower in HOP_BY_HOP_HEADERS:
                    continue
                self.send_header(key, value)
            self.send_header("connection", "close")
            self.end_headers()

            if self.command != "HEAD":
                while True:
                    chunk = resp.read(8192)
                    if not chunk:
                        break
                    self.wfile.write(chunk)
                    self.wfile.flush()

            elapsed_ms = int((time.time() - started) * 1000)
            log(f"{self.command} {self.path} -> {resp.status} via {TARGET_URL} ({elapsed_ms}ms)")
        except BrokenPipeError:
            log(f"client disconnected during {self.command} {self.path}")
        except Exception as exc:  # noqa: BLE001
            log(f"proxy error for {self.command} {self.path}: {exc}")
            if not self.wfile.closed:
                try:
                    self._json(502, {"error": "gateway_proxy_error", "message": str(exc)})
                except Exception:
                    pass
        finally:
            conn.close()


def main() -> int:
    httpd = ThreadingHTTPServer((BIND_HOST, PORT), GatewayHandler)
    httpd.daemon_threads = True

    def _shutdown(_signum, _frame) -> None:
        log("shutting down")
        httpd.shutdown()

    signal.signal(signal.SIGTERM, _shutdown)
    signal.signal(signal.SIGINT, _shutdown)

    log(f"listening on http://{BIND_HOST}:{PORT} -> {TARGET_URL}")
    httpd.serve_forever()
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
