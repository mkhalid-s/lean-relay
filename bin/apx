#!/usr/bin/env bash
set -Eeuo pipefail

LABEL="${APX_LABEL:-io.github.apx}"
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
if [[ -d "$SCRIPT_DIR/../config" ]]; then
  DEFAULT_STACK_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"
else
  DEFAULT_STACK_ROOT="$HOME/.local/share/apx"
fi
STACK_ROOT="${APX_ROOT:-$DEFAULT_STACK_ROOT}"
CONFIG_FILE="${APX_CONFIG:-$HOME/.config/apx/config.env}"
CONFIG_DIR="$(dirname "$CONFIG_FILE")"
SOURCE_PATH_FILE="$CONFIG_DIR/source.path"
# PRICES_FILE is not consumed by the CLI (apx-gateway reads it directly), but
# it is documented here so users find the expected path via `grep` in bin/apx.
# shellcheck disable=SC2034
PRICES_FILE="$CONFIG_DIR/prices.env"
STATE_DIR="${APX_STATE:-$HOME/.local/state/apx}"
VERSION_FILE="$STATE_DIR/VERSION"
SHARE_DIR="${APX_SHARE:-$HOME/.local/share/apx}"
DASHBOARD_HTML="${APX_DASHBOARD_HTML:-$SHARE_DIR/dashboard.html}"
RUN_DIR="$STATE_DIR/run"
LOG_DIR="$STATE_DIR/logs"
UPDATE_REPO_URL="${APX_REPO_URL:-https://github.com/mkhalid-s/ai-proxy-stack.git}"
UPDATE_REPO_BRANCH="${APX_REPO_BRANCH:-main}"
PLIST_FILE="$HOME/Library/LaunchAgents/$LABEL.plist"
CLAUDE_SETTINGS_FILE="${APX_CLAUDE_SETTINGS:-$HOME/.claude/settings.json}"
DEFAULT_PATH="$HOME/.local/bin:/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin:/usr/sbin:/sbin"
export PATH="${APX_PATH:-$DEFAULT_PATH}:$PATH"

mkdir -p "$RUN_DIR" "$LOG_DIR"

load_config() {
  if [[ ! -f "$CONFIG_FILE" ]]; then
    echo "missing config: $CONFIG_FILE" >&2
    exit 1
  fi
  # shellcheck disable=SC1090
  source "$CONFIG_FILE"
  : "${BIND_HOST:=127.0.0.1}"
  : "${GATEWAY_PORT:=8787}"
  : "${PXPIPE_PORT:=47821}"
  : "${HEADROOM_PORT:=8788}"
  : "${SQUEEZR_PORT:=18780}"
  : "${SQUEEZR_MITM_PORT:=18781}"
  : "${WORKDIR:=$PWD}"
  : "${GATEWAY_ENABLED:=1}"
  : "${PXPIPE_ENABLED:=1}"
  : "${HEADROOM_ENABLED:=1}"
  : "${SQUEEZR_ENABLED:=0}"
  : "${GATEWAY_CMD:=$HOME/.local/bin/apx-gateway}"
  : "${PXPIPE_CMD:=npx -y pxpipe-proxy@0.8.0}"
  : "${SQUEEZR_CMD:=$HOME/.local/bin/apx-squeezr}"
  : "${PXPIPE_MODELS:=claude-fable-5,claude-opus-4-8,claude-opus-4-7,claude-sonnet-5,claude-sonnet-4-6,gpt-5.6,gpt-5.5}"
  : "${HEADROOM_CMD:=headroom proxy}"
  : "${PXPIPE_TARGET_API_URL:=https://api.anthropic.com}"
  : "${HEADROOM_TARGET_API_URL:=http://$BIND_HOST:$PXPIPE_PORT}"
  : "${GATEWAY_TARGET_API_URL:=http://$BIND_HOST:$HEADROOM_PORT}"
  : "${HEADROOM_MODE:=token}"
  : "${HEADROOM_ENABLE_TOOL_SEARCH:=true}"
  : "${HEADROOM_CODE_AWARE_ENABLED:=1}"
  : "${HEADROOM_CODE_GRAPH:=1}"
  : "${HEADROOM_NO_RATE_LIMIT:=1}"
  : "${HEADROOM_NO_SUBSCRIPTION_TRACKING:=1}"
  : "${HEADROOM_NO_TELEMETRY:=1}"
  : "${HEADROOM_TLS_STRICT:=0}"
  : "${CA_BUNDLE_FILE:=}"
  : "${TIKTOKEN_CACHE_DIR:=$HOME/.cache/tiktoken}"
  : "${HEALTH_INTERVAL_SECONDS:=10}"
  : "${STARTUP_TIMEOUT_SECONDS:=45}"
  : "${RESTART_BACKOFF_SECONDS:=3}"
  : "${ADOPT_EXISTING:=1}"
  : "${PXPIPE_EXTRA_ARGS:=}"
  : "${HEADROOM_EXTRA_ARGS:=}"
  : "${SQUEEZR_EXTRA_ARGS:=}"
  : "${APX_DASHBOARD_ENABLED:=1}"
  : "${APX_HISTORY_SIZE:=500}"
  : "${APX_METRICS_ENABLED:=0}"
  # APX_CHAIN is authoritative; if unset (legacy config), infer it from the
  # ENABLED flags and TARGET_API_URL routing so upgrades don't break silently.
  if [[ -z "${APX_CHAIN+x}" ]]; then
    APX_CHAIN=""
    if [[ "$HEADROOM_ENABLED" == "1" && "$PXPIPE_ENABLED" == "1" ]]; then
      if [[ "$GATEWAY_TARGET_API_URL" == "http://$BIND_HOST:$PXPIPE_PORT" ]]; then
        APX_CHAIN="pxpipe,headroom"
      else
        APX_CHAIN="headroom,pxpipe"
      fi
    elif [[ "$HEADROOM_ENABLED" == "1" && "$SQUEEZR_ENABLED" == "1" ]]; then
      APX_CHAIN="headroom,squeezr"
    elif [[ "$HEADROOM_ENABLED" == "1" ]]; then
      APX_CHAIN="headroom"
    elif [[ "$PXPIPE_ENABLED" == "1" ]]; then
      APX_CHAIN="pxpipe"
    elif [[ "$SQUEEZR_ENABLED" == "1" ]]; then
      APX_CHAIN="squeezr"
    fi
  fi
  export APX_CHAIN
}

now() { date '+%Y-%m-%dT%H:%M:%S%z'; }
log() {
  local line
  line="[$(now)] $*"
  printf '%s\n' "$line" >> "$LOG_DIR/supervisor.log"
  if [[ -t 2 ]]; then
    printf '%s\n' "$line" >&2
  fi
}

pid_alive() { [[ -n "${1:-}" ]] && kill -0 "$1" 2>/dev/null; }
read_pid() { [[ -f "$1" ]] && tr -d '[:space:]' < "$1" || true; }
port_pid() { lsof -nP -tiTCP:"$1" -sTCP:LISTEN 2>/dev/null | awk 'NR==1 {print; exit}' || true; }
proc_cmd() { ps -p "$1" -o command= 2>/dev/null || true; }

url_ok() {
  local url="$1"
  curl -fsS --max-time 3 -o /dev/null "$url" 2>/dev/null
}

export_ca_bundle() {
  [[ -n "${CA_BUNDLE_FILE:-}" && -f "$CA_BUNDLE_FILE" ]] || return 0
  export SSL_CERT_FILE="$CA_BUNDLE_FILE"
  export REQUESTS_CA_BUNDLE="$CA_BUNDLE_FILE"
  export CURL_CA_BUNDLE="$CA_BUNDLE_FILE"
  export NODE_EXTRA_CA_CERTS="$CA_BUNDLE_FILE"
}

gateway_ok() { url_ok "http://$BIND_HOST:$GATEWAY_PORT/livez"; }
pxpipe_ok() { url_ok "http://$BIND_HOST:$PXPIPE_PORT/"; }
headroom_ok() { url_ok "http://$BIND_HOST:$HEADROOM_PORT/livez"; }
squeezr_ok() { url_ok "http://$BIND_HOST:$SQUEEZR_PORT/squeezr/health"; }

wait_until_ok() {
  local name="$1" check_fn="$2" deadline=$((SECONDS + STARTUP_TIMEOUT_SECONDS))
  until "$check_fn"; do
    if (( SECONDS >= deadline )); then
      log "$name did not become healthy within ${STARTUP_TIMEOUT_SECONDS}s"
      return 1
    fi
    sleep 1
  done
  log "$name is healthy"
}

safe_kill_port_owner() {
  local name="$1" port="$2" pattern="$3"
  local pid cmd
  pid="$(port_pid "$port")"
  [[ -z "$pid" ]] && return 0
  cmd="$(proc_cmd "$pid")"
  if [[ "$cmd" =~ $pattern ]]; then
    log "taking over $name on port $port from pid $pid: $cmd"
    kill "$pid" 2>/dev/null || true
    sleep 2
    if pid_alive "$pid"; then
      log "force stopping $name pid $pid"
      kill -9 "$pid" 2>/dev/null || true
    fi
    return 0
  fi
  log "refusing to kill unknown process on $name port $port: pid $pid: $cmd"
  return 1
}

start_gateway() {
  local pid existing log_file
  log_file="$LOG_DIR/gateway.log"
  pid="$(read_pid "$RUN_DIR/gateway.pid")"
  if pid_alive "$pid" && gateway_ok; then
    return 0
  fi
  existing="$(port_pid "$GATEWAY_PORT")"
  if [[ -n "$existing" ]]; then
    if [[ "${APX_TAKEOVER:-0}" == "1" ]]; then
      safe_kill_port_owner "gateway" "$GATEWAY_PORT" 'apx-gateway|python.*apx-gateway' || return 1
    elif [[ "$ADOPT_EXISTING" == "1" ]]; then
      echo "$existing" > "$RUN_DIR/gateway.adopted.pid"
      log "Gateway already listening on $GATEWAY_PORT; adopting external pid $existing"
      return 0
    else
      log "Gateway port $GATEWAY_PORT is already in use by pid $existing"
      return 1
    fi
  fi
  log "starting Gateway on $BIND_HOST:$GATEWAY_PORT -> $GATEWAY_TARGET_API_URL"
  (
    cd "$WORKDIR"
    export HOST="$BIND_HOST" GATEWAY_HOST="$BIND_HOST" GATEWAY_PORT="$GATEWAY_PORT" GATEWAY_TARGET_URL="$GATEWAY_TARGET_API_URL"
    export APX_DASHBOARD_ENABLED="$APX_DASHBOARD_ENABLED" APX_DASHBOARD_HTML="$DASHBOARD_HTML" APX_HISTORY_SIZE="$APX_HISTORY_SIZE"
    export APX_METRICS_ENABLED="$APX_METRICS_ENABLED"
    export APX_CHAIN="${APX_CHAIN:-}"
    export APX_STATE_DIR="$STATE_DIR" APX_LOG_DIR="$LOG_DIR" APX_CONFIG="$CONFIG_FILE"
    export APX_HEADROOM_URL="http://$BIND_HOST:$HEADROOM_PORT" APX_PXPIPE_URL="http://$BIND_HOST:$PXPIPE_PORT" APX_SQUEEZR_URL="http://$BIND_HOST:$SQUEEZR_PORT"
    exec bash -lc "exec $GATEWAY_CMD"
  ) >> "$log_file" 2>&1 &
  echo $! > "$RUN_DIR/gateway.pid"
  wait_until_ok Gateway gateway_ok
}

start_squeezr() {
  local pid existing log_file
  log_file="$LOG_DIR/squeezr.log"
  pid="$(read_pid "$RUN_DIR/squeezr.pid")"
  if pid_alive "$pid" && squeezr_ok; then
    return 0
  fi
  existing="$(port_pid "$SQUEEZR_PORT")"
  if [[ -n "$existing" ]]; then
    if [[ "${APX_TAKEOVER:-0}" == "1" ]]; then
      safe_kill_port_owner "squeezr" "$SQUEEZR_PORT" 'squeezr|node .*squeezr|npx .*squeezr' || return 1
    elif [[ "$ADOPT_EXISTING" == "1" ]]; then
      echo "$existing" > "$RUN_DIR/squeezr.adopted.pid"
      log "Squeezr already listening on $SQUEEZR_PORT; adopting external pid $existing"
      return 0
    else
      log "Squeezr port $SQUEEZR_PORT is already in use by pid $existing"
      return 1
    fi
  fi
  log "starting Squeezr on $BIND_HOST:$SQUEEZR_PORT"
  (
    cd "$WORKDIR"
    export_ca_bundle
    export SQUEEZR_PORT="$SQUEEZR_PORT" SQUEEZR_MITM_PORT="$SQUEEZR_MITM_PORT" SQUEEZR_DAEMON=1
    exec bash -lc "exec $SQUEEZR_CMD $SQUEEZR_EXTRA_ARGS"
  ) >> "$log_file" 2>&1 &
  echo $! > "$RUN_DIR/squeezr.pid"
  wait_until_ok Squeezr squeezr_ok
}

start_pxpipe() {
  local pid existing log_file
  log_file="$LOG_DIR/pxpipe.log"
  pid="$(read_pid "$RUN_DIR/pxpipe.pid")"
  if pid_alive "$pid" && pxpipe_ok; then
    return 0
  fi
  existing="$(port_pid "$PXPIPE_PORT")"
  if [[ -n "$existing" ]]; then
    if [[ "${APX_TAKEOVER:-0}" == "1" ]]; then
      safe_kill_port_owner "pxpipe" "$PXPIPE_PORT" 'pxpipe|node .*/pxpipe' || return 1
    elif [[ "$ADOPT_EXISTING" == "1" ]]; then
      echo "$existing" > "$RUN_DIR/pxpipe.adopted.pid"
      log "pxpipe already listening on $PXPIPE_PORT; adopting external pid $existing"
      return 0
    else
      log "pxpipe port $PXPIPE_PORT is already in use by pid $existing"
      return 1
    fi
  fi
  log "starting pxpipe on $BIND_HOST:$PXPIPE_PORT"
  (
    cd "$WORKDIR"
    export_ca_bundle
    export PORT="$PXPIPE_PORT" PXPIPE_PORT="$PXPIPE_PORT" HOST="$BIND_HOST" PXPIPE_MODELS="$PXPIPE_MODELS" ANTHROPIC_UPSTREAM="$PXPIPE_TARGET_API_URL"
    exec bash -lc "exec $PXPIPE_CMD $PXPIPE_EXTRA_ARGS"
  ) >> "$log_file" 2>&1 &
  echo $! > "$RUN_DIR/pxpipe.pid"
  wait_until_ok pxpipe pxpipe_ok
}

headroom_args() {
  local args="--host '$BIND_HOST' --port '$HEADROOM_PORT' --mode '$HEADROOM_MODE'"
  [[ "$HEADROOM_NO_RATE_LIMIT" == "1" ]] && args="$args --no-rate-limit"
  [[ "$HEADROOM_NO_SUBSCRIPTION_TRACKING" == "1" ]] && args="$args --no-subscription-tracking"
  [[ "$HEADROOM_NO_TELEMETRY" == "1" ]] && args="$args --no-telemetry"
  [[ "$HEADROOM_CODE_GRAPH" == "1" ]] && args="$args --code-graph"
  printf '%s %s' "$args" "$HEADROOM_EXTRA_ARGS"
}

start_headroom() {
  local pid existing log_file
  log_file="$LOG_DIR/headroom.log"
  pid="$(read_pid "$RUN_DIR/headroom.pid")"
  if pid_alive "$pid" && headroom_ok; then
    return 0
  fi
  existing="$(port_pid "$HEADROOM_PORT")"
  if [[ -n "$existing" ]]; then
    if [[ "${APX_TAKEOVER:-0}" == "1" ]]; then
      safe_kill_port_owner "headroom" "$HEADROOM_PORT" 'headroom|Python' || return 1
    elif [[ "$ADOPT_EXISTING" == "1" ]]; then
      echo "$existing" > "$RUN_DIR/headroom.adopted.pid"
      log "Headroom already listening on $HEADROOM_PORT; adopting external pid $existing"
      return 0
    else
      log "Headroom port $HEADROOM_PORT is already in use by pid $existing"
      return 1
    fi
  fi
  log "starting Headroom on $BIND_HOST:$HEADROOM_PORT -> $HEADROOM_TARGET_API_URL"
  (
    cd "$WORKDIR"
    export_ca_bundle
    export TIKTOKEN_CACHE_DIR="$TIKTOKEN_CACHE_DIR"
    export ANTHROPIC_TARGET_API_URL="$HEADROOM_TARGET_API_URL"
    export ENABLE_TOOL_SEARCH="$HEADROOM_ENABLE_TOOL_SEARCH"
    export HEADROOM_CODE_AWARE_ENABLED="$HEADROOM_CODE_AWARE_ENABLED"
    export HEADROOM_TLS_STRICT="$HEADROOM_TLS_STRICT"
    exec bash -lc "exec $HEADROOM_CMD $(headroom_args)"
  ) >> "$log_file" 2>&1 &
  echo $! > "$RUN_DIR/headroom.pid"
  wait_until_ok Headroom headroom_ok
}

stop_owned_process() {
  local name="$1" pid_file="$2" pid
  pid="$(read_pid "$pid_file")"
  if pid_alive "$pid"; then
    log "stopping owned $name pid $pid"
    kill "$pid" 2>/dev/null || true
    sleep 2
    pid_alive "$pid" && kill -9 "$pid" 2>/dev/null || true
  fi
  rm -f "$pid_file"
}

stop_children() {
  stop_owned_process gateway "$RUN_DIR/gateway.pid"
  stop_owned_process headroom "$RUN_DIR/headroom.pid"
  stop_owned_process pxpipe "$RUN_DIR/pxpipe.pid"
  stop_owned_process squeezr "$RUN_DIR/squeezr.pid"
  safe_kill_port_owner "squeezr" "$SQUEEZR_PORT" 'squeezr|node .*squeezr|npx .*squeezr' || true
  rm -f "$RUN_DIR/gateway.adopted.pid" "$RUN_DIR/pxpipe.adopted.pid" "$RUN_DIR/headroom.adopted.pid" "$RUN_DIR/squeezr.adopted.pid"
}

stop_stale_supervisors() {
  local self pid cmd
  self="$$"
  while read -r pid cmd; do
    [[ -n "${pid:-}" ]] || continue
    [[ "$pid" == "$self" ]] && continue
    [[ "$cmd" == *"apx supervisor"* ]] || continue
    log "stopping stale supervisor pid $pid: $cmd"
    kill "$pid" 2>/dev/null || true
    sleep 1
    pid_alive "$pid" && kill -9 "$pid" 2>/dev/null || true
  done < <(ps -axo pid=,command= 2>/dev/null)
}

supervisor() {
  load_config
  echo $$ > "$RUN_DIR/supervisor.pid"
  trap 'log "supervisor stopping"; stop_children; rm -f "$RUN_DIR/supervisor.pid"; exit 0' INT TERM
  log "supervisor starting"
  while true; do
    if [[ "$PXPIPE_ENABLED" == "1" ]]; then
      start_pxpipe || log "pxpipe start/check failed"
    else
      stop_owned_process pxpipe "$RUN_DIR/pxpipe.pid"
    fi
    if [[ "$SQUEEZR_ENABLED" == "1" ]]; then
      start_squeezr || log "Squeezr start/check failed"
    else
      stop_owned_process squeezr "$RUN_DIR/squeezr.pid"
      safe_kill_port_owner "squeezr" "$SQUEEZR_PORT" 'squeezr|node .*squeezr|npx .*squeezr' || true
    fi
    if [[ "$HEADROOM_ENABLED" == "1" ]]; then
      start_headroom || log "Headroom start/check failed"
    else
      stop_owned_process headroom "$RUN_DIR/headroom.pid"
    fi
    if [[ "$GATEWAY_ENABLED" == "1" ]]; then
      start_gateway || log "Gateway start/check failed"
    else
      stop_owned_process gateway "$RUN_DIR/gateway.pid"
    fi
    sleep "$HEALTH_INTERVAL_SECONDS"
    if [[ "$PXPIPE_ENABLED" == "1" ]] && ! pxpipe_ok; then
      log "pxpipe health check failed; restarting owned process if any"
      stop_owned_process pxpipe "$RUN_DIR/pxpipe.pid"
      sleep "$RESTART_BACKOFF_SECONDS"
    fi
    if [[ "$SQUEEZR_ENABLED" == "1" ]] && ! squeezr_ok; then
      log "Squeezr health check failed; restarting owned process if any"
      stop_owned_process squeezr "$RUN_DIR/squeezr.pid"
      sleep "$RESTART_BACKOFF_SECONDS"
    fi
    if [[ "$HEADROOM_ENABLED" == "1" ]] && ! headroom_ok; then
      log "Headroom health check failed; restarting owned process if any"
      stop_owned_process headroom "$RUN_DIR/headroom.pid"
      sleep "$RESTART_BACKOFF_SECONDS"
    fi
    if [[ "$GATEWAY_ENABLED" == "1" ]] && ! gateway_ok; then
      log "Gateway health check failed; restarting owned process if any"
      stop_owned_process gateway "$RUN_DIR/gateway.pid"
      sleep "$RESTART_BACKOFF_SECONDS"
    fi
  done
}

start_bg() {
  load_config
  local takeover=0
  if [[ "${1:-}" == "--takeover" ]]; then takeover=1; fi
  local spid
  spid="$(read_pid "$RUN_DIR/supervisor.pid")"
  if pid_alive "$spid"; then
    echo "already running: supervisor pid $spid"
    return 0
  fi
  APX_TAKEOVER="$takeover" nohup "$0" supervisor >> "$LOG_DIR/supervisor.log" 2>&1 &
  echo $! > "$RUN_DIR/supervisor.pid"
  sleep 2
  status
}

launchd_domain() { printf 'gui/%s' "$(id -u)"; }

write_plist() {
  mkdir -p "$HOME/Library/LaunchAgents" "$STATE_DIR"
  cat > "$PLIST_FILE" <<EOF
<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key><string>$LABEL</string>
  <key>ProgramArguments</key>
  <array>
    <string>$HOME/.local/bin/apx</string>
    <string>supervisor</string>
  </array>
  <key>RunAtLoad</key><true/>
  <key>KeepAlive</key><true/>
  <key>WorkingDirectory</key><string>$WORKDIR</string>
  <key>StandardOutPath</key><string>$LOG_DIR/launchd.out.log</string>
  <key>StandardErrorPath</key><string>$LOG_DIR/launchd.err.log</string>
  <key>EnvironmentVariables</key>
  <dict>
    <key>PATH</key><string>$DEFAULT_PATH</string>
    <key>APX_ROOT</key><string>$STACK_ROOT</string>
    <key>APX_CONFIG</key><string>$CONFIG_FILE</string>
    <key>APX_STATE</key><string>$STATE_DIR</string>
  </dict>
</dict>
</plist>
EOF
}

install_service() {
  load_config
  write_plist
  launchctl bootout "$(launchd_domain)" "$PLIST_FILE" >/dev/null 2>&1 || true
  sleep 2
  stop_stale_supervisors
  stop_children
  launchctl bootstrap "$(launchd_domain)" "$PLIST_FILE"
  launchctl enable "$(launchd_domain)/$LABEL" >/dev/null 2>&1 || true
  launchctl kickstart -k "$(launchd_domain)/$LABEL" >/dev/null 2>&1 || true
  echo "installed and started: $PLIST_FILE"
}

stop_service() {
  launchctl bootout "$(launchd_domain)" "$PLIST_FILE" >/dev/null 2>&1 || true
  local spid
  spid="$(read_pid "$RUN_DIR/supervisor.pid")"
  pid_alive "$spid" && kill "$spid" 2>/dev/null || true
  sleep 2
  stop_stale_supervisors
  stop_children
  echo "stopped"
}

# --- uninstall / purge ------------------------------------------------------
#
# `apx uninstall` (no flags)              → stop LaunchAgent, remove plist. Everything else stays.
# `apx uninstall --purge`                 → stop service + delete binaries, share, state, config,
#                                            claude entry, completion files, and the source clone.
# `apx uninstall --purge=cat1,cat2,...`   → selectively delete listed categories.
# `apx uninstall --dry-run`               → print what would happen; change nothing.
# `apx uninstall --yes`                   → skip the interactive confirmation.
#
# Categories:
#   service     : LaunchAgent plist + running processes (implicit for any purge)
#   binaries    : ~/.local/bin/apx, apx-gateway, apx-squeezr
#   share       : ~/.local/share/apx/ (dashboard.html)
#   state       : ~/.local/state/apx/ (logs, history, run, VERSION)
#   config      : ~/.config/apx/ (config.env, prices.env, source.path)
#   claude      : remove ANTHROPIC_BASE_URL from ~/.claude/settings.json (file is preserved)
#   completions : bash/zsh/fish completion files at their canonical paths
#   source      : the git clone recorded in ~/.config/apx/source.path
#
# Never touched: ~/.headroom, ~/.squeezr, ~/.certs, ~/.cache/tiktoken, and
# everything else we don't own.

APX_ALL_PURGE_CATEGORIES=(binaries share state config claude completions source)

parse_purge_categories() {
  local input="$1"
  APX_PURGE_CATS=()
  if [[ "$input" == "1" || -z "$input" ]]; then
    APX_PURGE_CATS=("${APX_ALL_PURGE_CATEGORIES[@]}")
    return 0
  fi
  local IFS=,
  local cat
  for cat in $input; do
    cat="${cat// /}"
    [[ -z "$cat" ]] && continue
    local found=0 known
    for known in "${APX_ALL_PURGE_CATEGORIES[@]}"; do
      if [[ "$cat" == "$known" ]]; then
        APX_PURGE_CATS+=("$cat")
        found=1
        break
      fi
    done
    if (( found == 0 )); then
      echo "error: unknown purge category: $cat" >&2
      echo "valid: ${APX_ALL_PURGE_CATEGORIES[*]}" >&2
      return 2
    fi
  done
}

purge_has() {
  local target="$1" cat
  for cat in "${APX_PURGE_CATS[@]:-}"; do
    [[ "$cat" == "$target" ]] && return 0
  done
  return 1
}

purge_action() {
  local desc="$1"
  shift
  if [[ "${APX_DRY_RUN:-0}" == "1" ]]; then
    printf '[apx:uninstall] (dry-run) %s\n' "$desc"
    return 0
  fi
  printf '[apx:uninstall] %s\n' "$desc"
  "$@"
}

confirm_purge() {
  if [[ "${APX_YES:-0}" == "1" || "${APX_DRY_RUN:-0}" == "1" ]]; then
    return 0
  fi
  printf 'This will remove the following categories: %s\n' "${APX_PURGE_CATS[*]}"
  printf 'Type "yes" to proceed: '
  local reply
  read -r reply || return 1
  [[ "$reply" == "yes" ]]
}

remove_from_claude_settings() {
  [[ ! -f "$CLAUDE_SETTINGS_FILE" ]] && return 0
  python3 - "$CLAUDE_SETTINGS_FILE" <<'PY'
import json
import sys
from pathlib import Path

path = Path(sys.argv[1])
try:
    data = json.loads(path.read_text())
except json.JSONDecodeError:
    sys.exit(0)
if not isinstance(data, dict):
    sys.exit(0)
env = data.get("env")
if isinstance(env, dict) and "ANTHROPIC_BASE_URL" in env:
    env.pop("ANTHROPIC_BASE_URL", None)
    path.write_text(json.dumps(data, indent=2) + "\n")
PY
}

remove_completion_files() {
  local -a paths=(
    "$HOME/.local/share/bash-completion/completions/apx"
    "/opt/homebrew/etc/bash_completion.d/apx"
    "/usr/local/etc/bash_completion.d/apx"
    "$HOME/.config/fish/completions/apx.fish"
  )
  local zdir
  for zdir in "$HOME/.zfunc" "$HOME/.zsh/completions" "/opt/homebrew/share/zsh/site-functions" "/usr/local/share/zsh/site-functions"; do
    paths+=("$zdir/_apx")
  done
  local p
  for p in "${paths[@]}"; do
    if [[ -f "$p" ]]; then
      rm -f "$p" || true
    fi
  done
  return 0
}

source_clone_path() {
  [[ -f "$SOURCE_PATH_FILE" ]] || return 1
  local p
  p="$(head -n 1 "$SOURCE_PATH_FILE" | tr -d '[:space:]')"
  [[ -n "$p" && -d "$p/.git" ]] || return 1
  case "$p" in
    "$HOME"/*) printf '%s\n' "$p" ;;
    *) return 1 ;;
  esac
}

running_inside_dir() {
  # True if the currently executing apx binary (BASH_SOURCE[0]) lives under
  # the given directory. Used to refuse deleting the source clone we are
  # running from.
  local dir="$1" real
  real="$(python3 -c "import os,sys;print(os.path.realpath(sys.argv[1]))" "${BASH_SOURCE[0]}" 2>/dev/null)"
  [[ -n "$real" ]] || return 1
  case "$real" in
    "$dir"/*) return 0 ;;
    *) return 1 ;;
  esac
}

delete_source_clone() {
  local src="$1"
  if running_inside_dir "$src"; then
    echo "[apx:uninstall] refusing to delete source clone $src (this apx binary lives inside it)"
    echo "[apx:uninstall]   remove it manually after uninstall:  rm -rf $src"
    return 0
  fi
  rm -rf "$src"
}

do_uninstall_service_only() {
  # stop_service touches config-derived ports; the config may already be gone.
  if [[ -f "$CONFIG_FILE" ]]; then
    load_config
    stop_service
  else
    # Fall back to a best-effort launchctl bootout when config is missing.
    launchctl bootout "$(launchd_domain)" "$PLIST_FILE" >/dev/null 2>&1 || true
  fi
  purge_action "remove $PLIST_FILE" rm -f "$PLIST_FILE"
  echo "removed LaunchAgent. Config, state, and binaries were preserved."
  echo "Run 'apx uninstall --purge' to remove everything."
}

do_uninstall_purge() {
  # Always stop the service first so nothing races the deletions.
  if [[ -f "$CONFIG_FILE" ]]; then
    purge_action "stop service and remove plist" bash -c "'$0' stop >/dev/null 2>&1 || true; rm -f '$PLIST_FILE'"
  else
    purge_action "bootout LaunchAgent (config missing)" bash -c "launchctl bootout '$(launchd_domain)' '$PLIST_FILE' >/dev/null 2>&1 || true; rm -f '$PLIST_FILE'"
  fi

  if purge_has claude; then
    purge_action "remove ANTHROPIC_BASE_URL from $CLAUDE_SETTINGS_FILE" remove_from_claude_settings
  fi
  if purge_has completions; then
    purge_action "remove installed shell completion files" remove_completion_files
  fi
  if purge_has share; then
    purge_action "remove $SHARE_DIR" rm -rf "$SHARE_DIR"
  fi
  if purge_has state; then
    purge_action "remove $STATE_DIR" rm -rf "$STATE_DIR"
  fi
  if purge_has config; then
    purge_action "remove $CONFIG_DIR" rm -rf "$CONFIG_DIR"
  fi
  if purge_has source; then
    local src
    if src="$(source_clone_path)"; then
      purge_action "remove source clone $src" delete_source_clone "$src"
    fi
  fi
  if purge_has binaries; then
    # Remove the CLI last so any prior category deletions can still shell out
    # through this same script if they need to.
    purge_action "remove $HOME/.local/bin/apx*" rm -f \
      "$HOME/.local/bin/apx" \
      "$HOME/.local/bin/apx-gateway" \
      "$HOME/.local/bin/apx-squeezr"
  fi

  if [[ "${APX_DRY_RUN:-0}" != "1" ]]; then
    echo "apx uninstalled (categories: ${APX_PURGE_CATS[*]})."
    echo "Anything owned by other tools (Headroom, pxpipe, Squeezr, CA bundle, tiktoken cache) was preserved."
  fi
}

uninstall_command() {
  APX_DRY_RUN=0
  APX_YES=0
  APX_PURGE_CATS=()
  local purge_arg="" mode="service"
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --purge) mode="purge"; purge_arg="1" ;;
      --purge=*) mode="purge"; purge_arg="${1#--purge=}" ;;
      --dry-run) APX_DRY_RUN=1 ;;
      --yes|-y) APX_YES=1 ;;
      -h|--help) uninstall_usage; return 0 ;;
      *) uninstall_usage >&2; return 2 ;;
    esac
    shift
  done

  if [[ "$mode" == "service" ]]; then
    do_uninstall_service_only
    return
  fi

  if ! parse_purge_categories "$purge_arg"; then
    return 2
  fi
  if ! confirm_purge; then
    echo "aborted"
    return 1
  fi
  do_uninstall_purge
}

uninstall_usage() {
  cat <<EOF
usage: apx uninstall [--purge[=cats]] [--dry-run] [--yes]

  (no flags)              Stop the LaunchAgent and remove the plist only.
                          Binaries, config, state, and Claude settings stay.
  --purge                 Remove everything apx owns:
                            ${APX_ALL_PURGE_CATEGORIES[*]}
  --purge=cats            Remove only the listed categories (comma-separated).
                          Available: ${APX_ALL_PURGE_CATEGORIES[*]}
  --dry-run               Print planned actions; make no changes.
  --yes, -y               Skip the interactive confirmation.

Never touched: ~/.headroom, ~/.squeezr, ~/.certs, ~/.cache/tiktoken, and
everything else apx does not own.
EOF
}

set_config_var() {
  local key="$1" value="$2" tmp
  tmp="$(mktemp)"
  awk -v key="$key" -v value="$value" '
    BEGIN { done = 0 }
    $0 ~ "^" key "=" { print key "=" value; done = 1; next }
    { print }
    END { if (!done) print key "=" value }
  ' "$CONFIG_FILE" > "$tmp"
  mv "$tmp" "$CONFIG_FILE"
}

# --- chain-based routing ----------------------------------------------------
#
# The chain is an ordered comma-separated list of service names (e.g.
# "headroom,pxpipe") stored as APX_CHAIN in config.env. All ENABLED flags and
# per-service TARGET_API_URLs are derived from it. Presets in `apx mode` are
# thin sugar that compile to a chain via preset_to_chain().
#
# To add a new service in the future, extend service_port, service_label, and
# UPSTREAM_URL_FOR_SERVICE below. No mode permutations need to change.

APX_ANTHROPIC_UPSTREAM='"https://api.anthropic.com"'
APX_KNOWN_SERVICES=(headroom pxpipe squeezr)

service_port() {
  case "$1" in
    headroom) echo "$HEADROOM_PORT" ;;
    pxpipe)   echo "$PXPIPE_PORT" ;;
    squeezr)  echo "$SQUEEZR_PORT" ;;
    *) echo "" ;;
  esac
}

service_label() {
  case "$1" in
    headroom) echo "Headroom" ;;
    pxpipe)   echo "pxpipe" ;;
    squeezr)  echo "Squeezr" ;;
    *) echo "$1" ;;
  esac
}

service_url() {
  local port
  port="$(service_port "$1")"
  [[ -n "$port" ]] && echo "http://$BIND_HOST:$port"
}

service_known() {
  local candidate="$1" svc
  for svc in "${APX_KNOWN_SERVICES[@]}"; do
    [[ "$svc" == "$candidate" ]] && return 0
  done
  return 1
}

# Parse APX_CHAIN into a bash array in the current shell. Empty when the chain
# is unset or set to "direct".
parse_chain() {
  local raw="${APX_CHAIN:-}"
  raw="${raw//[[:space:]]/}"
  APX_CHAIN_ARR=()
  [[ -z "$raw" || "$raw" == "direct" ]] && return 0
  local IFS=,
  local part
  for part in $raw; do
    [[ -n "$part" ]] && APX_CHAIN_ARR+=("$part")
  done
}

# Given a chain, return its canonical preset name if one matches, else "custom".
canonical_preset_for_chain() {
  local chain="$1"
  case "$chain" in
    "")                  echo "direct" ;;
    "headroom")          echo "headroom" ;;
    "pxpipe")            echo "pxpipe" ;;
    "squeezr")           echo "squeezr" ;;
    "headroom,pxpipe")   echo "headroom-pxpipe" ;;
    "pxpipe,headroom")   echo "pxpipe-headroom" ;;
    "headroom,squeezr")  echo "headroom-squeezr" ;;
    *)                   echo "custom" ;;
  esac
}

preset_to_chain() {
  case "$1" in
    off)                     echo "" ;;
    direct)                  echo "" ;;
    headroom|no-pxpipe)      echo "headroom" ;;
    pxpipe|no-headroom)      echo "pxpipe" ;;
    squeezr|squeezr-only)    echo "squeezr" ;;
    headroom-pxpipe|full)    echo "headroom,pxpipe" ;;
    pxpipe-headroom|pxpipe-then-headroom) echo "pxpipe,headroom" ;;
    headroom-squeezr|squeezr-headroom)    echo "headroom,squeezr" ;;
    *) return 2 ;;
  esac
}

current_mode() {
  if [[ "$GATEWAY_ENABLED" != "1" ]]; then
    echo "off"
    return
  fi
  parse_chain
  local joined
  joined="$(IFS=,; echo "${APX_CHAIN_ARR[*]:-}")"
  canonical_preset_for_chain "$joined"
}

chain_description() {
  if [[ "$GATEWAY_ENABLED" != "1" ]]; then
    echo "disabled (ANTHROPIC_BASE_URL removed)"
    return
  fi
  parse_chain
  local parts=("Claude" "Gateway($BIND_HOST:$GATEWAY_PORT)") svc
  if (( ${#APX_CHAIN_ARR[@]} > 0 )); then
    for svc in "${APX_CHAIN_ARR[@]}"; do
      parts+=("$(service_label "$svc")($BIND_HOST:$(service_port "$svc"))")
    done
  fi
  parts+=("upstream")
  local joined="" p
  for p in "${parts[@]}"; do
    if [[ -z "$joined" ]]; then joined="$p"; else joined="$joined -> $p"; fi
  done
  echo "$joined"
}

# Write APX_CHAIN plus derived ENABLED flags and TARGET_API_URLs from the
# supplied chain string. The chain is a comma-separated ordered list; empty
# means "direct to upstream".
apply_chain() {
  local chain="$1" gateway_enabled="${2:-1}"
  chain="${chain//[[:space:]]/}"

  if [[ -n "$chain" ]]; then
    local IFS=, part
    for part in $chain; do
      if ! service_known "$part"; then
        echo "error: unknown service in chain: $part" >&2
        echo "known services: ${APX_KNOWN_SERVICES[*]}" >&2
        return 2
      fi
    done
  fi

  set_config_var APX_CHAIN "\"$chain\""
  set_config_var GATEWAY_ENABLED "$gateway_enabled"

  local svc enabled_val gateway_target="$APX_ANTHROPIC_UPSTREAM"
  local -a chain_arr=()
  if [[ -n "$chain" ]]; then
    IFS=, read -r -a chain_arr <<<"$chain"
    gateway_target="\"$(service_url "${chain_arr[0]}")\""
  fi

  for svc in "${APX_KNOWN_SERVICES[@]}"; do
    enabled_val=0
    local idx=-1 i=0
    for i in "${!chain_arr[@]}"; do
      if [[ "${chain_arr[$i]}" == "$svc" ]]; then
        idx=$i
        enabled_val=1
        break
      fi
    done
    local target="$APX_ANTHROPIC_UPSTREAM"
    if (( idx >= 0 )) && (( idx + 1 < ${#chain_arr[@]} )); then
      target="\"$(service_url "${chain_arr[$((idx + 1))]}")\""
    fi
    case "$svc" in
      headroom) set_config_var HEADROOM_ENABLED "$enabled_val"; set_config_var HEADROOM_TARGET_API_URL "$target" ;;
      pxpipe)   set_config_var PXPIPE_ENABLED   "$enabled_val"; set_config_var PXPIPE_TARGET_API_URL   "$target" ;;
      squeezr)  set_config_var SQUEEZR_ENABLED  "$enabled_val" ;;
    esac
  done

  set_config_var GATEWAY_TARGET_API_URL "$gateway_target"
}

mode_hint() {
  if [[ "$(current_mode)" == "off" ]]; then
    echo "Claude Code base URL: unset ANTHROPIC_BASE_URL"
  else
    echo "Claude Code base URL: http://host.docker.internal:$GATEWAY_PORT"
  fi
}

claude_base_url_for_mode() {
  if [[ "$(current_mode)" == "off" ]]; then
    echo ""
  else
    echo "http://host.docker.internal:$GATEWAY_PORT"
  fi
}

sync_claude_settings() {
  load_config
  local mode base_url
  mode="$(current_mode)"
  base_url="$(claude_base_url_for_mode)"
  if [[ ! -f "$CLAUDE_SETTINGS_FILE" ]]; then
    mkdir -p "$(dirname "$CLAUDE_SETTINGS_FILE")"
    printf '{\n  "env": {}\n}\n' > "$CLAUDE_SETTINGS_FILE"
  fi
  python3 - "$CLAUDE_SETTINGS_FILE" "$base_url" <<'PY'
import json
import sys
from pathlib import Path

path = Path(sys.argv[1])
base_url = sys.argv[2]

try:
    data = json.loads(path.read_text())
except json.JSONDecodeError as exc:
    raise SystemExit(f"invalid JSON in {path}: {exc}")

if not isinstance(data, dict):
    raise SystemExit(f"{path} must contain a JSON object")

env = data.setdefault("env", {})
if not isinstance(env, dict):
    raise SystemExit(f"{path} env must be a JSON object")

if base_url:
    env["ANTHROPIC_BASE_URL"] = base_url
else:
    env.pop("ANTHROPIC_BASE_URL", None)

path.write_text(json.dumps(data, indent=2) + "\n")
PY
  if [[ -n "$base_url" ]]; then
    echo "Claude settings: ANTHROPIC_BASE_URL=$base_url"
  else
    echo "Claude settings: ANTHROPIC_BASE_URL removed"
  fi
  echo "Claude settings file: $CLAUDE_SETTINGS_FILE"
  echo "Restart Claude Code for settings changes to take effect."
}


disable_stack() {
  load_config
  apply_chain "" 0
  load_config
  echo "mode set: $(current_mode)"
  echo "chain: $(chain_description)"
  mode_hint
  sync_claude_settings
  stop_service
  status
}

apply_mode_common() {
  local sync_claude="$1" restart="$2"
  load_config
  echo "mode set: $(current_mode)"
  echo "chain: $(chain_description)"
  mode_hint
  if [[ "$sync_claude" == "1" ]]; then
    sync_claude_settings
  fi
  if [[ "$restart" == "1" ]]; then
    APX_TAKEOVER=1 install_service
    sleep 5
    status
  else
    echo "not restarted; run: apx install"
  fi
}

set_mode() {
  local mode="${1:-}" restart="1" sync_claude="1"
  shift || true
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --no-restart) restart="0" ;;
      --no-claude-sync) sync_claude="0" ;;
      *) mode_usage >&2; return 2 ;;
    esac
    shift
  done
  load_config

  case "$mode" in
    current|status|"")
      echo "mode: $(current_mode)"
      echo "chain: $(chain_description)"
      mode_hint
      return 0
      ;;
    off)
      apply_chain "" 0
      apply_mode_common "$sync_claude" "$restart"
      return
      ;;
  esac

  local chain
  if ! chain="$(preset_to_chain "$mode")"; then
    mode_usage >&2
    return 2
  fi
  apply_chain "$chain" 1
  apply_mode_common "$sync_claude" "$restart"
}

mode_usage() {
  cat <<EOF
usage: apx mode <preset> [--no-restart] [--no-claude-sync]

Presets:
  headroom-pxpipe    Claude -> Gateway -> Headroom -> pxpipe -> Anthropic (alias: full)
  pxpipe-headroom    Claude -> Gateway -> pxpipe -> Headroom -> Anthropic
  headroom           Claude -> Gateway -> Headroom -> Anthropic
  pxpipe             Claude -> Gateway -> pxpipe -> Anthropic
  squeezr            Claude -> Gateway -> Squeezr -> Anthropic
  headroom-squeezr   Claude -> Gateway -> Headroom -> Squeezr -> Anthropic
  direct             Claude -> Gateway -> Anthropic (no upstream tools)
  off                Gateway disabled; ANTHROPIC_BASE_URL removed
  current            Show the current mode without changing anything

For arbitrary orderings use: apx chain set <a,b,...>
EOF
}

chain_usage() {
  cat <<EOF
usage: apx chain <subcommand>

  get                       Show APX_CHAIN and derived Gateway routing
  set <a,b,...>             Set the chain to an ordered list of services
  clear                     Alias for 'set ""' (equivalent to mode direct)
  ls                        List services known to apx
  preset ls                 List preset chains
  preset use <name>         Apply a preset chain

Known services: ${APX_KNOWN_SERVICES[*]}
Presets: headroom-pxpipe, pxpipe-headroom, headroom, pxpipe, squeezr,
         headroom-squeezr, direct, off
EOF
}

chain_cli() {
  local sub="${1:-}"
  shift || true
  local restart="1" sync_claude="1"
  local -a positional=()
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --no-restart) restart="0" ;;
      --no-claude-sync) sync_claude="0" ;;
      *) positional+=("$1") ;;
    esac
    shift
  done
  load_config
  case "$sub" in
    ""|get|show|status)
      local displayed="${APX_CHAIN-}"
      if [[ -z "${APX_CHAIN+set}" ]]; then
        displayed="<unset>"
      elif [[ -z "$displayed" ]]; then
        displayed="(empty; direct to upstream)"
      fi
      echo "chain: $displayed"
      echo "mode:  $(current_mode)"
      echo "hops:  $(chain_description)"
      mode_hint
      ;;
    set)
      local target="${positional[0]:-}"
      if [[ -z "$target" ]]; then
        echo "usage: apx chain set <a,b,...>" >&2
        return 2
      fi
      apply_chain "$target" 1
      apply_mode_common "$sync_claude" "$restart"
      ;;
    clear)
      apply_chain "" 1
      apply_mode_common "$sync_claude" "$restart"
      ;;
    ls|list)
      printf '%s\n' "${APX_KNOWN_SERVICES[@]}"
      ;;
    preset)
      case "${positional[0]:-}" in
        ""|ls|list)
          for name in headroom-pxpipe pxpipe-headroom headroom pxpipe squeezr headroom-squeezr direct off; do
            printf '  %-18s %s\n' "$name" "$(preset_to_chain "$name" || echo "")"
          done
          ;;
        use)
          set_mode "${positional[1]:-}" ${restart:+$( ((restart==0)) && echo --no-restart )} ${sync_claude:+$( ((sync_claude==0)) && echo --no-claude-sync )}
          ;;
        *) chain_usage >&2; return 2 ;;
      esac
      ;;
    -h|--help|help) chain_usage ;;
    *) chain_usage >&2; return 2 ;;
  esac
}

status() {
  load_config
  local spid gpid ppid hpid sqpid gport pport hport sqport sstate ghealth phealth hhealth sqhealth
  spid="$(read_pid "$RUN_DIR/supervisor.pid")"
  gpid="$(read_pid "$RUN_DIR/gateway.pid")"
  ppid="$(read_pid "$RUN_DIR/pxpipe.pid")"
  hpid="$(read_pid "$RUN_DIR/headroom.pid")"
  sqpid="$(read_pid "$RUN_DIR/squeezr.pid")"
  gport="$(port_pid "$GATEWAY_PORT")"
  pport="$(port_pid "$PXPIPE_PORT")"
  hport="$(port_pid "$HEADROOM_PORT")"
  sqport="$(port_pid "$SQUEEZR_PORT")"
  if pid_alive "$spid"; then sstate="running"; else sstate="stopped"; fi
  if [[ "$GATEWAY_ENABLED" == "1" ]]; then
    if gateway_ok; then ghealth="ok"; else ghealth="fail"; fi
  else
    ghealth="disabled"
  fi
  if [[ "$PXPIPE_ENABLED" == "1" ]]; then
    if pxpipe_ok; then phealth="ok"; else phealth="fail"; fi
  else
    phealth="disabled"
  fi
  if [[ "$HEADROOM_ENABLED" == "1" ]]; then
    if headroom_ok; then hhealth="ok"; else hhealth="fail"; fi
  else
    hhealth="disabled"
  fi
  if [[ "$SQUEEZR_ENABLED" == "1" ]]; then
    if squeezr_ok; then sqhealth="ok"; else sqhealth="fail"; fi
  else
    sqhealth="disabled"
  fi
  echo "version: $(read_installed_version)"
  echo "config: $CONFIG_FILE"
  echo "mode: $(current_mode)"
  echo "chain: $(chain_description)"
  echo "supervisor: ${spid:-none} $sstate"
  echo "Gateway:   pidfile=${gpid:-none} listener=${gport:-none} health=$ghealth"
  echo "pxpipe:    pidfile=${ppid:-none} listener=${pport:-none} health=$phealth"
  if [[ "$PXPIPE_ENABLED" == "1" ]]; then
    echo "pxpipe models: $PXPIPE_MODELS"
  fi
  echo "Headroom:  pidfile=${hpid:-none} listener=${hport:-none} health=$hhealth"
  echo "Squeezr:   pidfile=${sqpid:-none} listener=${sqport:-none} health=$sqhealth"
  if [[ "$SQUEEZR_ENABLED" == "1" ]]; then
    echo "Squeezr dashboard: http://$BIND_HOST:$SQUEEZR_PORT/squeezr/dashboard"
  fi
  echo "logs: $LOG_DIR"
}

doctor() {
  status
  echo
  echo "commands:"
  command -v node || true
  command -v npx || true
  command -v headroom || true
  command -v squeezr || true
  command -v python3 || true
  command -v ast-grep || true
  command -v sg || true
  echo
  echo "Headroom doctor:"
  headroom doctor || true
}

show_logs() {
  local file="${1:-supervisor}"
  local headroom_proxy_log="${HEADROOM_LOG_FILE:-$HOME/.headroom/logs/proxy.log}"
  case "$file" in
    all)
      log_files=()
      for name in supervisor gateway headroom pxpipe squeezr launchd.out launchd.err; do
        path="$LOG_DIR/$name.log"
        [[ -f "$path" ]] || : > "$path"
        log_files+=("$path")
      done
      mkdir -p "$(dirname "$headroom_proxy_log")"
      [[ -f "$headroom_proxy_log" ]] || : > "$headroom_proxy_log"
      log_files+=("$headroom_proxy_log")
      tail -n 40 -F "${log_files[@]}"
      ;;
    headroom)
      [[ -f "$LOG_DIR/headroom.log" ]] || : > "$LOG_DIR/headroom.log"
      mkdir -p "$(dirname "$headroom_proxy_log")"
      [[ -f "$headroom_proxy_log" ]] || : > "$headroom_proxy_log"
      tail -n 80 -F "$LOG_DIR/headroom.log" "$headroom_proxy_log"
      ;;
    headroom.stdout)
      [[ -f "$LOG_DIR/headroom.log" ]] || : > "$LOG_DIR/headroom.log"
      tail -n 80 -F "$LOG_DIR/headroom.log"
      ;;
    headroom.proxy)
      mkdir -p "$(dirname "$headroom_proxy_log")"
      [[ -f "$headroom_proxy_log" ]] || : > "$headroom_proxy_log"
      tail -n 80 -F "$headroom_proxy_log"
      ;;
    supervisor|gateway|pxpipe|squeezr|launchd.out|launchd.err)
      [[ -f "$LOG_DIR/$file.log" ]] || : > "$LOG_DIR/$file.log"
      tail -n 80 -F "$LOG_DIR/$file.log"
      ;;
    *)
      echo "usage: $0 logs [all|supervisor|gateway|pxpipe|squeezr|headroom|headroom.stdout|headroom.proxy|launchd.out|launchd.err]" >&2
      exit 2
      ;;
  esac
}

dashboard_urls() {
  load_config
  echo "pxpipe dashboard: http://$BIND_HOST:$PXPIPE_PORT/"
  echo "Gateway health:   http://$BIND_HOST:$GATEWAY_PORT/livez"
  echo "Headroom health:  http://$BIND_HOST:$HEADROOM_PORT/livez"
  echo "Headroom stats:   http://$BIND_HOST:$HEADROOM_PORT/stats"
  echo "Squeezr health:   http://$BIND_HOST:$SQUEEZR_PORT/squeezr/health"
  echo "Squeezr dashboard:http://$BIND_HOST:$SQUEEZR_PORT/squeezr/dashboard"
}

open_dashboard() {
  load_config
  dashboard_urls
  if [[ "${1:-}" == "--open" ]]; then
    open "http://$BIND_HOST:$GATEWAY_PORT/livez" >/dev/null 2>&1 || true
  fi
}

read_installed_version() {
  if [[ -f "$VERSION_FILE" ]]; then
    head -n 1 "$VERSION_FILE" | tr -d '[:space:]'
  else
    echo "unknown"
  fi
}

read_source_repo() {
  if [[ -f "$SOURCE_PATH_FILE" ]]; then
    head -n 1 "$SOURCE_PATH_FILE" | tr -d '[:space:]'
  else
    echo ""
  fi
}

remote_version() {
  local url="$UPDATE_REPO_URL"
  local branch="$UPDATE_REPO_BRANCH"
  local tmp
  tmp="$(mktemp -d)"
  local ver="unknown"
  if command -v curl >/dev/null 2>&1; then
    local raw_url="${url%.git}"
    raw_url="${raw_url/github.com/raw.githubusercontent.com}/$branch/VERSION"
    local fetched
    fetched="$(curl -fsSL --max-time 10 "$raw_url" 2>/dev/null | head -n 1 | tr -d '[:space:]' || true)"
    if [[ -n "$fetched" ]]; then
      ver="$fetched"
    fi
  fi
  rm -rf "$tmp"
  echo "$ver"
}

show_version() {
  local installed local_repo local_ver
  installed="$(read_installed_version)"
  local_repo="$(read_source_repo)"
  echo "installed version: $installed"
  if [[ -n "$local_repo" && -d "$local_repo/.git" ]]; then
    local_ver="$(git -C "$local_repo" describe --tags --always --dirty 2>/dev/null || echo unknown)"
    echo "source repo:       $local_repo"
    echo "source git rev:    $local_ver"
  else
    echo "source repo:       (unknown; set via reinstall from a git clone)"
  fi
  echo "update channel:    $UPDATE_REPO_URL ($UPDATE_REPO_BRANCH)"
}

check_updates() {
  local installed remote
  installed="$(read_installed_version)"
  echo "installed version: $installed"
  remote="$(remote_version)"
  echo "latest version:    $remote"
  if [[ "$installed" == "$remote" || "$remote" == "unknown" ]]; then
    echo "status: up to date"
  else
    echo "status: update available"
    echo "run: apx update"
  fi
}

do_update() {
  local repo installer force=0 target_ref="" dry_run=0
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --force) force=1 ;;
      --to) shift; target_ref="${1:-}" ;;
      --to=*) target_ref="${1#--to=}" ;;
      --to-latest) target_ref="$UPDATE_REPO_BRANCH" ;;
      --dry-run) dry_run=1 ;;
      -h|--help)
        cat <<EOF
Usage: apx update [--to <ref>|--to-latest] [--force] [--dry-run]

  --to <ref>    Check out a branch, tag, or SHA before reinstalling.
  --to-latest   Alias for --to $UPDATE_REPO_BRANCH.
  --force       git reset --hard the source clone before pulling; discards
                any local changes made inside the source repo.
  --dry-run     Fetch and show what would change; do not modify anything.
EOF
        return 0
        ;;
      *) echo "unknown option: $1" >&2; return 2 ;;
    esac
    shift
  done
  repo="$(read_source_repo)"
  if [[ -z "$repo" ]]; then
    cat >&2 <<EOF
error: no recorded source repo path.

Options:
  1. Run install.sh again from a fresh clone:
       git clone $UPDATE_REPO_URL /tmp/apx-update
       cd /tmp/apx-update
       ./install.sh --yes
  2. Point the CLI at a clone once, then rerun update:
       echo /path/to/apx-source > "$SOURCE_PATH_FILE"
EOF
    return 1
  fi
  if [[ ! -d "$repo/.git" ]]; then
    echo "error: recorded source path is not a git repo: $repo" >&2
    return 1
  fi
  installer="$repo/install.sh"
  if [[ ! -x "$installer" ]]; then
    echo "error: installer not found or not executable: $installer" >&2
    return 1
  fi

  local dirty detached current_ref
  dirty="$(git -C "$repo" status --porcelain 2>/dev/null || true)"
  if [[ -n "$dirty" ]]; then
    if [[ "$force" != "1" ]]; then
      cat >&2 <<EOF
error: local changes in source clone: $repo
Run one of:
  cd $repo && git status
  apx update --force            # git reset --hard, discards local edits
EOF
      return 1
    fi
    echo "resetting local changes in $repo (--force)"
    ( cd "$repo" && git reset --hard HEAD && git clean -fd )
  fi

  if ! current_ref="$(git -C "$repo" symbolic-ref -q --short HEAD)"; then
    detached=1
    current_ref="$(git -C "$repo" rev-parse --short HEAD)"
  else
    detached=0
  fi

  echo "updating from $repo (currently on ${detached:+detached }$current_ref)"
  ( cd "$repo" && git fetch --tags --prune origin )

  local pre_version post_version
  pre_version="$(cat "$VERSION_FILE" 2>/dev/null || echo unknown)"

  if [[ "$dry_run" == "1" ]]; then
    echo "=== dry-run: git changes ==="
    if [[ -n "$target_ref" ]]; then
      ( cd "$repo" && git log --oneline "HEAD..$target_ref" 2>/dev/null || echo "(no visible commits between HEAD and $target_ref)" )
    else
      ( cd "$repo" && git log --oneline "HEAD..origin/$current_ref" 2>/dev/null || echo "(source clone is up to date or on a detached ref)" )
    fi
    echo
    echo "=== dry-run: installer check-only ==="
    "$installer" --check-only
    return 0
  fi

  if [[ -n "$target_ref" ]]; then
    echo "checking out $target_ref"
    ( cd "$repo" && git checkout "$target_ref" && git pull --ff-only origin "$target_ref" 2>/dev/null || true )
  elif [[ "$detached" == "1" ]]; then
    cat >&2 <<EOF
warning: source clone is on detached HEAD ($current_ref).
apx will reinstall from this ref without pulling. To advance:
  apx update --to $UPDATE_REPO_BRANCH   # latest on default branch
  apx update --to v0.2.0                # specific release tag
EOF
  else
    ( cd "$repo" && git pull --ff-only origin "$current_ref" )
  fi

  "$installer" --yes

  post_version="$(cat "$VERSION_FILE" 2>/dev/null || echo unknown)"
  echo
  echo "=== apx update summary ==="
  echo "  version:      $pre_version -> $post_version"
  echo "  source:       $repo"
  echo "  config:       $CONFIG_FILE"
  echo "  restart:      done (LaunchAgent reloaded)"
  if command -v apx >/dev/null 2>&1; then
    # Warn if any installed completion file is older than the CLI binary.
    local cli_time f stale=0
    cli_time="$(stat -f %m "$HOME/.local/bin/apx" 2>/dev/null || echo 0)"
    for f in \
      "$HOME/.local/share/bash-completion/completions/apx" \
      "$HOME/.zfunc/_apx" \
      "$HOME/.config/fish/completions/apx.fish"; do
      if [[ -f "$f" ]]; then
        local ft
        ft="$(stat -f %m "$f" 2>/dev/null || echo 0)"
        if (( ft < cli_time )); then stale=1; fi
      fi
    done
    if (( stale == 1 )); then
      echo "  completions:  stale detected. Re-run: apx completions install"
    fi
  fi
}

print_completions() {
  local shell="${1:-}"
  local cmds="start stop disable restart status mode chain doctor install uninstall supervisor logs urls dashboard version check-updates update completions help"
  local modes="current headroom-pxpipe pxpipe-headroom headroom squeezr headroom-squeezr pxpipe direct off full"
  local chain_subs="get set clear ls preset help"
  local services="headroom pxpipe squeezr"
  local log_targets="all supervisor gateway pxpipe squeezr headroom headroom.stdout headroom.proxy launchd.out launchd.err"
  case "$shell" in
    bash)
      cat <<BASH
# apx bash completion. Install with:
#   apx completions bash > ~/.local/share/bash-completion/completions/apx
_apx_completions() {
  local cur prev words cword
  _get_comp_words_by_ref -n : cur prev words cword 2>/dev/null || {
    cur="\${COMP_WORDS[COMP_CWORD]}"
    prev="\${COMP_WORDS[COMP_CWORD-1]}"
  }
  if [[ "\$cword" -le 1 ]]; then
    COMPREPLY=( \$(compgen -W "$cmds" -- "\$cur") )
    return
  fi
  case "\${words[1]}" in
    mode)     COMPREPLY=( \$(compgen -W "$modes" -- "\$cur") ) ;;
    chain)    COMPREPLY=( \$(compgen -W "$chain_subs $services" -- "\$cur") ) ;;
    logs)     COMPREPLY=( \$(compgen -W "$log_targets" -- "\$cur") ) ;;
    completions) COMPREPLY=( \$(compgen -W "bash zsh fish install uninstall" -- "\$cur") ) ;;
    uninstall) COMPREPLY=( \$(compgen -W "--purge --dry-run --yes" -- "\$cur") ) ;;
    update)   COMPREPLY=( \$(compgen -W "--to --to-latest --force --dry-run" -- "\$cur") ) ;;
  esac
}
complete -F _apx_completions apx
BASH
      ;;
    zsh)
      cat <<'ZSH'
# apx zsh completion. Install with:
#   apx completions zsh > "${fpath[1]}/_apx"
# or source it directly in ~/.zshrc.
#compdef apx
_apx() {
  local -a cmds modes log_targets
ZSH
      printf '  cmds=(%s)\n' "$cmds"
      printf '  modes=(%s)\n' "$modes"
      printf '  chain_subs=(%s)\n' "$chain_subs"
      printf '  services=(%s)\n' "$services"
      printf '  log_targets=(%s)\n' "$log_targets"
      cat <<'ZSH'
  if (( CURRENT == 2 )); then
    _describe -t commands 'apx command' cmds
    return
  fi
  case "$words[2]" in
    mode) _describe -t modes 'apx mode' modes ;;
    chain) _describe -t chain 'apx chain' chain_subs && _describe -t services 'services' services ;;
    logs) _describe -t logs 'apx log target' log_targets ;;
    completions) _values 'action' 'bash' 'zsh' 'fish' 'install' 'uninstall' ;;
    uninstall) _values 'flag' '--purge' '--dry-run' '--yes' ;;
    update) _values 'flag' '--to[git ref]' '--to-latest' '--force' '--dry-run' ;;
  esac
}
_apx "$@"
ZSH
      ;;
    fish)
      cat <<FISH
# apx fish completion. Install with:
#   apx completions fish > ~/.config/fish/completions/apx.fish
complete -c apx -f
FISH
      for c in $cmds; do
        printf 'complete -c apx -n "__fish_use_subcommand" -a "%s"\n' "$c"
      done
      for m in $modes; do
        printf 'complete -c apx -n "__fish_seen_subcommand_from mode" -a "%s"\n' "$m"
      done
      for c in $chain_subs; do
        printf 'complete -c apx -n "__fish_seen_subcommand_from chain" -a "%s"\n' "$c"
      done
      for s in $services; do
        printf 'complete -c apx -n "__fish_seen_subcommand_from chain" -a "%s"\n' "$s"
      done
      for l in $log_targets; do
        printf 'complete -c apx -n "__fish_seen_subcommand_from logs" -a "%s"\n' "$l"
      done
      cat <<'FISH'
complete -c apx -n "__fish_seen_subcommand_from completions" -a "bash zsh fish install uninstall"
complete -c apx -n "__fish_seen_subcommand_from uninstall" -l purge -l dry-run -l yes
complete -c apx -n "__fish_seen_subcommand_from update" -l to -l to-latest -l force -l dry-run
FISH
      ;;
    *)
      cat >&2 <<EOF
Usage: apx completions <shell>|install|uninstall [--shell SHELL]

Emit or install shell completion scripts.

  apx completions bash > file        Print bash completion script
  apx completions zsh > file         Print zsh completion script
  apx completions fish > file        Print fish completion script
  apx completions install [--shell]  Detect current shell and install
  apx completions uninstall          Remove installed completion files
EOF
      return 2
      ;;
  esac
}

detect_shell() {
  local s="${APX_COMPLETION_SHELL:-}"
  if [[ -n "$s" ]]; then
    printf '%s\n' "$s"
    return
  fi
  # $SHELL is set by login; fall back to parent process comm for exotic setups.
  s="$(basename "${SHELL:-}")"
  case "$s" in
    bash|zsh|fish) printf '%s\n' "$s" ;;
    *) printf '%s\n' "" ;;
  esac
}

completion_target_path() {
  case "$1" in
    bash) printf '%s\n' "$HOME/.local/share/bash-completion/completions/apx" ;;
    zsh)
      # Prefer a user-writable fpath dir. Falls back to ~/.zfunc, which the
      # user needs to add to fpath in .zshrc.
      local dir="$HOME/.zfunc"
      if [[ -w "/opt/homebrew/share/zsh/site-functions" ]]; then
        dir="/opt/homebrew/share/zsh/site-functions"
      elif [[ -w "/usr/local/share/zsh/site-functions" ]]; then
        dir="/usr/local/share/zsh/site-functions"
      fi
      printf '%s/_apx\n' "$dir"
      ;;
    fish) printf '%s\n' "$HOME/.config/fish/completions/apx.fish" ;;
    *) return 1 ;;
  esac
}

install_completion_for_shell() {
  local shell="$1" dst
  if ! dst="$(completion_target_path "$shell")"; then
    echo "unknown shell: $shell" >&2
    return 2
  fi
  mkdir -p "$(dirname "$dst")"
  print_completions "$shell" > "$dst"
  echo "installed $shell completions: $dst"
  case "$shell" in
    zsh)
      case "$dst" in
        "$HOME/.zfunc/"*)
          echo "note: add these lines to ~/.zshrc if they are not already there:"
          echo "  fpath=($HOME/.zfunc \$fpath)"
          echo "  autoload -Uz compinit && compinit"
          ;;
      esac
      ;;
    bash)
      echo "note: ensure your ~/.bashrc sources bash-completion, e.g.:"
      echo "  [[ -r /opt/homebrew/etc/profile.d/bash_completion.sh ]] && source /opt/homebrew/etc/profile.d/bash_completion.sh"
      ;;
  esac
}

completions_command() {
  local sub="${1:-}"
  case "$sub" in
    install)
      shift
      local shell=""
      while [[ $# -gt 0 ]]; do
        case "$1" in
          --shell) shift; shell="${1:-}" ;;
          --shell=*) shell="${1#--shell=}" ;;
          *) echo "unknown option: $1" >&2; return 2 ;;
        esac
        shift
      done
      if [[ -z "$shell" ]]; then
        shell="$(detect_shell)"
      fi
      if [[ -z "$shell" ]]; then
        echo "error: could not detect shell. Pass --shell bash|zsh|fish." >&2
        return 2
      fi
      install_completion_for_shell "$shell"
      ;;
    uninstall)
      # This is a subset of `apx uninstall --purge=completions --yes`; we
      # keep it as a friendly alias.
      APX_PURGE_CATS=(completions) APX_DRY_RUN=0 APX_YES=1 remove_completion_files
      echo "removed installed apx completion files"
      ;;
    bash|zsh|fish)
      print_completions "$sub"
      ;;
    -h|--help|"")
      print_completions ""  # prints usage to stderr
      ;;
    *)
      print_completions "$sub"
      ;;
  esac
}

usage() {
  cat <<EOF
Usage: apx <command>

Commands:
  start [--takeover]   Start supervisor in the background
  stop                 Stop launchd service/supervisor and owned children
  disable              Stop stack/gateway and remove ANTHROPIC_BASE_URL
  restart [--takeover] Stop then start
  status               Show current health and pids
  mode [preset]        Show/set mode preset and sync Claude settings
  chain <sub>          Get/set the routing chain (get|set|clear|ls|preset)
  doctor               Show status plus dependency diagnostics
  install              Install/start macOS LaunchAgent with KeepAlive
  uninstall [--purge]  Stop and remove LaunchAgent; --purge also removes files
  supervisor           Internal foreground supervisor for launchd
  logs [name]          Follow logs: all, supervisor, gateway, pxpipe, squeezr, headroom, headroom.proxy, launchd.*
  urls                 Print dashboard, health, and stats URLs
  dashboard [--open]   Print URLs; with --open, open the pxpipe dashboard
  version              Print installed and source-repo version
  check-updates        Compare installed version against origin/main
  update [--to REF]    git pull the recorded source repo and reinstall
                       (--dry-run to preview; --to REF to change branch/tag)
  completions <sub>    Print or install shell completions (bash|zsh|fish|install|uninstall)

Mode presets:
  headroom-pxpipe      Claude -> Headroom -> pxpipe -> Anthropic (alias: full)
  pxpipe-headroom      Claude -> pxpipe -> Headroom -> Anthropic
  headroom             Claude -> Headroom -> Anthropic directly
  squeezr              Claude -> Squeezr -> Anthropic directly
  headroom-squeezr     Claude -> Headroom -> Squeezr -> Anthropic
  pxpipe               Claude -> pxpipe -> upstream
  direct               Gateway pass-through to Anthropic
  off                  Disable local services in config

For arbitrary orderings:
  apx chain set headroom,pxpipe
  apx chain set squeezr
  apx chain clear

Options:
  --no-restart         Do not restart the LaunchAgent after mode/chain change
  --no-claude-sync     Do not update ~/.claude/settings.json

Config: $CONFIG_FILE
EOF
}

cmd="${1:-status}"
shift || true
case "$cmd" in
  supervisor) supervisor ;;
  start) start_bg "${1:-}" ;;
  stop) stop_service ;;
  disable) disable_stack ;;
  restart) stop_service; start_bg "${1:-}" ;;
  status) status ;;
  mode) set_mode "${@:-current}" ;;
  chain) chain_cli "$@" ;;
  doctor) doctor ;;
  install) install_service ;;
  uninstall) uninstall_command "$@" ;;
  logs) show_logs "${1:-supervisor}" ;;
  urls) dashboard_urls ;;
  dashboard) open_dashboard "${1:-}" ;;
  version|--version|-V) show_version ;;
  check-updates|check-update) check_updates ;;
  update|upgrade) do_update "$@" ;;
  completions) completions_command "$@" ;;
  help|-h|--help) usage ;;
  *) usage >&2; exit 2 ;;
esac
