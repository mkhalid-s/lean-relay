# apx configuration.
#
# Routing model:
#   APX_CHAIN is the authoritative ordered list of local services between the
#   gateway and the upstream (Anthropic). All *_ENABLED flags and
#   *_TARGET_API_URL values below are derived from it and rewritten by
#   `apx mode` and `apx chain`. Do not hand-edit those flags; use:
#
#     apx mode headroom-pxpipe
#     apx chain set headroom,pxpipe
#     apx chain clear                 # equivalent to `apx mode direct`
#
# From a devcontainer, point Claude Code at:
#   http://host.docker.internal:${GATEWAY_PORT}

BIND_HOST=127.0.0.1
GATEWAY_PORT=8787
PXPIPE_PORT=47821
HEADROOM_PORT=8788
SQUEEZR_PORT=18780
SQUEEZR_MITM_PORT=18781
GATEWAY_ENABLED=1
# Ordered chain of local services; comma-separated, empty means direct-to-upstream.
APX_CHAIN="headroom"
HEADROOM_ENABLED=1
PXPIPE_ENABLED=0
SQUEEZR_ENABLED=0

# LaunchAgent-safe working directory. Keep this outside protected repo paths.
WORKDIR="${HOME}"

# Commands. The wrapper supplies PATH for launchd and normal shells.
GATEWAY_CMD="$HOME/.local/bin/apx-gateway"
SQUEEZR_CMD="$HOME/.local/bin/apx-squeezr"
PXPIPE_CMD="npx -y pxpipe-proxy@0.8.0"
# Persistent pxpipe image-compression allowlist. Dashboard model chips are runtime-only.
PXPIPE_MODELS="claude-fable-5,claude-opus-4-8,claude-opus-4-7,claude-sonnet-5,claude-sonnet-4-6,gpt-5.6,gpt-5.5"
HEADROOM_CMD="headroom proxy"
PXPIPE_TARGET_API_URL="https://api.anthropic.com"
HEADROOM_TARGET_API_URL="https://api.anthropic.com"
GATEWAY_TARGET_API_URL="http://127.0.0.1:8788"

# Headroom behavior.
HEADROOM_MODE=token
HEADROOM_ENABLE_TOOL_SEARCH=true
HEADROOM_CODE_AWARE_ENABLED=1
HEADROOM_CODE_GRAPH=0
HEADROOM_NO_RATE_LIMIT=1
HEADROOM_NO_SUBSCRIPTION_TRACKING=1
HEADROOM_NO_TELEMETRY=1
# Keeps cert verification on, but relaxes OpenSSL's strict CA extension check for corporate/local CA bundles.
HEADROOM_TLS_STRICT=0
# Optional CA bundle used by launchd-started Python/Node tools. Leave empty if not needed.
CA_BUNDLE_FILE="${HOME}/.certs/ca-bundle.pem"
# Stable cache for tiktoken encoder files; avoids launchd/temp-dir cache misses.
TIKTOKEN_CACHE_DIR="${HOME}/.cache/tiktoken"

# Supervisor behavior.
HEALTH_INTERVAL_SECONDS=10
STARTUP_TIMEOUT_SECONDS=45
RESTART_BACKOFF_SECONDS=3
ADOPT_EXISTING=1

# Optional extra args, appended verbatim.
PXPIPE_EXTRA_ARGS=
HEADROOM_EXTRA_ARGS=
SQUEEZR_EXTRA_ARGS=

# Unified dashboard served by apx-gateway on http://${BIND_HOST}:${GATEWAY_PORT}/
APX_DASHBOARD_ENABLED=1
# Optional shared secret for the dashboard. Required when BIND_HOST is not loopback.
# APX_DASHBOARD_TOKEN=""
# In-memory request history ring buffer size (per gateway process).
APX_HISTORY_SIZE=500
# Prometheus-compatible /metrics endpoint. Off by default.
APX_METRICS_ENABLED=0
# Maximum request body forwarded through the gateway (bytes).
# APX_MAX_REQUEST_BYTES=67108864
