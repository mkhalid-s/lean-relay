# apx configuration.
#
# Routing model:
#   APX_CHAIN is the authoritative ordered list of local services between the
#   gateway and the upstream (Anthropic). All *_ENABLED flags and
#   *_TARGET_API_URL values below are derived from it and rewritten by
#   `apx mode` and `apx chain`. Do not hand-edit those flags; use:
#
#     apx mode headroom-pxpipe
#     apx chain set headroom,pxpipe
#     apx chain clear                 # equivalent to `apx mode direct`
#
# From a devcontainer, point Claude Code at:
#   http://host.docker.internal:${GATEWAY_PORT}

BIND_HOST=127.0.0.1
# Prefer `apx port set <service> <port>` after install so derived chain URLs
# are refreshed with the changed port.
GATEWAY_PORT=8787
PXPIPE_PORT=47821
HEADROOM_PORT=8788
SQUEEZR_PORT=18780
SQUEEZR_MITM_PORT=18781
GATEWAY_ENABLED=1
# Service lifecycle: auto selects launchd (macOS), systemd --user, then nohup.
APX_SERVICE_BACKEND=auto
# Claude client topology: local, docker-host, custom, or none.
APX_CLIENT_TOPOLOGY=none
# Claude client URL. Set by `apx claude set`; empty defaults to 127.0.0.1.
APX_CLIENT_BASE_URL=
# Ordered chain of local services; comma-separated, empty means direct-to-upstream.
APX_CHAIN="headroom"
HEADROOM_ENABLED=1
PXPIPE_ENABLED=0
SQUEEZR_ENABLED=0

# LaunchAgent-safe working directory. Keep this outside protected repo paths.
WORKDIR="${HOME}"

# Commands. The wrapper supplies PATH for launchd and normal shells.
GATEWAY_CMD="$HOME/.local/bin/apx-gateway"
SQUEEZR_CMD="$HOME/.local/bin/apx-squeezr"
# Pinned for reproducible apx-managed startup. Override only when validating a newer Squeezr release.
SQUEEZR_PACKAGE_SPEC="squeezr-ai@1.99.2"
PXPIPE_CMD="npx -y pxpipe-proxy@0.8.0"
# Persistent pxpipe image-compression allowlist. Dashboard model chips are runtime-only.
PXPIPE_MODELS="claude-fable-5,claude-opus-4-8,claude-opus-4-7,claude-sonnet-5,claude-sonnet-4-6,gpt-5.6,gpt-5.5"
HEADROOM_CMD="headroom proxy"
# Final upstream API endpoint. `apx target set <url>` updates this and
# re-derives the current chain's *_TARGET_API_URL values below.
APX_TARGET_API_URL="https://api.anthropic.com"
PXPIPE_TARGET_API_URL="https://api.anthropic.com"
HEADROOM_TARGET_API_URL="https://api.anthropic.com"
SQUEEZR_TARGET_API_URL="https://api.anthropic.com"
GATEWAY_TARGET_API_URL="http://127.0.0.1:8788"

# Headroom behavior.
HEADROOM_MODE=token
HEADROOM_ENABLE_TOOL_SEARCH=true
HEADROOM_CODE_AWARE_ENABLED=1
HEADROOM_CODE_GRAPH=0
HEADROOM_NO_RATE_LIMIT=1
HEADROOM_NO_SUBSCRIPTION_TRACKING=1
HEADROOM_NO_TELEMETRY=1
# Keeps cert verification on, but relaxes OpenSSL's strict CA extension check for corporate/local CA bundles.
HEADROOM_TLS_STRICT=0
# Optional CA bundle used by launchd-started Python/Node tools. Leave empty if not needed.
CA_BUNDLE_FILE="${HOME}/.certs/ca-bundle.pem"
# Stable cache for tiktoken encoder files; avoids launchd/temp-dir cache misses.
TIKTOKEN_CACHE_DIR="${HOME}/.cache/tiktoken"

# Supervisor behavior.
HEALTH_INTERVAL_SECONDS=10
STARTUP_TIMEOUT_SECONDS=45
RESTART_BACKOFF_SECONDS=3
ADOPT_EXISTING=1

# Optional extra args, appended verbatim.
PXPIPE_EXTRA_ARGS=
HEADROOM_EXTRA_ARGS=
SQUEEZR_EXTRA_ARGS=

# Unified dashboard served by apx-gateway on http://${BIND_HOST}:${GATEWAY_PORT}/
APX_DASHBOARD_ENABLED=1
# Optional shared secret for the dashboard. Required when BIND_HOST is not loopback.
# APX_DASHBOARD_TOKEN=""
# In-memory request history ring buffer size (per gateway process).
APX_HISTORY_SIZE=500
# Maximum live dashboard SSE connections from one client address.
APX_MAX_EVENT_STREAMS_PER_IP=4
# Prometheus-compatible /metrics endpoint. Off by default.
APX_METRICS_ENABLED=0
# Maximum request body forwarded through the gateway (bytes).
# APX_MAX_REQUEST_BYTES=67108864

# --- Metrics data plane (0.4.0+) ---
# What per-request data the gateway captures. Levels:
#   metadata (default) - timing, status, model, token counts, cost. Never request/response bodies.
#   full               - metadata + first ~64KB of request body (redacted keys) + first ~64KB of response.
#                        REQUIRES explicit acknowledgment: set APX_CAPTURE_FULL_ACK=i-understand.
# Recording is entirely local (SQLite + JSONL under $APX_STATE_DIR). No data leaves your box.
APX_CAPTURE=metadata
# Acknowledgment required to enable APX_CAPTURE=full. Any other value makes the gateway refuse to start.
APX_CAPTURE_FULL_ACK=
# Comma-separated additional header/body keys to redact even in metadata mode.
# apx already redacts: authorization, cookie, set-cookie, x-api-key, api-key, proxy-authorization,
# x-anthropic-api-key, openai-organization, x-goog-api-key, x-amz-*.
APX_REDACT_KEYS=

# SQLite metrics store. Set APX_METRICS_DB="" to disable durable metrics (JSONL still writes).
APX_METRICS_DB="${HOME}/.local/state/apx/metrics.db"
# Retention: rows older than N days are pruned on the daily vacuum. 0 = never prune.
APX_METRICS_RETENTION_DAYS=30
# Backfill on first start: import existing history/*.jsonl into SQLite if the DB is fresh.
APX_METRICS_BACKFILL=1
