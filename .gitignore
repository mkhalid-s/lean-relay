.DS_Store
__pycache__/
*.py[cod]

# Runtime state and logs generated by apx
state/**
!state/.gitkeep
*.log
*.pid
*.adopted.pid

# Local runtime backups created by install.sh
*.bak.*

# Local/private config overrides
*.local
.env
.env.*

# Build outputs (dist/apx.sh + sha256) are release artifacts, not committed.
dist/
